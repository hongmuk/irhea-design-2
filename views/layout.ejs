<!DOCTYPE html>
<html lang="ko">
<head>
  <%- include('partials/head') %>
</head>
<body class="ir-theme">
  <div class="viewport">
    <%- include('partials/topbar') %>
    
    <main class="viewport-main" style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
      <%- include('pages/' + page) %>
    </main>

    <%- include('partials/bottomnav') %>
  </div>

  <%- include('partials/modal') %>
  <%- include('partials/toast') %>

  <!-- PWA install banner — 브라우저 모드일 때만 표시 (install.js 가 토글) -->
  <div id="pwa-install-banner" class="pib" role="status" aria-live="polite" hidden>
    <span class="pib-msg">풀스크린 모드로 사용하려면 홈 화면에 추가하세요.</span>
    <button class="pib-install" type="button" hidden>홈 화면에 추가</button>
    <button class="pib-close" type="button" aria-label="닫기" title="닫기">✕</button>
  </div>

</body>
</html>
