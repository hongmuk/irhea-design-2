<!DOCTYPE html>
<html lang="ko">
<head>
  <%- include('partials/head') %>
</head>
<body class="ir-theme">
  <div class="viewport">
    <%- include('partials/topbar') %>
    
    <main class="viewport-main" style="flex: 1; display: flex; flex-direction: column; min-height: 0;">
      <%- include('pages/' + page) %>
    </main>

    <%- include('partials/bottomnav') %>
  </div>

  <%- include('partials/modal') %>
  <%- include('partials/toast') %>

  <!-- Shared fitscreen script for 1280x800 target -->
  <script>
    (function() {
      const W = 1280, H = 800;
      function fit() {
        const sw = window.innerWidth / W;
        const sh = window.innerHeight / H;
        const s = Math.min(sw, sh);
        // Only scale down if viewport is smaller, or scale to fit
        document.body.style.transform = 'scale(' + s + ')';
        document.body.style.transformOrigin = 'center center';
      }
      window.addEventListener('resize', fit);
      fit();
    })();
  </script>

  <% if (page === 'dashboard' || page === 'main') { %><script src="/js/pages/dashboard.js"></script><% } %>
  <% if (page === 'settings-general') { %><script src="/js/pages/settings.js"></script><% } %>
</body>
</html>
