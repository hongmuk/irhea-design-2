<!-- 추출 완료 (Design 2 Cinema Gold Light) -->
<div class="ir-shell">

  <!-- Background (blurred main dashboard) -->
  <div class="brew-complete-backdrop">
    <div style="flex:1; display:grid; grid-template-columns: repeat(5, 1fr); gap: 10px; opacity: 0.1; filter: blur(6px);">
      <% for (var i = 0; i < 5; i++) { %><div style="background:#C5A059; border:1px solid #E0C896;"></div><% } %>
    </div>
  </div>

  <!-- Center Overlay Band -->
  <div class="brew-complete-overlay-gold">
    <div class="ov-left">
      <div class="ov-cup">
        <svg viewBox="0 0 40 40" width="52" height="52">
          <path d="M10,15 L10,30 Q10,35 20,35 L20,35 Q30,35 30,30 L30,15 Z" fill="none" stroke="var(--ir-orange)" stroke-width="2"/>
          <path d="M30,18 C35,18 35,26 30,26" fill="none" stroke="var(--ir-orange)" stroke-width="2"/>
          <path d="M8,15 L32,15" stroke="var(--ir-orange)" stroke-width="1.5"/>
        </svg>
        <div class="ov-title">BREWING <span class="accent">COMPLETE</span></div>
      </div>
      <div class="ov-time">
        <span class="ov-time-big">03:42</span>
        <span class="ov-time-unit">SEC</span>
        <span class="ov-delta">▲ 3s</span>
      </div>
      <div class="ov-time-target">TARGET: 03:45 · RECIPE 03</div>
    </div>

    <div class="ov-right">
      <div class="ov-donut">
        <svg viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="46" fill="none" stroke="rgba(255,255,255,0.08)" stroke-width="2"/>
          <circle cx="50" cy="50" r="46" fill="none" stroke="var(--ir-orange)" stroke-width="3" stroke-dasharray="289" stroke-dashoffset="0" stroke-linecap="round" transform="rotate(-90 50 50)"/>
        </svg>
        <div class="ov-donut-num">
          <span class="pct">100</span>
          <span class="lbl">PERCENT</span>
        </div>
      </div>
      <div class="ov-meta">
        <div class="ov-meta-row">YIELD: <b>312.4g</b></div>
        <div class="ov-meta-row">AVG TEMP: <b>93.2°C</b></div>
      </div>
    </div>

    <div class="ov-progress-bar-gold"></div>
    <div class="ov-close-hint">5초 후 자동 닫힘 · 호출 화면(S6.2)으로 복귀</div>
  </div>

  <footer class="ir-action-bar-gold">
    <button class="ir-btn" id="bc-cancel">취소</button>
    <button class="ir-btn" id="bc-save">저장</button>
    <button class="ir-btn" id="bc-fav">즐겨찾기 등록</button>
    <div style="flex:1;"></div>
    <button class="ir-btn ir-btn-primary" id="bc-confirm">확인</button>
  </footer>

</div>

<style>
  .brew-complete-backdrop { position: absolute; inset: 0; padding: 20px; display: flex; flex-direction: column; z-index: 0; }
  
  .brew-complete-overlay-gold {
    position: absolute; left: 0; right: 0; top: 0; bottom: 72px;
    background: linear-gradient(180deg, #1D1D1F 0%, #2A2A2A 100%);
    color: #FFFFFF;
    box-shadow: 0 40px 100px rgba(0,0,0,0.6);
    display: flex; align-items: stretch; padding: 40px 80px; gap: 70px;
    z-index: 10; overflow: hidden;
  }
  .brew-complete-overlay-gold::before {
    content: ''; position: absolute; inset: 0; pointer-events: none;
    background: radial-gradient(circle at 15% 50%, rgba(197,160,89,0.12) 0%, transparent 65%);
  }

  .ov-left { flex: 1; display: flex; flex-direction: column; justify-content: center; gap: 24px; position: relative; }
  .ov-cup { display: flex; align-items: center; gap: 18px; }
  .ov-title { font-family: var(--ir-font-display); font-size: 34px; font-weight: 500; letter-spacing: 0.05em; color: #FFF; text-transform: uppercase; }
  .ov-title .accent { color: var(--ir-orange); font-style: italic; }

  .ov-time { display: flex; align-items: baseline; gap: 12px; }
  .ov-time-big { font-size: 72px; font-weight: 300; font-family: var(--ir-font-mono); color: #FFF; letter-spacing: -0.02em; }
  .ov-time-unit { font-size: 14px; font-weight: 700; color: rgba(255,255,255,0.3); letter-spacing: 0.2em; text-transform: uppercase; }
  .ov-time-target { font-size: 13px; color: rgba(255,255,255,0.4); font-weight: 600; font-family: var(--ir-font-mono); }
  .ov-delta { font-size: 12px; padding: 4px 12px; background: rgba(197,160,89,0.2); color: var(--ir-orange); font-weight: 800; border-radius: 2px; }

  .ov-right { width: 320px; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 20px; position: relative; }
  .ov-donut { width: 170px; height: 170px; position: relative; }
  .ov-donut svg { width: 100%; height: 100%; }
  .ov-donut-num { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; }
  .ov-donut-num .pct { font-size: 52px; font-weight: 400; color: #FFF; font-family: var(--ir-font-mono); }
  .ov-donut-num .lbl { font-size: 10px; font-weight: 800; color: rgba(255,255,255,0.3); letter-spacing: 0.25em; text-transform: uppercase; }
  
  .ov-meta { display: flex; flex-direction: column; gap: 10px; align-items: center; }
  .ov-meta-row { font-size: 13px; color: rgba(255,255,255,0.6); font-weight: 600; letter-spacing: 0.05em; }
  .ov-meta-row b { color: #FFF; font-weight: 800; }

  .ov-progress-bar-gold { position: absolute; left: 0; right: 0; bottom: 0; height: 3px; background: rgba(255,255,255,0.05); }
  .ov-progress-bar-gold::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 100%; background: var(--ir-orange); animation: ir-countdown 5s linear forwards; }
  .ov-close-hint { position: absolute; right: 28px; bottom: 12px; font-size: 10px; color: rgba(255,255,255,0.3); font-weight: 800; letter-spacing: 0.1em; }

  .ir-action-bar-gold { height: 72px; padding: 0 32px; border-top: 1px solid var(--ir-line); display: flex; align-items: center; gap: 10px; background: var(--ir-bg-2); position: absolute; bottom: 0; left: 0; right: 0; z-index: 20; }
</style>

<script>
(function() {
  var autoTimer = setTimeout(function () { window.location.href = '/main'; }, 5000);
  function cancelAuto() { clearTimeout(autoTimer); var hint = document.querySelector('.ov-close-hint'); if (hint) hint.style.display = 'none'; var bar = document.querySelector('.ov-progress-bar-gold'); if (bar) bar.style.display = 'none'; }

  document.getElementById('bc-cancel').onclick = function () { cancelAuto(); window.location.href = '/main'; };
  document.getElementById('bc-save').onclick = function () { cancelAuto(); window.IRToast?.show('추출 결과를 저장했습니다.'); };
  document.getElementById('bc-fav').onclick = function () { cancelAuto(); window.IRToast?.show('즐겨찾기에 추가되었습니다.'); };
  document.getElementById('bc-confirm').onclick = function () { cancelAuto(); window.location.href = '/main'; };
})();
</script>
