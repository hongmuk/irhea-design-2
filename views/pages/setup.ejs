<!-- 최초 장비 정보 설정 (S1.6) — designs/02-initial-setup.html 정합. Topbar는 layout.ejs. -->

<div class="setup-shell">
  <div class="heading-bar">
    <div class="heading-kicker">최초 설정</div>
    <div class="heading-title">장비 정보 입력<em> · 최초 1회</em></div>
    <div class="heading-sub">아래 정보를 확인하고 필요 시 수정 후 저장하세요. 저장 후 자동으로 다음 단계로 이동합니다.</div>
  </div>

  <div class="card-wrap">
    <div class="card">
      <div class="card-h">
        <span class="card-title">장비 정보</span>
      </div>

      <div class="rows">
        <div class="row edit">
          <span class="row-k">일련 번호</span>
          <input class="row-v" id="setup-serial" value="R5KrW2600001" />
          <span class="row-tag edit">EDIT</span>
        </div>
        <div class="row edit">
          <span class="row-k">모델 번호</span>
          <input class="row-v" id="setup-model" value="iRHEA-Light-M5" />
          <span class="row-tag edit">EDIT</span>
        </div>
        <div class="row">
          <span class="row-k">펌웨어 버전</span>
          <span class="row-v" id="setup-fw">1.0</span>
          <span class="row-tag ro">READ-ONLY</span>
        </div>
        <div class="row">
          <span class="row-k">펌웨어 업데이트 일자</span>
          <span class="row-v" id="setup-fw-date">2026.03.01</span>
          <span class="row-tag ro">READ-ONLY</span>
        </div>
        <div class="row edit">
          <span class="row-k">타임존</span>
          <select class="row-v kr" id="setup-tz">
            <option>아시아 / 서울</option>
            <option>아시아 / 도쿄</option>
            <option>아시아 / 상하이</option>
            <option>UTC</option>
          </select>
          <span class="row-tag edit">EDIT</span>
        </div>
      </div>
    </div>
  </div>

  <div class="setup-ab">
    <div class="ab-l">저장 후 자동으로 <b>장치 연결</b> 단계로 이동합니다.</div>
    <button class="save-btn" id="btn-setup-save">저장하고 다음</button>
  </div>
</div>

<style>
  /* setup — designs/02-initial-setup.html 정합 */
  .setup-shell { flex: 1; display: flex; flex-direction: column; background: #F4F4F2; overflow-y: auto; }
  .heading-bar { padding: 22px 0 12px; text-align: center; flex-shrink: 0; }
  .heading-kicker { font-size: 11px; color: var(--brand); font-weight: 700; letter-spacing: 3px; text-transform: uppercase; }
  .heading-title { font-size: 22px; font-weight: 700; color: var(--ink); letter-spacing: -0.5px; margin-top: 6px; }
  .heading-title em { font-style: normal; font-weight: 500; color: var(--ink-3); }
  .heading-sub { font-size: 12px; color: var(--ink-3); font-weight: 500; margin-top: 4px; }

  .card-wrap { flex: 1; display: flex; align-items: center; justify-content: center; padding: 24px; }
  .card { width: 640px; background: var(--bg); border: 1px solid var(--hair-2); padding: 38px 44px 32px; box-shadow: 0 12px 40px rgba(0,0,0,0.06), 0 2px 6px rgba(0,0,0,0.04); }
  .card-h { padding-bottom: 18px; border-bottom: 1px solid var(--hair); margin-bottom: 18px; display: flex; align-items: baseline; justify-content: space-between; }
  .card-title { font-size: 16px; font-weight: 700; color: var(--ink); letter-spacing: -0.3px; }
  .card-id { font-size: clamp(11.5px, 1vw + 7px, 14px); color: var(--ink-3); font-weight: 600; letter-spacing: 0.5px; font-variant-numeric: tabular-nums; }

  .rows { display: flex; flex-direction: column; gap: 4px; }
  .row { display: grid; grid-template-columns: 200px 1fr auto; gap: 12px; align-items: center; padding: 14px 0; border-top: 1px solid var(--hair); }
  .row:first-of-type { border-top: none; }
  /* 위계: 라벨(작은 회색) ↔ 값(굵은 검정 모노) — 차이로 가독성 */
  .row-k { font-size: 12.5px; color: var(--ink-3); font-weight: 600; letter-spacing: -0.1px; }
  .row-v { font-size: 15px; font-weight: 700; color: var(--ink); font-family: var(--font-mono); letter-spacing: 0.3px; }
  .row-v.kr { font-family: var(--font-main); letter-spacing: -0.2px; }
  .row.edit .row-v { color: var(--brand); border: none; border-bottom: 1.5px dashed var(--brand); padding: 0 0 2px; background: transparent; outline: none; width: 100%; font-family: var(--font-mono); }
  .row.edit select.row-v { -webkit-appearance: none; appearance: none; cursor: pointer; }
  .row.edit .row-v:focus { border-bottom-style: solid; }
  .row-tag { font-size: clamp(11px, 0.9vw + 7px, 13px); padding: 3px 7px; font-weight: 700; letter-spacing: 0.4px; }
  .row-tag.edit { background: var(--brand); color: #FFF; }
  .row-tag.ro { background: transparent; color: var(--ink-3); border: 1px solid var(--hair-2); }

  .setup-ab { padding: 18px 24px; display: flex; align-items: center; justify-content: space-between; flex-shrink: 0; gap: 12px; }
  .ab-l { font-size: 11px; color: var(--ink-3); font-weight: 500; }
  .ab-l b { color: var(--ink-2); font-weight: 700; }
  .save-btn { padding: 14px 42px; font-size: 13px; font-weight: 700; background: var(--brand); color: #FFF; border: 1px solid var(--brand); cursor: pointer; letter-spacing: 0.3px; transition: all 0.15s; box-shadow: 0 6px 20px rgba(230,0,18,0.18); font-family: inherit; }
  .save-btn:hover { background: #C8000F; box-shadow: 0 8px 24px rgba(230,0,18,0.28); }
</style>

<script>
(function () {
  fetch('/api/system-config').then(r => r.json()).then(function (sc) {
    if (sc.serialNumber) document.getElementById('setup-serial').value = sc.serialNumber;
    if (sc.modelName) document.getElementById('setup-model').value = sc.modelName;
    if (sc.firmwareVersion) document.getElementById('setup-fw').textContent = sc.firmwareVersion;
    if (sc.firmwareDate) document.getElementById('setup-fw-date').textContent = sc.firmwareDate;
  });
  document.getElementById('btn-setup-save').addEventListener('click', function () {
    fetch('/api/system-config/configure', { method: 'POST' }).then(function () {
      window.location.href = '/connect';
    });
  });
})();
</script>
