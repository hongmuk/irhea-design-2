<!-- 추출 중 (Design 2 Cinema Gold Light) -->
<div class="ir-shell">

  <main class="ir-brew-body">
    <!-- Header -->
    <div class="ir-brew-header">
      <div class="ir-brew-kicker">NOW BREWING</div>
      <h1 class="ir-brew-title">NT-iRHEA <em>Spout 1</em></h1>
      <p class="ir-brew-recipe">RECIPE 03 · Ethiopia Aricha G1</p>
    </div>

    <!-- Main visual area -->
    <div class="ir-brew-visual">
      <div class="ir-brew-ring-wrap">
        <svg viewBox="0 0 200 200" width="240" height="240">
          <circle cx="100" cy="100" r="95" fill="none" stroke="var(--ir-line)" stroke-width="2"/>
          <circle id="brew-ring-outer" cx="100" cy="100" r="95" fill="none" stroke="var(--ir-orange)" stroke-width="4"
            stroke-dasharray="597" stroke-dashoffset="597" stroke-linecap="round" transform="rotate(-90 100 100)"/>
          
          <circle cx="100" cy="100" r="75" fill="none" stroke="var(--ir-line-soft)" stroke-width="1"/>
          <text x="100" y="98" text-anchor="middle" font-family="var(--ir-font-mono)" font-size="44" font-weight="400" fill="var(--ir-fg)" id="brew-pct">0%</text>
          <text x="100" y="128" text-anchor="middle" font-family="var(--ir-font-mono)" font-size="11" font-weight="700" fill="var(--ir-fg-subtle)" style="letter-spacing: 0.15em;">EXTRACTING</text>
        </svg>
      </div>

      <!-- Real-time metrics grid -->
      <div class="ir-brew-metrics">
        <div class="ir-metric">
          <div class="lbl">ELAPSED</div>
          <div class="val" id="brew-elapsed">00:00</div>
        </div>
        <div class="ir-metric gold">
          <div class="lbl">TEMP</div>
          <div class="val" id="brew-temp">95.0°C</div>
        </div>
        <div class="ir-metric">
          <div class="lbl">REMAINING</div>
          <div class="val" id="brew-remaining">03:45</div>
        </div>
        <div class="ir-metric">
          <div class="lbl">FLOW RATE</div>
          <div class="val" id="brew-flow">3.5 <span class="unit">g/s</span></div>
        </div>
        <div class="ir-metric">
          <div class="lbl">WEIGHT</div>
          <div class="val" id="brew-weight">0.0 <span class="unit">g</span></div>
        </div>
      </div>
    </div>

    <!-- Stage Progress Bar -->
    <div class="ir-brew-stages-wrap">
      <div class="ir-brew-stages-lbl">BREWING STAGES PROGRESS</div>
      <div class="ir-brew-stages" id="brew-stages-container">
        <!-- Stages injected by JS -->
      </div>
    </div>

  </main>

  <footer class="ir-action-bar-gold">
    <button class="ir-btn ir-btn-danger" id="btn-stop">STOP BREWING</button>
    <div style="flex:1;"></div>
    <div style="font-family: var(--ir-font-display); font-style: italic; color: var(--ir-fg-subtle); font-size: 14px;">Specialty Coffee Excellence</div>
  </footer>

</div>

<style>
  .ir-brew-body { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 40px; background: var(--ir-bg); }
  
  .ir-brew-header { text-align: center; margin-bottom: 40px; }
  .ir-brew-kicker { font-size: 11px; color: var(--ir-orange); font-weight: 800; letter-spacing: 0.25em; text-transform: uppercase; }
  .ir-brew-title { font-family: var(--ir-font-display); font-size: 36px; font-weight: 400; color: var(--ir-fg); margin: 8px 0; letter-spacing: -0.01em; }
  .ir-brew-title em { font-style: italic; color: var(--ir-orange-deep); font-weight: 500; }
  .ir-brew-recipe { font-size: 14px; font-weight: 600; color: var(--ir-fg-subtle); font-family: var(--ir-font-mono); letter-spacing: 0.05em; }

  .ir-brew-visual { display: flex; align-items: center; gap: 60px; margin-bottom: 56px; }
  
  .ir-brew-metrics { display: grid; grid-template-columns: 150px 150px; gap: 16px; }
  .ir-metric { padding: 16px; border: 1px solid var(--ir-line); background: var(--ir-bg-2); border-radius: var(--ir-radius); }
  .ir-metric.gold { border-color: var(--ir-orange); background: rgba(197,160,89,0.03); }
  .ir-metric .lbl { font-size: 9px; font-weight: 800; color: var(--ir-fg-subtle); letter-spacing: 0.1em; margin-bottom: 6px; text-transform: uppercase; }
  .ir-metric .val { font-size: 24px; font-weight: 400; color: var(--ir-fg); font-family: var(--ir-font-mono); }
  .ir-metric .unit { font-size: 11px; color: var(--ir-fg-subtle); margin-left: 2px; }

  .ir-brew-stages-wrap { width: 640px; }
  .ir-brew-stages-lbl { font-size: 10px; font-weight: 800; color: var(--ir-fg-subtle); letter-spacing: 0.15em; margin-bottom: 14px; text-align: center; text-transform: uppercase; }
  .ir-brew-stages { display: flex; height: 36px; background: var(--ir-bg-3); border: 1px solid var(--ir-line); padding: 4px; gap: 4px; border-radius: 4px; }
  .ir-stage-item { flex: 1; height: 100%; background: #FFF; position: relative; overflow: hidden; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 800; color: var(--ir-fg-subtle); transition: all 0.3s; border-radius: 2px; }
  .ir-stage-item.active { background: var(--ir-orange); color: #FFF; }
  .ir-stage-item.done { background: var(--ir-fg); color: #FFF; }
  .ir-stage-item .fill { position: absolute; left: 0; top: 0; bottom: 0; background: rgba(255,255,255,0.25); width: 0%; }

  .ir-action-bar-gold { height: 72px; padding: 0 32px; border-top: 1px solid var(--ir-line); display: flex; align-items: center; background: var(--ir-bg-2); }
</style>

<script>
(function() {
  var progress = 0;
  var elapsed = 0;
  var total = 225; // 3:45

  var stages = [
    { name: 'BLOOM', dur: 45 },
    { name: '1ST', dur: 45 },
    { name: '2ND', dur: 45 },
    { name: '3RD', dur: 45 },
    { name: '4TH', dur: 45 }
  ];

  var container = document.getElementById('brew-stages-container');
  stages.forEach((s, idx) => {
    var el = document.createElement('div');
    el.className = 'ir-stage-item';
    el.innerHTML = `<span>${s.name}</span><div class="fill" id="stage-fill-${idx}"></div>`;
    container.appendChild(el);
  });

  function fmt(s) {
    var m = Math.floor(s / 60), sec = s % 60;
    return String(m).padStart(2, '0') + ':' + String(sec).padStart(2, '0');
  }

  var timer = setInterval(function() {
    elapsed++;
    progress = Math.min(100, Math.floor((elapsed / total) * 100));
    
    document.getElementById('brew-pct').textContent = progress + '%';
    document.getElementById('brew-elapsed').textContent = fmt(elapsed);
    document.getElementById('brew-remaining').textContent = fmt(total - elapsed);
    document.getElementById('brew-weight').innerHTML = (elapsed * 1.4).toFixed(1) + ' <span class="unit">g</span>';
    
    var ring = document.getElementById('brew-ring-outer');
    ring.style.strokeDashoffset = 597 * (1 - progress / 100);

    // Update stages
    var runningDur = 0;
    stages.forEach((s, idx) => {
      var el = container.children[idx];
      var fill = el.querySelector('.fill');
      if (elapsed > runningDur + s.dur) {
        el.className = 'ir-stage-item done';
        fill.style.width = '100%';
      } else if (elapsed > runningDur) {
        el.className = 'ir-stage-item active';
        fill.style.width = ((elapsed - runningDur) / s.dur * 100) + '%';
      } else {
        el.className = 'ir-stage-item';
        fill.style.width = '0%';
      }
      runningDur += s.dur;
    });

    if (elapsed >= total) {
      clearInterval(timer);
      setTimeout(function() {
        window.location.href = '/brewing/complete';
      }, 500);
    }
  }, 100);

  document.getElementById('btn-stop').addEventListener('click', function() {
    window.IRModal.confirm({
      title: 'STOP BREWING',
      body: '추출을 중단하시겠습니까?<br>ARE YOU SURE TO ABORT?',
      onOk: function() {
        clearInterval(timer);
        window.location.href = '/main';
      }
    });
  });
})();
</script>
