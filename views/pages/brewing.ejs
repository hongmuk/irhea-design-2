<!-- 추출 중 (Design 2 Cinema Gold Light) -->
<div class="ir-shell">

  <!-- 회의 피드백 v1.2: 영문 → 한글, 단계 표시 명확화, "현 단계" 직접 명시 -->
  <main class="ir-brew-body">
    <!-- Header -->
    <div class="ir-brew-header">
      <div class="ir-brew-kicker">추출 중</div>
      <h1 class="ir-brew-title">추출구 <em>1</em></h1>
      <p class="ir-brew-recipe" id="brew-recipe-line">에티오피아 예가체프  ·  원두 20g · 비율 1:16 · 추출 320g</p>
    </div>

    <!-- 중앙: 전체 진행률 링 + 현 단계 라벨 -->
    <div class="ir-brew-visual">
      <div class="ir-brew-ring-wrap">
        <svg viewBox="0 0 200 200" width="240" height="240">
          <circle cx="100" cy="100" r="95" fill="none" stroke="var(--ir-line)" stroke-width="2"/>
          <circle id="brew-ring-outer" cx="100" cy="100" r="95" fill="none" stroke="var(--ir-orange)" stroke-width="4"
            stroke-dasharray="597" stroke-dashoffset="597" stroke-linecap="round" transform="rotate(-90 100 100)"/>
          <circle cx="100" cy="100" r="75" fill="none" stroke="var(--ir-line-soft)" stroke-width="1"/>
          <text x="100" y="92" text-anchor="middle" font-family="var(--ir-font-mono)" font-size="36" font-weight="400" fill="var(--ir-fg)" id="brew-pct">0%</text>
          <text x="100" y="115" text-anchor="middle" font-family="var(--ir-font-mono)" font-size="10" font-weight="700" fill="var(--ir-fg-subtle)" style="letter-spacing: 0.15em;">전체 진행률</text>
          <text x="100" y="138" text-anchor="middle" font-family="var(--ir-font-display)" font-size="13" font-weight="600" fill="var(--ir-orange-deep)" id="brew-stage-label">대기</text>
        </svg>
      </div>

      <!-- 메트릭 — 회의 피드백: 저울 없음 → 추정값임 명시 + estimation 공식 표시 -->
      <div class="ir-brew-metrics">
        <div class="ir-metric">
          <div class="lbl">경과</div>
          <div class="val" id="brew-elapsed">00:00</div>
          <div class="sublbl">/ <span id="brew-total-est">03:45</span> 예상</div>
        </div>
        <div class="ir-metric gold">
          <div class="lbl">물 온도</div>
          <div class="val" id="brew-temp">95.0°C</div>
          <div class="sublbl">보일러 설정</div>
        </div>
        <div class="ir-metric">
          <div class="lbl">남은 시간</div>
          <div class="val" id="brew-remaining">03:45</div>
          <div class="sublbl">웨이팅 포함</div>
        </div>
        <div class="ir-metric">
          <div class="lbl">유속</div>
          <div class="val" id="brew-flow">3.5 <span class="unit">g/s</span></div>
          <div class="sublbl">현 단계</div>
        </div>
        <div class="ir-metric">
          <div class="lbl">추정 추출량</div>
          <div class="val" id="brew-weight">0 <span class="unit">g</span></div>
          <div class="sublbl">/ 목표 <span id="brew-target">320g</span> · 펌프시간×유속</div>
        </div>
      </div>
    </div>

    <!-- 단계별 진행 (회의 피드백: 휴지 → 다음 단계 흐름 명확화) -->
    <div class="ir-brew-stages-wrap">
      <div class="ir-brew-stages-lbl">단계별 진행 <em>(블룸 → 1단계 → 2단계 → … 순차)</em></div>
      <div class="ir-brew-stages" id="brew-stages-container">
        <!-- JS 가 채움 -->
      </div>
    </div>

  </main>

  <footer class="ir-action-bar-gold">
    <button class="ir-btn ir-btn-danger" id="btn-stop">추출 중단</button>
    <div style="flex:1;"></div>
    <div style="font-family: var(--ir-font-display); font-style: italic; color: var(--ir-fg-subtle); font-size: 14px;">Specialty Coffee Excellence</div>
  </footer>

</div>

<style>
  /* 회의 v1.2: viewport 684px 내 fit (8행 + sublbl로 인한 overflow 해소) */
  .ir-brew-body { flex: 1; display: flex; flex-direction: column; align-items: center; padding: 22px 40px 18px; background: var(--ir-bg); overflow-y: auto; }

  .ir-brew-header { text-align: center; margin-bottom: 18px; }
  .ir-brew-kicker { font-size: 11px; color: var(--ir-orange); font-weight: 800; letter-spacing: 0.25em; text-transform: uppercase; }
  .ir-brew-title { font-family: var(--ir-font-display); font-size: 30px; font-weight: 400; color: var(--ir-fg); margin: 6px 0; letter-spacing: -0.01em; }
  .ir-brew-title em { font-style: italic; color: var(--ir-orange-deep); font-weight: 500; }
  .ir-brew-recipe { font-size: 14px; font-weight: 600; color: var(--ir-fg-subtle); font-family: var(--ir-font-mono); letter-spacing: 0.05em; }

  .ir-brew-visual { display: flex; align-items: center; gap: 40px; margin-bottom: 24px; }

  /* 메트릭 3col x 2row (5 cell) 으로 — 더 컴팩트 */
  .ir-brew-metrics { display: grid; grid-template-columns: 140px 140px 140px; gap: 10px; }
  .ir-metric { padding: 10px 12px; border: 1px solid var(--ir-line); background: var(--ir-bg-2); border-radius: var(--ir-radius); }
  .ir-metric.gold { border-color: var(--ir-orange); background: rgba(197,160,89,0.03); }
  .ir-metric .lbl { font-size: 10px; font-weight: 800; color: var(--ir-fg-subtle); letter-spacing: 0.08em; margin-bottom: 4px; text-transform: uppercase; }
  .ir-metric .val { font-size: 22px; font-weight: 400; color: var(--ir-fg); font-family: var(--ir-font-mono); line-height: 1.1; }
  .ir-metric .unit { font-size: 11px; color: var(--ir-fg-subtle); margin-left: 2px; }
  .ir-metric .sublbl { font-size: 10px; font-weight: 600; color: var(--ir-fg-muted); margin-top: 3px; letter-spacing: -0.1px; line-height: 1.3; }

  .ir-brew-stages-wrap { width: 720px; }
  .ir-brew-stages-lbl {
    font-size: 12px; font-weight: 700; color: var(--ir-fg-subtle);
    letter-spacing: 0.04em; margin-bottom: 10px; text-align: center;
  }
  .ir-brew-stages-lbl em {
    font-style: normal; color: var(--ir-fg-muted); font-weight: 500;
    font-size: 11px; margin-left: 6px;
  }
  /* 단계 박스 — 회의 피드백: 각 단계 상태 명확히 (대기/진행/완료) */
  .ir-brew-stages {
    display: flex; height: 50px;
    background: var(--ir-bg-3); border: 1px solid var(--ir-line);
    padding: 4px; gap: 4px; border-radius: 4px;
  }
  .ir-stage-item {
    flex: 1; height: 100%; background: #FFF;
    position: relative; overflow: hidden;
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    font-weight: 700; color: var(--ir-fg-subtle);
    transition: all 0.3s; border-radius: 2px;
    line-height: 1.2;
  }
  .ir-stage-item .lab { font-size: 11px; letter-spacing: -0.1px; z-index: 1; }
  .ir-stage-item .sub { font-size: 9px; font-weight: 600; color: var(--ir-fg-muted); margin-top: 2px; z-index: 1; }
  .ir-stage-item.active { background: var(--ir-orange); color: #FFF; }
  .ir-stage-item.active .sub { color: rgba(255,255,255,0.85); }
  .ir-stage-item.done { background: var(--ir-fg); color: #FFF; }
  .ir-stage-item.done .sub { color: rgba(255,255,255,0.75); }
  .ir-stage-item.done .lab::before { content: '✓ '; }
  .ir-stage-item .fill { position: absolute; left: 0; top: 0; bottom: 0; background: rgba(255,255,255,0.22); width: 0%; }

  .ir-action-bar-gold { height: 72px; padding: 0 32px; border-top: 1px solid var(--ir-line); display: flex; align-items: center; background: var(--ir-bg-2); }
</style>

<script>
(function() {
  var progress = 0;
  var elapsed = 0;
  var total = 225; // 3:45

  // 회의 피드백: 영문 → 한글, 블룸/1단계/2단계/... 순차 + 휴지 시간 별도
  var stages = [
    { name: '블룸',   dur: 45 },
    { name: '1단계', dur: 45 },
    { name: '2단계', dur: 45 },
    { name: '3단계', dur: 45 },
    { name: '4단계', dur: 45 }
  ];

  var container = document.getElementById('brew-stages-container');
  stages.forEach((s, idx) => {
    var el = document.createElement('div');
    el.className = 'ir-stage-item';
    el.innerHTML =
      '<span class="lab">' + s.name + '</span>' +
      '<span class="sub" data-sub>대기</span>' +
      '<div class="fill" id="stage-fill-' + idx + '"></div>';
    container.appendChild(el);
  });

  function fmt(s) {
    var m = Math.floor(s / 60), sec = s % 60;
    return String(m).padStart(2, '0') + ':' + String(sec).padStart(2, '0');
  }

  var timer = setInterval(function() {
    elapsed++;
    progress = Math.min(100, Math.floor((elapsed / total) * 100));
    
    document.getElementById('brew-pct').textContent = progress + '%';
    document.getElementById('brew-elapsed').textContent = fmt(elapsed);
    document.getElementById('brew-remaining').textContent = fmt(total - elapsed);

    // 회의 피드백: 저울 없음 → 펌프 가동시간 × 유속 = 추정 추출량
    // 현재 stage 의 flowRate 와 elapsed-in-stage 로 계산 (간단 mock: 평균 유속 3.5)
    var avgFlow = 3.5; // 평균 유속 (g/s)
    // pumpActiveSec = elapsed − 휴지 시간 (각 stage 사이 약 5s 휴지 가정)
    var waitingPerStage = 5;
    var stagesDone = Math.min(stages.length, Math.floor(elapsed / 45));
    var pumpActive = Math.max(0, elapsed - stagesDone * waitingPerStage);
    var estWeight = Math.round(pumpActive * avgFlow);
    document.getElementById('brew-weight').innerHTML = estWeight + ' <span class="unit">g</span>';
    
    var ring = document.getElementById('brew-ring-outer');
    ring.style.strokeDashoffset = 597 * (1 - progress / 100);

    // Update stages — 회의 피드백: 각 단계 상태 (대기/진행/완료) 명확히
    var runningDur = 0;
    var currentStageIdx = -1;
    stages.forEach((s, idx) => {
      var el = container.children[idx];
      var fill = el.querySelector('.fill');
      var sub = el.querySelector('[data-sub]');
      if (elapsed > runningDur + s.dur) {
        el.className = 'ir-stage-item done';
        fill.style.width = '100%';
        if (sub) sub.textContent = '완료';
      } else if (elapsed > runningDur) {
        el.className = 'ir-stage-item active';
        fill.style.width = ((elapsed - runningDur) / s.dur * 100) + '%';
        if (sub) sub.textContent = '진행 중';
        currentStageIdx = idx;
      } else {
        el.className = 'ir-stage-item';
        fill.style.width = '0%';
        if (sub) sub.textContent = '대기';
      }
      runningDur += s.dur;
    });

    // 중앙 링 안의 단계 라벨
    var stageLabel = document.getElementById('brew-stage-label');
    if (stageLabel) {
      stageLabel.textContent = currentStageIdx < 0
        ? '대기'
        : (stages[currentStageIdx].name + ' 진행 중');
    }

    if (elapsed >= total) {
      clearInterval(timer);
      setTimeout(function() {
        window.location.href = '/brewing/complete';
      }, 500);
    }
  }, 100);

  document.getElementById('btn-stop').addEventListener('click', function() {
    window.IRModal.confirm({
      title: '추출 중단',
      body: '추출을 중단하시겠습니까?',
      bodyClass: 'is-error',
      ok: '중단',
      cancel: '계속 추출',
      onOk: function() {
        clearInterval(timer);
        window.location.href = '/main';
      }
    });
  });
})();
</script>
