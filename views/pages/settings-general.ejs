<!-- 설정 (S3.1) — 다른 설정 페이지와 동일한 settings-shell partial 사용 (디자인 통일) -->
<%- include('../partials/settings-shell', { activeTab: 'general', showSave: true }) %>

<div class="cards">

  <!-- Card 1: 환경설정 -->
  <div class="card">
    <div class="card-head">
      <span class="card-title">환경설정</span>
      <span class="card-id">3.1.3</span>
    </div>
    <div class="cr"><span class="cr-k">추출 단위</span>
      <span class="seg" data-name="unit">
        <span class="seg-i on" data-value="percent">Percent (%)</span>
        <span class="seg-i" data-value="gram">Gram (g)</span>
      </span>
    </div>
    <div class="cr"><span class="cr-k">알람</span>
      <span class="seg" data-name="alarm">
        <span class="seg-i on" data-value="on">예</span>
        <span class="seg-i" data-value="off">아니오</span>
      </span>
    </div>
    <div class="cr"><span class="cr-k">기본 드립퍼</span><button class="cr-v cr-pick" id="sg-dripper">Kalita</button></div>
    <div class="card-foot"><span>일반 환경설정</span></div>
  </div>

  <!-- Card 2: 보일러 — 회의 피드백 v1.2: 웜업 상태 제거 (장비 켜진 시간과 동일) -->
  <div class="card">
    <div class="card-head">
      <span class="card-title">보일러</span>
      <span class="card-id">3.1.4</span>
    </div>
    <div class="cr"><span class="cr-k">설정 온도</span><button class="cr-v cr-pick" id="sg-boiler-set" data-pick="boiler-temp" data-min="80" data-max="95" data-unit="°C" data-label="보일러 설정 온도">95<span class="unit">°C</span></button></div>
    <div class="cr"><span class="cr-k">현재 온도</span><span class="cr-v muted" id="sg-boiler-cur">95.2<span class="unit">°C</span></span></div>
    <div class="card-foot"><span>범위 · 80~95°C · 클릭하여 변경</span></div>
  </div>

  <!-- Card 3: 물붓기 범위 -->
  <div class="card">
    <div class="card-head">
      <span class="card-title">물붓기 범위</span>
      <span class="card-id">3.1.5</span>
    </div>
    <div id="sg-pour-rows"></div>
    <div class="card-foot"><span>범위 · 25~55 mm (반지름)</span></div>
  </div>

  <!-- Card 4: 워터 / 린스 — 회의 피드백 v1.2: 항목/값 가독성 개선 (제목 볼딕 + 단위 명시) -->
  <div class="card">
    <div class="card-head">
      <span class="card-title">워터 / 린스</span>
      <span class="card-id">3.1.6</span>
    </div>
    <table class="ct wr-t">
      <thead><tr><th>항목</th><th>워터</th><th>린스</th></tr></thead>
      <tbody id="sg-wr-rows">
        <tr><th class="wr-row-h">유속<em>ml/s</em></th><td class="wr-water" data-k="speed">—</td><td class="wr-rinse" data-k="speed">—</td></tr>
        <tr><th class="wr-row-h">온도<em>°C</em></th><td class="wr-water" data-k="temp">—</td><td class="wr-rinse" data-k="temp">—</td></tr>
        <tr><th class="wr-row-h">온수량<em>ml</em></th><td class="wr-water" data-k="amount">—</td><td class="wr-rinse" data-k="amount">—</td></tr>
      </tbody>
    </table>
    <div class="card-foot"><span>유속 3~5 / 온도는 보일러 기준</span></div>
  </div>

  <!-- Card 5: 레시피 기본값 — 회의 피드백 v1.2: 빠진 항목 추가 (가이드 디폴트) -->
  <div class="card">
    <div class="card-head">
      <span class="card-title">레시피 기본값</span>
      <span class="card-id">3.1.7</span>
    </div>
    <div class="cr"><span class="cr-k">원두량</span><button class="cr-v cr-pick" id="sg-def-weight" data-pick="def-weight" data-min="10" data-max="40" data-unit="g" data-label="기본 원두량">20<span class="unit">g</span></button></div>
    <div class="cr"><span class="cr-k">추출 비율</span><button class="cr-v cr-pick" id="sg-def-ratio" data-pick="def-ratio" data-label="기본 추출 비율" data-options="1:10,1:12,1:14,1:15,1:16,1:17,1:18,1:20">1:16</button></div>
    <div class="cr"><span class="cr-k">물 온도</span><button class="cr-v cr-pick" id="sg-def-temp" data-pick="def-temp" data-min="80" data-max="95" data-unit="°C" data-label="기본 물 온도">93<span class="unit">°C</span></button></div>
    <div class="cr"><span class="cr-k">기본 분쇄도</span><button class="cr-v cr-pick" id="sg-def-grind" data-pick="def-grind" data-min="1" data-max="40" data-label="기본 분쇄도">18</button></div>
    <div class="card-foot"><span>레시피 추가 시 prefill · 클릭하여 변경</span></div>
  </div>

  <!-- 즐겨찾기 정책 카드 제거 (회의 피드백 v1.2: 의미 불명) -->
  <!-- 펌프 교정 카드 제거 (회의 피드백 v1.2: 관리자 메뉴로 이관) -->

  <!-- Card 6: 장비 제어 — 5/13 §3: 스피커 / LED Bar ON/OFF -->
  <div class="card">
    <div class="card-head">
      <span class="card-title">장비 제어</span>
      <span class="card-id">3.1.8</span>
    </div>
    <div class="cr"><span class="cr-k">태블릿 스피커</span>
      <span class="seg" data-name="speaker-tablet">
        <span class="seg-i on" data-value="on">ON</span>
        <span class="seg-i" data-value="off">OFF</span>
      </span>
    </div>
    <div class="cr"><span class="cr-k">장비 스피커</span>
      <span class="seg" data-name="speaker-device">
        <span class="seg-i on" data-value="on">ON</span>
        <span class="seg-i" data-value="off">OFF</span>
      </span>
    </div>
    <div class="cr"><span class="cr-k">LED Bar #1</span>
      <span class="seg" data-name="led-1">
        <span class="seg-i on" data-value="on">ON</span>
        <span class="seg-i" data-value="off">OFF</span>
      </span>
    </div>
    <div class="cr"><span class="cr-k">LED Bar #2</span>
      <span class="seg" data-name="led-2">
        <span class="seg-i on" data-value="on">ON</span>
        <span class="seg-i" data-value="off">OFF</span>
      </span>
    </div>
    <div class="card-foot"><span>5/13 §3: 태블릿·장비 스피커 / LED Bar 2개</span></div>
  </div>

</div>

<%- include('../partials/settings-shell-close') %>

<style>
  /* settings-general — 카드 그리드만 (탭/액션은 settings-shell partial 사용) */
  .cards { flex: 1; padding: 16px 24px 14px; display: grid; grid-template-columns: repeat(3, 1fr); grid-auto-rows: minmax(0, 1fr); gap: 12px; min-height: 0; overflow-y: auto; }
  .card { background: var(--bg); border: 1px solid var(--hair); padding: 14px 16px 12px; display: flex; flex-direction: column; gap: 8px; min-height: 0; position: relative; overflow: hidden; }
  .card.accent { border: 1px solid var(--brand); background: linear-gradient(180deg, #FFFAFA 0%, var(--bg) 30%); }
  /* 카드 위계: 제목(굵은 검정) / 라벨(작은 회색) / 값(굵은 검정 모노) */
  .card-head { display: flex; align-items: baseline; justify-content: space-between; gap: 8px; padding-bottom: 8px; border-bottom: 1px solid var(--hair); }
  .card-title { font-size: 13.5px; font-weight: 700; color: var(--ink); letter-spacing: -0.2px; }
  .card.accent .card-title { color: var(--brand); }
  .card-badge { font-size: 9px; font-weight: 600; color: var(--brand); letter-spacing: 1px; text-transform: uppercase; }
  .card-id { font-size: 10px; font-weight: 500; color: var(--ink-3); letter-spacing: 0.4px; font-variant-numeric: tabular-nums; }

  .cr { display: grid; grid-template-columns: 1fr auto; gap: 10px; align-items: center; padding: 7px 0; border-top: 1px solid var(--hair); }
  .cr:first-of-type { border-top: none; padding-top: 4px; }
  .cr-k { font-size: 11.5px; color: var(--ink-3); font-weight: 500; letter-spacing: -0.1px; }
  .cr-v { font-size: 13px; color: var(--ink); font-weight: 700; font-variant-numeric: tabular-nums; letter-spacing: -0.2px; }
  .cr-v.muted { color: var(--ink-2); font-weight: 500; }
  .cr-v em { font-style: normal; color: var(--ink-3); font-weight: 400; margin-left: 4px; font-size: 11px; }
  .cr-v .unit { font-size: 10.5px; color: var(--ink-3); font-weight: 500; margin-left: 2px; }

  /* 세그먼트 토글 — 터치 영역 (높이 28+) */
  .seg { display: inline-flex; border: 1px solid var(--hair-2); height: 28px; align-items: stretch; user-select: none; }
  .seg-i { padding: 0 10px; font-size: 11.5px; font-weight: 600; color: var(--ink-3); display: inline-flex; align-items: center; border-right: 1px solid var(--hair-2); cursor: pointer; min-width: 44px; justify-content: center; }
  .seg-i:last-child { border-right: none; }
  .seg-i.on { background: var(--ink); color: #fff; font-weight: 700; }

  .ct { font-size: 11px; font-variant-numeric: tabular-nums; width: 100%; border-collapse: collapse; }
  .ct th { text-align: left; font-weight: 500; color: var(--ink-3); padding: 4px 0; border-bottom: 1px solid var(--hair); font-size: 10px; letter-spacing: 0.3px; text-transform: uppercase; }
  .ct td { padding: 3.5px 0; color: var(--ink); border-bottom: 1px solid var(--hair); font-weight: 500; }
  .ct td:last-child { text-align: right; }
  .ct tr:last-child td { border-bottom: none; }
  .ct .delta-up { color: var(--brand); font-size: 9px; margin-left: 4px; font-weight: 600; }
  .ct .delta-down { color: var(--ink-2); font-size: 9px; margin-left: 4px; font-weight: 600; }

  /* 워터/린스 테이블 가독성 (회의 피드백 v1.2: 항목명 볼딕 + 단위 첨부) */
  .wr-t th { padding: 5px 0; text-align: center; }
  .wr-t th:first-child { text-align: left; }
  .wr-t .wr-row-h {
    text-transform: none; letter-spacing: -0.2px;
    color: var(--ink); font-weight: 700; font-size: 11.5px;
    padding-right: 8px; width: 70px;
  }
  .wr-t .wr-row-h em {
    color: var(--ink-3); font-weight: 500; font-style: normal; font-size: 10px; margin-left: 4px;
  }
  .wr-t td {
    text-align: center !important;
    font-weight: 600; color: var(--ink-2); font-size: 12px;
  }

  .card-foot { margin-top: auto; padding-top: 8px; border-top: 1px solid var(--hair); font-size: 10px; color: var(--ink-3); display: flex; align-items: center; justify-content: space-between; }
  .card-foot a { color: var(--brand); font-weight: 600; text-decoration: none; }

  .fav-slots { display: flex; gap: 6px; margin-top: 2px; }
  .fav-chip { font-size: 10px; padding: 3px 8px; border: 1px solid var(--brand); color: var(--brand); font-weight: 600; }
  .fav-chip.b { border-color: var(--hair-2); color: var(--ink-3); }

  .cr-pick { background: transparent; border: 1px dashed var(--hair-2); padding: 4px 10px; cursor: pointer; font-family: inherit; color: var(--ink); font-size: 13px; font-weight: 600; letter-spacing: -0.2px; }
  .cr-pick:hover { border-color: var(--ink); border-style: solid; }
  .cr-pick::after { content: ' ▾'; color: var(--ink-3); font-size: 9px; }

  .dripper-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; max-width: 360px; }
  .drp-i { padding: 12px 14px; border: 1px solid var(--hair-2); background: var(--bg); cursor: pointer; font-family: inherit; font-size: 13px; font-weight: 600; color: var(--ink-2); text-align: center; }
  .drp-i:hover { border-color: var(--ink); color: var(--ink); }
  .drp-i.is-on { border: 2px solid var(--ink); color: var(--ink); background: #FAFAFA; padding: 11px 13px; }

  /* 시안 매칭 picker — 다른 alert 모달과 같은 톤. v1.1 매칭 (회의 §15) */
  .picker-range-hint {
    font-size: 11.5px; color: var(--ink-3); font-weight: 500;
    text-align: center; letter-spacing: -0.1px;
    margin-bottom: 4px;
  }
  .picker-input-row {
    display: inline-flex; align-items: center; gap: 8px;
    align-self: center;
  }
  .picker-input {
    /* 다른 폼 input 보다 약간 큼 (20px) — picker 의 단일 값 강조 */
    font-size: 20px; font-weight: 700;
    text-align: center; padding: 8px 12px;
    border: 1px solid var(--hair-2); background: var(--bg);
    width: 110px;
    font-family: var(--font-mono);
    color: var(--ink); letter-spacing: -0.5px;
  }
  .picker-input:focus { outline: none; border-color: var(--ink); }
  .picker-unit {
    font-size: 14px; color: var(--ink-3); font-weight: 600;
  }
  .picker-err {
    font-size: 11.5px; color: #DC2626; font-weight: 700;
    min-height: 14px; text-align: center; letter-spacing: -0.1px;
  }
  .picker-err:empty { min-height: 0; }
</style>

<script>
(function () {
  var DRIPPERS = ['Kalita Wave', 'Hario V60', 'Chemex', 'Kono', 'Origami', 'Melita', 'December'];

  // Hydrate from localStorage — 5/13 §3 장비 제어 4개도 포함
  function hydrate() {
    var s = window.IRState.getSettings();
    // Unit seg
    var unitSeg = document.querySelector('.seg[data-name=unit]');
    if (unitSeg) unitSeg.querySelectorAll('.seg-i').forEach(function (i) { i.classList.toggle('on', i.dataset.value === s.unit); });
    // Alarm seg
    var aSeg = document.querySelector('.seg[data-name=alarm]');
    if (aSeg) aSeg.querySelectorAll('.seg-i').forEach(function (i) {
      i.classList.toggle('on', (i.dataset.value === 'on') === !!s.alarm);
    });
    // 5/13 §3 장비 제어 — 기본 ON
    ['speaker-tablet', 'speaker-device', 'led-1', 'led-2'].forEach(function (k) {
      var seg = document.querySelector('.seg[data-name="' + k + '"]');
      if (!seg) return;
      var on = s[k] !== false; // 기본 true
      seg.querySelectorAll('.seg-i').forEach(function (i) {
        i.classList.toggle('on', (i.dataset.value === 'on') === on);
      });
    });
    // Dripper
    document.getElementById('sg-dripper').textContent = s.dripper || 'Kalita Wave';
  }
  hydrate();

  // Segmented controls — persist on click
  var SEG_HANDLERS = {
    'unit':           function (v) { window.IRState.setSetting('unit', v); },
    'alarm':          function (v) { window.IRState.setSetting('alarm', v === 'on'); },
    'speaker-tablet': function (v) { window.IRState.setSetting('speaker-tablet', v === 'on'); },
    'speaker-device': function (v) { window.IRState.setSetting('speaker-device', v === 'on'); },
    'led-1':          function (v) { window.IRState.setSetting('led-1', v === 'on'); },
    'led-2':          function (v) { window.IRState.setSetting('led-2', v === 'on'); }
  };
  document.querySelectorAll('.seg').forEach(function (seg) {
    var name = seg.dataset.name;
    seg.querySelectorAll('.seg-i').forEach(function (i) {
      i.addEventListener('click', function () {
        seg.querySelectorAll('.seg-i').forEach(function (x) { x.classList.remove('on'); });
        i.classList.add('on');
        var handler = SEG_HANDLERS[name];
        if (handler) handler(i.dataset.value);
      });
    });
  });

  // Dripper picker modal
  document.getElementById('sg-dripper').addEventListener('click', function () {
    var overlay = document.getElementById('ir-modal-overlay');
    var title = document.getElementById('ir-modal-title');
    var body = document.getElementById('ir-modal-body');
    var actions = document.getElementById('ir-modal-actions');
    var current = document.getElementById('sg-dripper').textContent.trim();
    title.textContent = '기본 드립퍼 선택';
    body.className = 'ir-modal-body is-info';
    body.style.padding = '14px 18px';
    body.style.textAlign = 'left';
    body.innerHTML = '<div class="dripper-grid">' +
      DRIPPERS.map(function (d) {
        return '<button class="drp-i' + (d === current ? ' is-on' : '') + '" data-d="' + d + '">' + d + '</button>';
      }).join('') + '</div>';
    actions.innerHTML = '';
    var cancel = document.createElement('button');
    cancel.className = 'ir-modal-btn';
    cancel.textContent = '취소';
    cancel.onclick = function () { overlay.classList.remove('is-open'); body.style.cssText = ''; };
    actions.appendChild(cancel);
    body.querySelectorAll('.drp-i').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var d = btn.dataset.d;
        document.getElementById('sg-dripper').textContent = d;
        window.IRState.setSetting('dripper', d);
        overlay.classList.remove('is-open');
        body.style.cssText = '';
        window.IRToast?.show('기본 드립퍼: ' + d);
      });
    });
    overlay.classList.add('is-open');
  });

  // Pour range
  fetch('/api/pour-range').then(r => r.json()).then(function (rows) {
    var html = rows.map(function (r) {
      return '<div class="cr"><span class="cr-k">' + r.cup + ' Cup</span>' +
             '<span class="cr-v">' + r.radius + '<span class="unit">mm</span></span></div>';
    }).join('');
    document.getElementById('sg-pour-rows').innerHTML = html;
  });

  // 펌프 교정 fetch 제거 — 회의 피드백 v1.2: 엔지니어링 메뉴로 이관

  // Water / Rinse — 회의 피드백 v1.2: 가독성 정리 (제목 별도, 값만 단위 없이)
  fetch('/api/water-rinse').then(r => r.json()).then(function (wr) {
    ['speed','temp','amount'].forEach(function (k) {
      var w = document.querySelector('.wr-water[data-k=' + k + ']');
      var r = document.querySelector('.wr-rinse[data-k=' + k + ']');
      if (wr.water && wr.water[k] != null && w) w.textContent = wr.water[k];
      if (wr.rinse && wr.rinse[k] != null && r) r.textContent = wr.rinse[k];
    });
  });

  // Boiler — 표시 + state hydrate
  fetch('/api/boiler-info').then(r => r.json()).then(function (b) {
    if (b.tempSet != null) {
      window.IRState.setSetting('boilerTemp', b.tempSet);
      document.getElementById('sg-boiler-set').innerHTML = b.tempSet + '<span class="unit">°C</span>';
    }
    if (b.tempMax != null) document.getElementById('sg-boiler-cur').innerHTML = b.tempMax + '<span class="unit">°C</span>';
  });

  // ─── 회의 v1.1 / 5/24 §10.5: 설정값 직접 편집 picker ──────────────
  // 클릭 → 입력 모달 (min/max validation 메시지 포함)
  function openValuePicker(btn) {
    var key  = btn.dataset.pick;
    var label = btn.dataset.label || key;
    var unit = btn.dataset.unit || '';
    var min  = btn.dataset.min  != null ? parseFloat(btn.dataset.min)  : null;
    var max  = btn.dataset.max  != null ? parseFloat(btn.dataset.max)  : null;
    var opts = btn.dataset.options ? btn.dataset.options.split(',') : null;

    var current = (btn.textContent || '').replace(/[^0-9.:]/g, '');
    var modal   = document.getElementById('ir-modal');
    var overlay = document.getElementById('ir-modal-overlay');
    var title   = document.getElementById('ir-modal-title');
    var body    = document.getElementById('ir-modal-body');
    var actions = document.getElementById('ir-modal-actions');

    title.textContent = label;
    // 시안 매칭: 다른 모달과 일관된 톤 — 알림형 default 색·가운데 정렬
    // (picker 도 본질은 알림+선택. is-info 의 좌측 정렬·검은색은 큰 폼 모달용)
    body.className = 'ir-modal-body';
    body.style.padding = '14px 18px 8px';
    body.style.gap = '8px';

    if (opts) {
      // 옵션 그리드 — 드립퍼 picker 와 동일 컴포넌트 (.drp-i) 재사용
      var rangeOpts = '<div class="picker-range-hint">선택지: ' + opts.length + '개</div>';
      body.innerHTML = rangeOpts +
        '<div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;width:100%;max-width:320px;">' +
        opts.map(function (o) {
          var on = o === current.trim() ? ' is-on' : '';
          return '<button class="drp-i' + on + '" data-v="' + o + '">' + o + '</button>';
        }).join('') + '</div>';
    } else {
      // 숫자 input + 범위 안내. 다른 모달 본문 폰트(14px)와 일관.
      // input 은 본문 폰트 1.4배(20px)로 — 너무 크지 않게.
      var rangeText = (min != null && max != null) ? '범위 ' + min + ' ~ ' + max + (unit ? ' ' + unit : '') : '';
      body.innerHTML =
        (rangeText ? '<div class="picker-range-hint">' + rangeText + '</div>' : '') +
        '<div class="picker-input-row">' +
          '<input type="number" id="val-input" value="' + current + '"' +
            (min != null ? ' min="' + min + '"' : '') +
            (max != null ? ' max="' + max + '"' : '') +
            ' class="picker-input">' +
          (unit ? '<span class="picker-unit">' + unit + '</span>' : '') +
        '</div>' +
        '<span id="val-err" class="picker-err"></span>';
    }

    actions.innerHTML = '';
    var btnCancel = document.createElement('button');
    btnCancel.className = 'ir-modal-btn';
    btnCancel.textContent = '취소';
    btnCancel.onclick = function () {
      overlay.classList.remove('is-open');
      body.style.cssText = '';
    };

    if (opts) {
      body.querySelectorAll('.drp-i').forEach(function (b) {
        b.addEventListener('click', function () {
          btn.innerHTML = b.dataset.v;
          window.IRState.setSetting(key, b.dataset.v);
          overlay.classList.remove('is-open');
          body.style.cssText = '';
          window.IRToast?.show(label + ' = ' + b.dataset.v);
        });
      });
      actions.appendChild(btnCancel);
    } else {
      var btnOk = document.createElement('button');
      btnOk.className = 'ir-modal-btn is-primary';
      btnOk.textContent = '저장';
      btnOk.onclick = function () {
        var v = parseFloat(document.getElementById('val-input').value);
        var err = document.getElementById('val-err');
        if (isNaN(v)) { err.textContent = '숫자를 입력해 주세요.'; return; }
        if (max != null && v > max) { err.textContent = label + ' 최댓값은 ' + max + ' ' + unit + ' 입니다'; return; }
        if (min != null && v < min) { err.textContent = label + ' 최솟값은 ' + min + ' ' + unit + ' 입니다'; return; }
        btn.innerHTML = v + (unit ? '<span class="unit">' + unit + '</span>' : '');
        window.IRState.setSetting(key, v);
        overlay.classList.remove('is-open');
        body.style.cssText = '';
        window.IRToast?.show(label + ' = ' + v + ' ' + unit);
      };
      actions.appendChild(btnOk);
      actions.appendChild(btnCancel);
      setTimeout(function () { document.getElementById('val-input').select(); }, 50);
    }
    overlay.classList.add('is-open');
  }
  // 모든 cr-pick 버튼에 바인딩 (드립퍼 picker 는 기존 핸들러 우선 — id 'sg-dripper'는 이 위 위 ABOVE 핸들러)
  document.querySelectorAll('.cr-pick[data-pick]').forEach(function (b) {
    b.addEventListener('click', function () { openValuePicker(b); });
  });

  // Save — settings-shell 의 [data-ir-save] 셀렉터로 통일
  document.querySelector('[data-ir-save]')?.addEventListener('click', function () {
    window.IRModal?.confirm({
      title: '설정 저장',
      body: '변경된 설정값을 저장하시겠습니까?',
      ok: '저장',
      onOk: function () { window.IRModal.info({ body: '설정이 저장되었습니다.' }); }
    });
  });
})();
</script>
