<!-- 추출 실적 (S8.3) — 정보에서 분리. 레시피별·기간별·요일별 통계. -->

<!-- 추출 실적 — 회의 피드백 v1.2: 드릴다운 + 시간대별 분포 + 인사이트 -->
<div class="sub-h">
  <div class="sub-h-l">추출 실적<em><span id="hist-mode-label">전체 통계</span></em></div>
  <div class="sub-h-r">
    <span id="hist-drill-back" style="display:none;cursor:pointer;color:var(--brand);font-weight:600;">← 전체 보기</span>
    <span>마지막 갱신 <b id="hist-updated">--:--</b></span>
  </div>
</div>

<div class="hist-body">

  <!-- 검색 바 + 기간 필터 (회의 v1.1 S8.3: 기간/레시피명/키워드 검색) -->
  <div class="hist-period">
    <input type="text" class="hist-search" id="hist-search" placeholder="🔍  레시피명 / 키워드">
    <span class="hist-period-spacer"></span>
    <button class="hist-pbtn is-active" data-p="all">전체</button>
    <button class="hist-pbtn" data-p="month">이번 달</button>
    <button class="hist-pbtn" data-p="week">이번 주</button>
    <button class="hist-pbtn" data-p="today">오늘</button>
  </div>

  <!-- Panel 1: KPI 4 카드 (회의 v1.1 S8.3.3) -->
  <div class="panel metric">
    <div class="panel-h">
      <span class="panel-title"><span class="ico">📊</span><span id="hist-summary-title">요약</span></span>
      <span class="hist-insight" id="hist-insight">— 데이터 분석 중 —</span>
    </div>
    <div class="metric-grid">
      <div class="metric-cell">
        <span class="metric-num" id="hist-total">—</span>
        <span class="metric-lbl">총 추출</span>
        <span class="metric-comp" id="hist-total-comp">설치 후 누적</span>
      </div>
      <div class="metric-cell">
        <span class="metric-num" id="hist-today">—</span>
        <span class="metric-lbl">오늘 (KST)</span>
        <span class="metric-comp" id="hist-today-comp">전일 대비 —</span>
      </div>
      <div class="metric-cell">
        <span class="metric-num" id="hist-week">—</span>
        <span class="metric-lbl">이번 주</span>
        <span class="metric-comp" id="hist-week-comp">전주 대비 —</span>
      </div>
      <div class="metric-cell">
        <span class="metric-num" id="hist-month">—</span>
        <span class="metric-lbl">이번 달</span>
        <span class="metric-comp" id="hist-month-comp">전월 대비 —</span>
      </div>
    </div>
  </div>

  <!-- Panel: 일별 막대 (회의 v1.1 S8.3 — 신규) — 최근 14일 -->
  <div class="panel panel-daily">
    <div class="panel-h">
      <span class="panel-title"><span class="ico">📈</span>일별 추출 (최근 14일)</span>
      <span class="panel-hint">왼쪽=오래된, 오른쪽=오늘</span>
    </div>
    <div class="hist-daily" id="hist-daily"></div>
  </div>

  <!-- Panel 2: 레시피별 (클릭 → drill-down) -->
  <div class="panel">
    <div class="panel-h">
      <span class="panel-title"><span class="ico">☕</span>레시피별 추출 횟수 <em class="panel-hint">(클릭하면 상세)</em></span>
      <div class="hist-sort" role="group">
        <button type="button" class="hist-sort-i is-active" data-sort="count">횟수순</button>
        <button type="button" class="hist-sort-i" data-sort="name">이름순</button>
      </div>
    </div>
    <div class="hist-bars" id="hist-by-recipe"></div>
  </div>

  <!-- Panel 3: 요일별 + 시간대별 (좌/우 분할) -->
  <div class="panel">
    <div class="panel-h">
      <span class="panel-title"><span class="ico">📅</span>요일·시간대 분포</span>
    </div>
    <div class="hist-dist">
      <div class="hist-dist-col">
        <div class="hist-dist-lbl">요일별</div>
        <div class="hist-dow" id="hist-dow"></div>
      </div>
      <div class="hist-dist-col">
        <div class="hist-dist-lbl">시간대별</div>
        <div class="hist-hour" id="hist-hour"></div>
      </div>
    </div>
  </div>

  <!-- Panel 4: 최근 추출 (가로 전체) — 표만 별도 스크롤 -->
  <div class="panel">
    <div class="panel-h">
      <span class="panel-title"><span class="ico">🕐</span>최근 추출</span>
    </div>
    <div class="hist-rt-wrap">
      <table class="rt hist-rt">
        <thead><tr><th>일시</th><th>레시피</th><th>추출구</th><th style="text-align:right;">사용량</th></tr></thead>
        <tbody id="hist-recent"></tbody>
      </table>
    </div>
  </div>

</div>

<style>
  /* 10인치 태블릿 — 위계 + 공백 중심 (폰트 자체보단 차이/대비/공백으로 가독성) */
  .sub-h { height: 48px; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--hair); flex-shrink: 0; background: var(--bg); }
  .sub-h-l { font-size: var(--fs-lg); font-weight: 700; color: var(--ink); letter-spacing: -0.2px; }
  .sub-h-l em { font-style: normal; color: var(--ink-3); font-weight: 500; margin-left: 8px; font-size: var(--fs-sm); }
  .sub-h-r { display: inline-flex; gap: 16px; align-items: center; font-size: var(--fs-sm); color: var(--ink-3); }
  .sub-h-r b { color: var(--ink-2); font-weight: 700; }

  /* v1.1 5행 그리드 — auto 행이 content 합산보다 작게 잠기는 문제 → max-content 명시 */
  .hist-body {
    flex: 1; padding: 14px 24px 18px;
    display: grid; grid-template-columns: 1fr 1fr;
    grid-template-rows: auto max-content max-content minmax(220px, 1fr) auto;
    gap: 12px; min-height: 0;
    overflow-y: auto;
  }
  /* 명시적 전폭 패널들 — 클래스 기반 (nth-of-type 충돌 회피) */
  .hist-body > .panel.metric,
  .hist-body > .panel-daily,
  .hist-body > .panel:last-child { grid-column: 1 / -1; }
  /* 최근 추출 표 — viewport 짧을 때도 최대 5행만 노출 (스크롤) */
  .hist-rt-wrap { max-height: 200px; overflow-y: auto; }
  .hist-period { grid-column: 1 / -1; display: flex; gap: 8px; align-items: center; }
  /* 검색 input (v1.1 S8.3.2) */
  .hist-search { flex: 1; max-width: 320px; min-height: var(--tap-min); padding: 0 14px; border: 1px solid var(--hair-2); background: var(--bg); font-size: var(--fs-sm); color: var(--ink); font-family: inherit; outline: none; }
  .hist-search:focus { border-color: var(--ink); }
  .hist-search::placeholder { color: var(--ink-3); }
  .hist-period-spacer { flex: 1; }
  /* 터치 타겟은 min-height 36 유지 (회의: "한국 사람 손가락"), 폰트는 합리적으로 */
  .hist-pbtn { padding: 10px 18px; font-size: var(--fs-sm); font-weight: 700; border: 1px solid var(--hair-2); background: var(--bg); color: var(--ink-3); cursor: pointer; letter-spacing: -0.1px; min-height: var(--tap-min); }
  .hist-pbtn:hover { color: var(--ink); }
  /* 활성 — 검정 ink 대신 Cinema Gold (settings 토글과 톤 통일). 폰트 12.5px 굵게 → 대비 충분. */
  .hist-pbtn.is-active { background: var(--gold); color: #fff; border-color: var(--gold); }

  /* 패널: 공백으로 분리 (padding 키움, 폰트는 그대로) */
  .panel { border: 1px solid var(--hair); padding: 14px 16px; display: flex; flex-direction: column; gap: 8px; min-height: 0; background: var(--bg); }
  .panel-h { display: flex; align-items: baseline; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid var(--hair); gap: 12px; }
  .panel-title { font-size: var(--fs-base); font-weight: 700; color: var(--ink); letter-spacing: -0.2px; }
  .panel-title .ico { margin-right: 6px; font-weight: 400; }
  .panel-id { font-size: clamp(11.5px, 1vw + 7px, 14px); color: var(--ink-3); font-weight: 500; letter-spacing: 0.4px; font-variant-numeric: tabular-nums; }

  /* 메트릭 패널 — panel 기본 구조 따름 (panel 자체가 flex column, gap 8) */
  .panel.metric {
    background: linear-gradient(180deg, #FFFAF2 0%, var(--bg) 60%);
    border-color: #C28200;
    grid-column: 1 / -1;
  }
  .panel.metric .panel-h .panel-title { color: #C28200; }
  /* v1.1 KPI 4개 — flex(grid)로 행 안에 4 cell + 명시적 자기 padding 없음 (panel padding 사용) */
  .metric-grid {
    display: grid; grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px; align-items: start;
    padding: 10px 0 6px;
  }
  @media (max-width: 768px) { .metric-grid { grid-template-columns: repeat(2, 1fr); } }
  .metric-cell { display: flex; flex-direction: column; gap: 6px; padding: 0 8px; min-width: 0; }
  .metric-cell + .metric-cell { border-left: 1px solid rgba(0,0,0,0.06); padding-left: 18px; }
  /* KPI 숫자 — 한 눈 스캐닝이 핵심. 24 → 44 (2x 가까이) (5/27) */
  .metric-num {
    font-size: clamp(36px, 3.5vw + 22px, 56px);
    font-weight: 700; color: var(--ink); letter-spacing: -1.5px;
    line-height: 1; font-variant-numeric: tabular-nums;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .metric-num.brand { color: var(--brand); }
  .metric-lbl {
    font-size: var(--fs-sm); color: var(--ink-2); font-weight: 700;
    letter-spacing: -0.1px; margin-top: 6px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    text-transform: uppercase; letter-spacing: 0.04em;
  }
  .metric-comp { font-size: var(--fs-sm); color: var(--ink-3); font-weight: 500; margin-top: 2px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .metric-comp.up { color: #15803D; font-weight: 700; }
  .metric-comp.down { color: var(--brand); font-weight: 700; }

  /* 일별 막대 차트 (v1.1 S8.3) — 최근 14일. 5/27 가독성 ↑ — 높이 + 폰트. */
  .hist-daily { display: grid; grid-template-columns: repeat(14, 1fr); gap: 5px; align-items: end; min-height: 140px; padding-top: 8px; }
  .hist-daily-col { display: flex; flex-direction: column; align-items: center; gap: 4px; min-width: 0; }
  .hist-daily-bar { width: 100%; background: var(--gold); min-height: 3px; transition: filter 0.15s; }
  .hist-daily-bar:hover { filter: brightness(1.1); }
  /* 오늘 강조 — 골드보다 진한 톤(brand)으로 차별화. */
  .hist-daily-col.today .hist-daily-bar { background: var(--brand); }
  .hist-daily-val { font-size: var(--fs-sm); color: var(--ink-2); font-weight: 700; font-variant-numeric: tabular-nums; }
  .hist-daily-lbl { font-size: var(--fs-sm); color: var(--ink-3); font-weight: 600; padding-top: 4px; border-top: 1px solid var(--hair); width: 100%; text-align: center; font-variant-numeric: tabular-nums; }
  .hist-daily-col.today .hist-daily-lbl { color: var(--gold-deep); font-weight: 700; }

  /* 레시피별 막대 — 클릭 가능. 터치 영역(min-h 36)만 보장, 폰트는 합리적 */
  .hist-bars { display: flex; flex-direction: column; gap: 4px; overflow-y: auto; flex: 1; padding-top: 4px; }
  .hist-bar-row {
    display: grid; grid-template-columns: 1.6fr 3fr 0.5fr;
    gap: 12px; align-items: center; font-size: var(--fs-sm);
    padding: 8px 10px; cursor: pointer; transition: background 0.12s;
    background: transparent; border: none; text-align: left; font-family: inherit; width: 100%;
    min-height: var(--tap-min);
  }
  .hist-bar-row:hover { background: rgba(0,0,0,0.03); }
  .hist-bar-row.is-active { background: var(--brand-dim); }
  .hist-bar-name { color: var(--ink); font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .hist-bar-row.is-active .hist-bar-name { color: var(--brand); font-weight: 700; }
  .hist-bar-track { height: 18px; background: rgba(0,0,0,0.06); position: relative; }
  /* 막대 기본 — 골드 (Cinema Gold 일관). 선택된 행만 brand red 강조(.is-active). */
  .hist-bar-fill { position: absolute; left: 0; top: 0; height: 100%; background: var(--gold); transition: width 0.3s; }
  .hist-bar-row.is-active .hist-bar-fill { background: var(--brand); }
  .hist-bar-val { text-align: right; font-variant-numeric: tabular-nums; color: var(--ink); font-weight: 700; font-size: var(--fs-base); }
  .panel-hint { color: var(--ink-3); font-weight: 500; font-size: var(--fs-sm); margin-left: 6px; font-style: italic; }

  /* 정렬 토글 */
  .hist-sort { display: inline-flex; border: 1px solid var(--hair-2); }
  .hist-sort-i {
    padding: 0 14px; font-size: var(--fs-sm); font-weight: 700;
    border: none; border-right: 1px solid var(--hair-2);
    background: var(--bg); color: var(--ink-3); cursor: pointer;
    font-family: inherit; letter-spacing: -0.1px;
    min-height: 36px;
  }
  .hist-sort-i:last-child { border-right: none; }
  .hist-sort-i.is-active { background: var(--gold); color: #fff; }

  /* 시간대·요일 좌우 분할 (24bar → 6 그룹) */
  .hist-dist { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; padding-top: 6px; min-height: 0; flex: 1; }
  @media (max-width: 900px) { .hist-dist { grid-template-columns: 1fr; } }
  .hist-dist-col { display: flex; flex-direction: column; gap: 6px; min-height: 0; }
  .hist-dist-lbl { font-size: var(--fs-sm); font-weight: 700; color: var(--ink-2); letter-spacing: 0.3px; text-transform: uppercase; }
  /* 6 그룹화 (4시간 단위): 새벽/오전/낮/오후/저녁/심야 */
  .hist-hour { display: grid; grid-template-columns: repeat(6, 1fr); gap: 8px; align-items: end; min-height: 120px; }
  .hist-hour-col { display: flex; flex-direction: column; align-items: center; gap: 6px; }
  .hist-hour-val { font-size: var(--fs-sm); color: var(--ink-2); font-weight: 700; font-variant-numeric: tabular-nums; }
  /* 시간대별 막대 — 골드 기본, peak 만 brand red 강조 */
  .hist-hour-bar { width: 100%; background: var(--gold); min-height: 3px; transition: filter 0.15s; }
  .hist-hour-bar:hover { filter: brightness(1.1); }
  .hist-hour-col[data-peak="true"] .hist-hour-bar { background: var(--brand); }
  .hist-hour-lbl { font-size: var(--fs-sm); color: var(--ink-3); font-weight: 700; padding-top: 6px; border-top: 1px solid var(--hair); width: 100%; text-align: center; }
  .hist-hour-col[data-peak="true"] .hist-hour-lbl { color: var(--gold-deep); }

  /* 빈 상태 — 친절한 안내 */
  .hist-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 28px 16px; gap: 6px; color: var(--ink-3);
    text-align: center;
  }
  .hist-empty-ico { font-size: 28px; opacity: 0.4; margin-bottom: 4px; }
  .hist-empty-msg { font-size: 13px; font-weight: 600; color: var(--ink-2); }
  .hist-empty-sub { font-size: 11px; color: var(--ink-3); }

  /* 인사이트 — 요약 panel 헤더 우측 (한 줄, 골드 톤). 별도 panel 차지 안 함. */
  .hist-insight {
    flex: 1; text-align: right;
    font-size: var(--fs-sm); color: var(--ink-2); font-weight: 500; line-height: 1.4;
    padding-left: 12px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .hist-insight b { color: var(--ink); font-weight: 700; }
  .hist-insight em { font-style: normal; color: var(--gold-deep); font-weight: 700; }

  /* 요일별 차트 */
  .hist-dow { display: grid; grid-template-columns: repeat(7, 1fr); gap: 6px; align-items: end; padding-top: 8px; min-height: 90px; }
  .hist-dow-col { display: flex; flex-direction: column; align-items: center; gap: 4px; }
  /* 요일별 막대 — 골드 기본, peak/select 만 brand red */
  .hist-dow-bar { width: 100%; background: var(--gold); min-height: 2px; }
  .hist-dow-col[data-peak="true"] .hist-dow-bar { background: var(--brand); }
  .hist-dow-val { font-size: clamp(11.5px, 1vw + 7px, 14px); color: var(--ink-3); font-weight: 700; font-variant-numeric: tabular-nums; }
  .hist-dow-lbl { font-size: clamp(11.5px, 1vw + 7px, 14px); color: var(--ink-3); font-weight: 700; padding-top: 5px; border-top: 1px solid var(--hair); width: 100%; text-align: center; }
  .hist-dow-col.weekend .hist-dow-lbl { color: var(--brand); }

  /* 최근 추출 표 — 표는 dense, 폰트 작게 OK */
  .hist-rt { width: 100%; font-size: 11.5px; font-variant-numeric: tabular-nums; }
  .hist-rt th { text-align: left; padding: 6px 4px; font-size: clamp(11.5px, 1vw + 7px, 14px); color: var(--ink-3); font-weight: 700; letter-spacing: 0.4px; border-bottom: 1px solid var(--hair); text-transform: uppercase; }
  .hist-rt th:last-child { text-align: right; }
  .hist-rt td { padding: 6px 4px; font-weight: 600; color: var(--ink); border-bottom: 1px solid var(--hair); }
  .hist-rt td:last-child { text-align: right; font-weight: 700; }
  .hist-rt tr:last-child td { border-bottom: none; }
</style>

<script>
(function () {
  var allSessions = [];
  var currentPeriod = 'all';
  var recipeSortMode = 'count';
  var drillRecipe = null; // 드릴다운 대상 레시피명 (null = 전체)
  var searchQuery = '';   // v1.1 S8.3.2 — 레시피명/키워드 검색

  var DOW_LABELS = ['일', '월', '화', '수', '목', '금', '토'];

  function fmtDur(sec) {
    var m = Math.floor(sec / 60), s = sec % 60;
    return m + ':' + String(s).padStart(2, '0');
  }
  function fmtDate(iso) {
    var d = new Date(iso);
    return (d.getMonth() + 1) + '.' + d.getDate() + ' ' +
           String(d.getHours()).padStart(2,'0') + ':' + String(d.getMinutes()).padStart(2,'0');
  }
  function filterByPeriod(sessions, period) {
    var out = sessions;
    if (period !== 'all') {
      var now = new Date();
      var cutoff = new Date(now);
      if (period === 'today') cutoff.setHours(0, 0, 0, 0);
      else if (period === 'week') cutoff.setDate(now.getDate() - 7);
      else if (period === 'month') cutoff.setMonth(now.getMonth() - 1);
      out = out.filter(function (s) { return new Date(s.startTime) >= cutoff; });
    }
    // v1.1 S8.3.2 검색 필터 — 레시피명 부분 일치
    if (searchQuery) {
      var q = searchQuery.toLowerCase();
      out = out.filter(function (s) { return (s.recipeName || '').toLowerCase().indexOf(q) >= 0; });
    }
    return out;
  }

  // 회의 피드백: 인사이트 메시지 자동 생성
  function buildInsight(sessions) {
    if (sessions.length === 0) return '추출 데이터가 아직 없습니다.';

    // 가장 많이 추출된 레시피
    var byR = {};
    sessions.forEach(function (s) { byR[s.recipeName] = (byR[s.recipeName] || 0) + 1; });
    var topR = Object.keys(byR).sort(function (a, b) { return byR[b] - byR[a]; })[0];
    var topRCount = byR[topR];
    var totalCount = sessions.length;
    var topRPct = Math.round(topRCount / totalCount * 100);

    // 가장 많이 사용된 요일
    var dow = [0, 0, 0, 0, 0, 0, 0];
    sessions.forEach(function (s) { dow[new Date(s.startTime).getDay()]++; });
    var maxDow = dow.indexOf(Math.max.apply(null, dow));

    // 피크 시간대
    var hr = new Array(24).fill(0);
    sessions.forEach(function (s) { hr[new Date(s.startTime).getHours()]++; });
    var peakHour = hr.indexOf(Math.max.apply(null, hr));
    var peakHourCount = hr[peakHour];

    var parts = [];
    if (drillRecipe) {
      parts.push('<b>' + drillRecipe + '</b>은(는) <em>' + DOW_LABELS[maxDow] + '요일</em>에 가장 많이 추출됩니다.');
      parts.push('피크 시간대: <em>' + peakHour + '시</em> (' + peakHourCount + '회)');
    } else {
      parts.push('가장 인기 있는 레시피: <b>' + topR + '</b> · ' + topRCount + '회 (' + topRPct + '%)');
      parts.push('가장 바쁜 요일: <em>' + DOW_LABELS[maxDow] + '요일</em> · ' + dow[maxDow] + '회');
      parts.push('피크 시간: <em>' + peakHour + '시</em>');
    }
    return parts.join('  ·  ');
  }

  function render() {
    var sessions = filterByPeriod(allSessions, currentPeriod);

    // 드릴다운 적용
    if (drillRecipe) {
      sessions = sessions.filter(function (s) { return s.recipeName === drillRecipe; });
      document.getElementById('hist-mode-label').textContent = '🔍 ' + drillRecipe;
      document.getElementById('hist-summary-title').textContent = drillRecipe + ' — 상세';
      document.getElementById('hist-drill-back').style.display = 'inline';
    } else {
      document.getElementById('hist-mode-label').textContent = '전체 통계';
      document.getElementById('hist-summary-title').textContent = '요약';
      document.getElementById('hist-drill-back').style.display = 'none';
    }

    // v1.1 S8.3.3: KPI 4 카드 — 총 추출 / 오늘 / 이번 주 / 이번 달 + 전 기간 대비
    var now = new Date();
    var startOfToday = new Date(now); startOfToday.setHours(0,0,0,0);
    var startOfYesterday = new Date(startOfToday); startOfYesterday.setDate(startOfYesterday.getDate() - 1);
    var startOfWeek = new Date(now); startOfWeek.setDate(now.getDate() - 7);
    var startOfPrevWeek = new Date(startOfWeek); startOfPrevWeek.setDate(startOfPrevWeek.getDate() - 7);
    var startOfMonth = new Date(now); startOfMonth.setMonth(now.getMonth() - 1);
    var startOfPrevMonth = new Date(startOfMonth); startOfPrevMonth.setMonth(startOfPrevMonth.getMonth() - 1);
    function cntInRange(from, to) {
      return allSessions.filter(function (s) {
        var d = new Date(s.startTime);
        return d >= from && (!to || d < to);
      }).length;
    }
    var totalAll = allSessions.length;
    var cntToday = cntInRange(startOfToday);
    var cntYesterday = cntInRange(startOfYesterday, startOfToday);
    var cntWeek = cntInRange(startOfWeek);
    var cntPrevWeek = cntInRange(startOfPrevWeek, startOfWeek);
    var cntMonth = cntInRange(startOfMonth);
    var cntPrevMonth = cntInRange(startOfPrevMonth, startOfMonth);
    function pctDiff(cur, prev) {
      if (prev === 0) return cur > 0 ? '+∞%' : '—';
      var d = Math.round((cur - prev) / prev * 100);
      return (d > 0 ? '+' : '') + d + '%';
    }
    function setComp(id, cur, prev, label) {
      var el = document.getElementById(id);
      if (!el) return;
      var diff = cur - prev;
      el.className = 'metric-comp' + (diff > 0 ? ' up' : diff < 0 ? ' down' : '');
      el.textContent = label + ' ' + pctDiff(cur, prev);
    }
    document.getElementById('hist-total').textContent = totalAll.toLocaleString();
    document.getElementById('hist-today').textContent = cntToday;
    setComp('hist-today-comp', cntToday, cntYesterday, '전일 대비');
    document.getElementById('hist-week').textContent = cntWeek;
    setComp('hist-week-comp', cntWeek, cntPrevWeek, '전주 대비');
    document.getElementById('hist-month').textContent = cntMonth;
    setComp('hist-month-comp', cntMonth, cntPrevMonth, '전월 대비');

    // 일별 차트 (최근 14일) — v1.1 신규
    var daily = new Array(14).fill(0);
    var dayLabels = new Array(14);
    for (var i = 0; i < 14; i++) {
      var d = new Date(startOfToday); d.setDate(startOfToday.getDate() - (13 - i));
      dayLabels[i] = { date: d, lbl: (d.getMonth()+1) + '/' + d.getDate() };
    }
    allSessions.forEach(function (s) {
      var d = new Date(s.startTime); d.setHours(0,0,0,0);
      for (var i = 0; i < 14; i++) {
        if (d.getTime() === dayLabels[i].date.getTime()) { daily[i]++; break; }
      }
    });
    var dailyMax = Math.max.apply(null, daily) || 1;
    var totalDaily = daily.reduce(function (a, b) { return a + b; }, 0);
    if (totalDaily === 0) {
      document.getElementById('hist-daily').innerHTML = '<div class="hist-empty" style="grid-column:1/-1;padding:14px;"><span class="hist-empty-ico">📅</span><span class="hist-empty-msg">최근 14일 추출 데이터가 없습니다</span><span class="hist-empty-sub">기간 필터를 "전체"로 변경하거나, mock 데이터의 startTime 을 최근 날짜로 갱신해 주세요.</span></div>';
    } else {
      document.getElementById('hist-daily').innerHTML = daily.map(function (n, i) {
        var h = (n / dailyMax * 56).toFixed(0);
        var isToday = i === 13;
        return '<div class="hist-daily-col' + (isToday ? ' today' : '') + '" title="' + dayLabels[i].lbl + ' · ' + n + '회">' +
          '<span class="hist-daily-val">' + (n || '·') + '</span>' +
          '<div class="hist-daily-bar" style="height:' + h + 'px;"></div>' +
          '<span class="hist-daily-lbl">' + dayLabels[i].lbl + '</span>' +
        '</div>';
      }).join('');
    }

    // 인사이트
    document.getElementById('hist-insight').innerHTML = buildInsight(sessions);

    // 레시피별 (드릴다운 시에도 표시 — 활성 레시피만 강조)
    var sessionsForRecipeChart = filterByPeriod(allSessions, currentPeriod); // 드릴 무시
    var byRecipe = {};
    sessionsForRecipeChart.forEach(function (s) { byRecipe[s.recipeName] = (byRecipe[s.recipeName] || 0) + 1; });
    var entries = Object.keys(byRecipe).map(function (k) { return [k, byRecipe[k]]; });
    if (recipeSortMode === 'count') {
      entries.sort(function (a, b) { return b[1] - a[1]; });
    } else if (recipeSortMode === 'name') {
      entries.sort(function (a, b) { return a[0].localeCompare(b[0], 'ko'); });
    }
    var max = entries.length ? Math.max.apply(null, entries.map(function (e) { return e[1]; })) : 1;
    document.getElementById('hist-by-recipe').innerHTML = entries.length === 0
      ? '<div class="hist-empty"><span class="hist-empty-ico">☕</span><span class="hist-empty-msg">이 기간에 추출된 레시피가 없습니다</span><span class="hist-empty-sub">기간 필터를 넓혀보세요</span></div>'
      : entries.map(function (e) {
          var pct = (e[1] / max * 100).toFixed(0);
          var active = drillRecipe === e[0] ? ' is-active' : '';
          return '<button type="button" class="hist-bar-row' + active + '" data-recipe="' + e[0].replace(/"/g, '&quot;') + '">' +
            '<span class="hist-bar-name">' + e[0] + '</span>' +
            '<span class="hist-bar-track"><span class="hist-bar-fill" style="width:' + pct + '%;"></span></span>' +
            '<span class="hist-bar-val">' + e[1] + '회</span>' +
          '</button>';
        }).join('');
    document.querySelectorAll('.hist-bar-row').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var r = btn.dataset.recipe;
        drillRecipe = drillRecipe === r ? null : r;
        render();
      });
    });

    // 요일별
    var dowCount = [0, 0, 0, 0, 0, 0, 0];
    sessions.forEach(function (s) { dowCount[new Date(s.startTime).getDay()]++; });
    var dowMax = Math.max.apply(null, dowCount) || 1;
    document.getElementById('hist-dow').innerHTML = dowCount.map(function (n, i) {
      var h = (n / dowMax * 70).toFixed(0);
      var cls = (i === 0 || i === 6) ? ' weekend' : '';
      return '<div class="hist-dow-col' + cls + '">' +
        '<span class="hist-dow-val">' + n + '</span>' +
        '<div class="hist-dow-bar" style="height:' + h + 'px;"></div>' +
        '<span class="hist-dow-lbl">' + DOW_LABELS[i] + '</span>' +
      '</div>';
    }).join('');

    // 시간대별 6 그룹 (4시간 단위) — 10인치 가독성 (24bar 너무 빽빽)
    // 새벽 0-3 / 오전 4-7 / 점심 8-11 / 오후 12-15 / 저녁 16-19 / 심야 20-23
    var hourGroupLabels = ['새벽', '오전', '점심', '오후', '저녁', '심야'];
    var hourGroups = [0, 0, 0, 0, 0, 0];
    sessions.forEach(function (s) {
      var hr = new Date(s.startTime).getHours();
      hourGroups[Math.floor(hr / 4)]++;
    });
    var hgMax = Math.max.apply(null, hourGroups) || 1;
    document.getElementById('hist-hour').innerHTML = hourGroups.map(function (n, i) {
      var h = (n / hgMax * 80).toFixed(0);
      var peak = n === hgMax && n > 0;
      var startHr = i * 4;
      var endHr = startHr + 3;
      return '<div class="hist-hour-col" data-peak="' + peak + '" title="' + startHr + '~' + endHr + '시 · ' + n + '회">' +
        '<span class="hist-hour-val">' + n + '</span>' +
        '<div class="hist-hour-bar" style="height:' + h + 'px;"></div>' +
        '<span class="hist-hour-lbl">' + hourGroupLabels[i] + '</span>' +
      '</div>';
    }).join('');

    // 최근 추출 (최대 10개)
    var recent = sessions.slice().sort(function (a, b) {
      return new Date(b.startTime) - new Date(a.startTime);
    }).slice(0, 10);
    document.getElementById('hist-recent').innerHTML = recent.length === 0
      ? '<tr><td colspan="4" style="color:var(--ink-3);padding:24px 0;text-align:center;font-size:12.5px;">아직 추출 기록이 없습니다.<br><span style="font-size:11px;color:var(--ink-3);opacity:0.7;">레시피 추출 후 여기에 표시됩니다.</span></td></tr>'
      : recent.map(function (s) {
          return '<tr>' +
            '<td>' + fmtDate(s.startTime) + '</td>' +
            '<td>' + s.recipeName + '</td>' +
            '<td>' + s.spoutId + '번</td>' +
            '<td>' + (s.waterUsed || '—') + ' mL</td>' +
          '</tr>';
        }).join('');

    // 갱신 시각
    var now = new Date();
    document.getElementById('hist-updated').textContent =
      String(now.getHours()).padStart(2,'0') + ':' + String(now.getMinutes()).padStart(2,'0');
  }

  fetch('/api/brew-sessions').then(function (r) { return r.json(); }).then(function (data) {
    allSessions = data || [];
    render();
  });

  // 기간 필터
  document.querySelectorAll('.hist-pbtn').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.hist-pbtn').forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      currentPeriod = btn.dataset.p;
      render();
    });
  });

  // 레시피 정렬 토글
  document.querySelectorAll('.hist-sort-i').forEach(function (btn) {
    btn.addEventListener('click', function () {
      document.querySelectorAll('.hist-sort-i').forEach(function (b) { b.classList.remove('is-active'); });
      btn.classList.add('is-active');
      recipeSortMode = btn.dataset.sort;
      render();
    });
  });

  // 드릴다운 해제
  document.getElementById('hist-drill-back').addEventListener('click', function () {
    drillRecipe = null;
    render();
  });

  // v1.1 S8.3.2: 검색 (IME composition 가드)
  document.getElementById('hist-search').addEventListener('input', function (ev) {
    if (ev.isComposing) return;
    searchQuery = ev.target.value.trim();
    render();
  });
  document.getElementById('hist-search').addEventListener('compositionend', function (ev) {
    searchQuery = ev.target.value.trim();
    render();
  });
})();
</script>
