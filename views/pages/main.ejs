<!-- Main Dashboard — 5-spout stations + 매뉴얼 큐 (v1.1 S2.1.7).
     Aligned with designs/02-cinema-gold.html (시안 ② Light · S2.1 메인 모니터링). -->
<script>
// PWA First-run guard — PWA standalone/fullscreen 모드일 때만 적용.
// 브라우저 모드에서는 demo 그대로 /main 표시. (5/27)
// 첫 실행 시 setup → connect 플로우 강제, 완료 시 firstRunComplete 영구화.
(function () {
  var isStandalone = window.matchMedia && (
    window.matchMedia('(display-mode: fullscreen)').matches ||
    window.matchMedia('(display-mode: standalone)').matches ||
    window.matchMedia('(display-mode: minimal-ui)').matches
  ) || window.navigator.standalone === true;
  if (!isStandalone) return;
  try {
    var state = JSON.parse(localStorage.getItem('irhea.state.v1') || '{}');
    if (!state.firstRunComplete) {
      var base = window.BASE_PATH || '';
      window.location.replace(base + '/setup/');
    }
  } catch (e) {}
})();
</script>
<div class="stations">
  <% for (let i = 1; i <= 5; i++) { %>
    <div class="st st-<%= i %> spout-card" data-spout="<%= i %>">
      <div class="st-head">
        <span class="st-num"><%= i %></span>
        <div class="st-head-r">
          <span class="st-state"><span class="dot"></span><span class="spout-status-text">Idle</span></span>
          <span class="st-count">누적 <b class="spout-count-val">--</b>회</span>
        </div>
      </div>
      <div class="st-vis">
        <div class="st-circle">
          <!-- 실사 비디오 제거 (회의 피드백: 균형감 ↓ / 시인성 ↓). 단색 배경 + 진행 링만 유지 -->
          <svg class="prog" viewBox="0 0 100 100">
            <circle class="prog-track" cx="50" cy="50" r="43"/>
            <circle class="spout-ring prog-fill idle" cx="50" cy="50" r="43" pathLength="100" stroke-dasharray="0 100"/>
            <circle class="prog-shimmer" cx="50" cy="50" r="43" pathLength="100"/>
          </svg>
          <div class="prog-center">
            <span class="prog-pct"><span class="spout-pct-val">0</span><span class="u spout-pct-u">%</span></span>
            <span class="prog-sub spout-sublabel">대기</span>
          </div>
        </div>
      </div>
      <div class="st-info">
        <div class="st-info-row">
          <span class="st-stage spout-stage">현 단계</span>
          <span class="st-time"><span class="spout-time-val">00:00</span><em> / <span class="spout-total-val">00:00</span></em></span>
        </div>
        <div class="st-bar"><div class="st-bar-fill spout-bar-fill" style="width:0%;"></div></div>
      </div>
      <!-- 현재 추출 중인 레시피 (큰 박스 — 4 카테고리: 원두명·원두량·비율·추출량)
           클릭 → 매뉴얼 레시피 변경 (회의 피드백: 즐겨찾기 외에도 매뉴얼 선택 가능) -->
      <button class="st-recipe spout-recipe-btn" type="button" title="탭하여 레시피 변경">
        <div class="st-recipe-name spout-recipe-name">—</div>
        <div class="st-recipe-meta">
          <span data-i18n="unit.bean">원두</span> <b class="spout-bean">20g</b> ·
          <span data-i18n="unit.ratio">비율</span> <b class="spout-ratio">1:12</b> ·
          <span data-i18n="unit.water">추출</span> <b class="spout-total">240g</b>
        </div>
        <span class="st-recipe-edit">✎ 변경</span>
      </button>
      <!-- 즐겨찾기 5 슬롯 — 레시피명만 (회의 피드백: 추가 정보 불필요)
           슬롯 클릭 → 해당 레시피로 즉시 적용 (메인 카드에 매핑) -->
      <div class="st-slots spout-faves">
        <div class="st-slots-title" data-i18n="unit.favorites">즐겨찾기</div>
        <button type="button" class="st-slot" data-slot="0"><span class="st-slot-recipe">—</span></button>
        <button type="button" class="st-slot" data-slot="1"><span class="st-slot-recipe">—</span></button>
        <button type="button" class="st-slot" data-slot="2"><span class="st-slot-recipe">—</span></button>
        <button type="button" class="st-slot" data-slot="3"><span class="st-slot-recipe">—</span></button>
        <button type="button" class="st-slot" data-slot="4"><span class="st-slot-recipe">—</span></button>
      </div>
    </div>
  <% } %>
</div>

<!-- v1.1 S2.1.7: 매뉴얼 큐 그리드 5×6 — 즐겨찾기와 분리. 추출구별 대기열.
     클릭: 큐에 추가 (현재는 mock 데이터로 표시만) -->
<div class="manual-queue" id="manual-queue">
  <div class="mq-head">
    <span class="mq-title">📋 매뉴얼 큐 <em>(다음 추출 대기열 · 최대 6잔/추출구)</em></span>
    <button type="button" class="mq-clear" id="mq-clear-all">전체 비우기</button>
  </div>
  <div class="mq-grid">
    <% for (let i = 1; i <= 5; i++) { %>
      <div class="mq-col" data-spout="<%= i %>">
        <div class="mq-col-label">추출구 <%= i %></div>
        <div class="mq-cells">
          <% for (let s = 0; s < 6; s++) { %>
            <div class="mq-cell" data-slot="<%= s %>"><span class="mq-cell-recipe">—</span></div>
          <% } %>
        </div>
      </div>
    <% } %>
  </div>
</div>

<style>
  /* minmax(0, 1fr) — 가로 스크롤 차단. overflow: hidden — active 카드 콘텐츠가 stations 영역 밖 ↑ 막음 */
  .stations { flex: 1; display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); min-height: 0; overflow: hidden; }
  /* 반응형 — 좁은 화면에서 5칸 → 3칸 → 2칸 (theme-irhea.css 의 같은 룰을 cascade 후순위로 override 하지 못하므로 페이지 inline 에도 정의). */
  @media (max-width: 1023px) { .stations { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 767px)  { .stations { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  .st { padding: 10px 10px 8px; display: flex; flex-direction: column; align-items: stretch; gap: 4px; border-right: 1px solid var(--hair); position: relative; min-height: 0; min-width: 0; overflow: hidden; }
  .st:last-child { border-right: none; }
  .st.active::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--brand); }
  /* 5/13 §1.2: 추출구별 파스텔톤 배경 차별화 — 순차 배색 (난잡하지 않게 매우 옅게) */
  .st-1 { background: linear-gradient(180deg, #FEF7F0 0%, var(--bg) 100%); }
  .st-2 { background: linear-gradient(180deg, #F3F9F0 0%, var(--bg) 100%); }
  .st-3 { background: linear-gradient(180deg, #F0F4FA 0%, var(--bg) 100%); }
  .st-4 { background: linear-gradient(180deg, #F8F4FA 0%, var(--bg) 100%); }
  .st-5 { background: linear-gradient(180deg, #FAFAF5 0%, var(--bg) 100%); }
  .st-head { display: flex; align-items: flex-start; justify-content: space-between; }
  /* Station 번호 — Cinema Gold 일관성: 모든 active 번호 골드 Playfair italic, idle 만 회색.
     상태 색은 우상단 dot+텍스트(st-state)에서 표현하므로 번호 색은 통일. */
  .st-num { font-weight: 700; font-size: 34px; line-height: 0.9; letter-spacing: -1px; color: var(--gold); font-variant-numeric: tabular-nums; font-family: var(--font-display); font-style: italic; }
  .st-5 .st-num { color: var(--st-idle); font-style: italic; }
  .st-head-r { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; padding-top: 2px; }
  .st-state { font-size: 11px; font-weight: 700; letter-spacing: 0.4px; text-transform: uppercase; color: var(--ink-3); display: inline-flex; align-items: center; gap: 5px; }
  .st-1 .st-state { color: var(--st-brewing); }
  .st-2 .st-state { color: var(--st-done); }
  .st-3 .st-state { color: var(--st-rinse); }
  .st-4 .st-state { color: var(--st-water); }
  .st-5 .st-state { color: var(--st-idle); }
  .st-state .dot { width: 6px; height: 6px; border-radius: 50%; background: currentColor; display: inline-block; animation: pulse-st 1.6s ease-in-out infinite; }
  @keyframes pulse-st { 0%,100% { opacity: 1; } 50% { opacity: 0.35; } }
  .st-count { font-size: clamp(11.5px, 1vw + 7px, 14px); color: var(--ink-3); font-weight: 500; }
  .st-count b { color: var(--ink-2); font-weight: 700; }
  .st-vis { display: flex; justify-content: center; align-items: center; padding: 4px 0; }
  .st-circle { width: 115px; height: 115px; position: relative; border-radius: 50%; overflow: hidden; background: #1a1a1a; }
  /* 상태별 배경 색조 — 비디오 대신 단색 + radial gradient */
  .st-circle::after { content: ''; position: absolute; inset: 0; z-index: 1; pointer-events: none; background: radial-gradient(circle at 50% 40%, rgba(255,255,255,0.04) 0%, rgba(0,0,0,0.0) 100%); }
  .st.active .st-circle { background: linear-gradient(135deg, #2a1a18 0%, #1a1a1a 100%); }
  .prog { position: absolute; inset: 0; transform: rotate(-90deg); z-index: 2; }
  .prog-track { fill: none; stroke: rgba(255,255,255,0.22); stroke-width: 5; }
  .prog-fill { fill: none; stroke-width: 5; stroke-linecap: round; transition: stroke-dasharray 0.7s cubic-bezier(.4,0,.2,1); animation: prog-breathe 2.8s ease-in-out infinite; }
  .prog-fill.brewing { stroke: var(--st-brewing); filter: drop-shadow(0 0 6px rgba(230,0,18,0.9)); }
  .prog-fill.done    { stroke: var(--st-done);    filter: drop-shadow(0 0 6px rgba(61,214,140,0.7)); }
  .prog-fill.rinse   { stroke: var(--st-rinse);   filter: drop-shadow(0 0 5px rgba(110,90,150,0.7)); }
  .prog-fill.water   { stroke: var(--st-water);   filter: drop-shadow(0 0 5px rgba(62,126,150,0.7)); }
  .prog-fill.idle    { stroke: rgba(255,255,255,0.35); animation: none; filter: none; }
  @keyframes prog-breathe { 0%,100% { opacity: 1; } 50% { opacity: 0.78; } }
  .prog-shimmer { fill: none; stroke: #FFF; stroke-width: 5; stroke-linecap: round; stroke-dasharray: 4 96; opacity: 0; }
  .st.active .prog-shimmer { opacity: 0.65; animation: shimmer-rot 2.4s linear infinite; }
  @keyframes shimmer-rot { from { stroke-dashoffset: 0; } to { stroke-dashoffset: -100; } }
  .prog-center { position: absolute; inset: 0; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #FFF; line-height: 1; z-index: 3; }
  .prog-pct { font-size: 38px; font-weight: 700; font-variant-numeric: tabular-nums; letter-spacing: -1.6px; text-shadow: 0 1px 10px rgba(0,0,0,0.7); }
  .prog-pct .u { font-size: 16px; font-weight: 600; color: rgba(255,255,255,0.7); margin-left: 1px; }
  .prog-sub { font-size: clamp(11.5px, 1vw + 7px, 14px); font-weight: 700; color: rgba(255,255,255,0.92); margin-top: 5px; letter-spacing: 0.6px; text-shadow: 0 1px 8px rgba(0,0,0,0.8); }
  .st-info { display: flex; flex-direction: column; gap: 4px; }
  .st-info-row { display: flex; justify-content: space-between; align-items: baseline; }
  /* 위계: 단계명(작은 회색) / 시간(굵은 검정 모노) — 차이로 가독성 */
  .st-stage { font-size: 11px; color: var(--ink-3); font-weight: 700; letter-spacing: -0.1px; }
  .st-time { font-size: 15px; font-weight: 700; color: var(--ink); font-family: var(--font-mono); }
  .st-time em { font-style: normal; color: var(--ink-3); font-weight: 500; font-size: 12px; }
  .st-bar { height: 3px; background: rgba(0,0,0,0.06); position: relative; overflow: hidden; }
  .st-bar-fill { position: absolute; top: 0; left: 0; height: 100%; background: var(--state-color, var(--brand)); }
  /* 추출 중인 레시피 (큰 박스, 클릭 가능) — 4 카테고리 + 변경 hint */
  .st-recipe {
    position: relative;
    padding: 6px 8px;
    background: transparent;
    border: 1px dashed transparent;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, background 0.15s;
  }
  .st-recipe:hover { border-color: var(--hair-2); background: rgba(0,0,0,0.02); }
  .st-recipe:hover .st-recipe-edit { opacity: 1; }
  .st-recipe-edit {
    position: absolute; top: 6px; right: 6px;
    font-size: clamp(11px, 0.9vw + 7px, 13px); font-weight: 700; color: var(--brand);
    letter-spacing: 0.3px; opacity: 0; transition: opacity 0.15s;
  }
  .st-recipe-name {
    font-weight: 700; font-size: 14px; color: var(--ink);
    /* 최대 2줄 (회의: 최대 60자 → 2줄), 넘으면 말줄임 */
    display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical;
    overflow: hidden; line-height: 1.25; word-break: keep-all;
  }
  /* 메타: 작은 회색 (보조 정보), bold만 검정 (값 강조) */
  .st-recipe-meta { font-size: 11px; color: var(--ink-3); font-weight: 500; line-height: 1.5; word-break: keep-all; margin-top: 3px; }
  .st-recipe-meta b { color: var(--ink); font-weight: 700; }

  /* 완료 시 점멸 — 회의 피드백: 서빙 타이밍 알림 (커피 식음 방지) */
  .st.is-complete-flash { animation: spout-complete-flash 1.2s ease-in-out infinite; }
  @keyframes spout-complete-flash {
    0%, 100% { box-shadow: inset 0 0 0 3px transparent; }
    50%      { box-shadow: inset 0 0 0 3px var(--st-done, #15803D); }
  }
  .st.is-complete-flash .st-num { color: var(--st-done, #15803D) !important; }

  /* v1.1 S2.1.7: 매뉴얼 큐 5×6 — stations 영역 침범 방지 컴팩트화 */
  .manual-queue { flex-shrink: 0; border-top: 2px solid var(--hair); background: linear-gradient(180deg, #FAF8F2 0%, var(--bg) 100%); padding: 4px 14px 6px; min-width: 0; overflow: hidden; }
  .mq-head { display: flex; align-items: center; justify-content: space-between; padding-bottom: 3px; }
  .mq-title { font-size: clamp(11.5px, 1vw + 7px, 14px); font-weight: 700; color: var(--ink-2); letter-spacing: 0.3px; text-transform: uppercase; }
  .mq-title em { font-style: normal; color: var(--ink-3); font-weight: 500; margin-left: 5px; font-size: clamp(11px, 0.9vw + 7px, 13px); text-transform: none; letter-spacing: 0; }
  .mq-clear { font-size: 11px; padding: 6px 12px; min-height: 28px; border: 1px dashed var(--hair-2); background: transparent; color: var(--ink-3); cursor: pointer; font-family: inherit; font-weight: 500; }
  .mq-clear:hover { color: var(--brand); border-color: var(--brand); }
  .mq-grid { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 6px; }
  @media (max-width: 1023px) { .mq-grid { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
  @media (max-width: 767px)  { .mq-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
  .mq-col { min-width: 0; display: grid; grid-template-columns: 28px minmax(0, 1fr); align-items: center; column-gap: 4px; }
  .mq-col-label { font-size: clamp(11px, 0.9vw + 7px, 13px); font-weight: 700; color: var(--ink-3); text-align: center; letter-spacing: 0.3px; }
  /* 6 셀 가로 배치 — 폭/높이 컴팩트 */
  .mq-cells { display: grid; grid-template-columns: repeat(6, minmax(0, 1fr)); gap: 1px; min-width: 0; }
  .mq-cell {
    min-height: 32px; padding: 4px 2px;
    border: 1px dashed rgba(0,0,0,0.1);
    background: var(--bg);
    display: flex; align-items: center; justify-content: center;
    /* 큐 셀은 가로 매우 좁음 (~26-40px) — 폰트 작게 잡아야 2~3 글자 보임 */
    font-size: clamp(9.5px, 0.5vw + 7.5px, 11.5px);
    color: var(--ink-3);
    cursor: pointer; transition: all 0.12s;
    min-width: 0;
  }
  .mq-cell:hover { border-color: var(--brand); border-style: solid; background: #FAFAFA; }
  .mq-cell.is-filled { border-style: solid; border-color: rgba(0,0,0,0.18); background: rgba(197,130,0,0.05); }
  .mq-cell.is-filled .mq-cell-recipe { color: var(--ink); font-weight: 600; }
  .mq-cell.is-head { border-color: var(--brand); background: rgba(230,0,18,0.08); }
  .mq-cell.is-head .mq-cell-recipe { color: var(--brand); font-weight: 700; }
  .mq-cell-recipe { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; flex: 1; min-width: 0; text-align: center; }

  /* 즐겨찾기 슬롯 5개 — stations 영역 안에 모두 들어가도록 컴팩트화 */
  .st-slots {
    display: flex; flex-direction: column; gap: 1px;
    margin-top: auto; padding-top: 5px;
    border-top: 1px solid rgba(0,0,0,0.05);
  }
  .st-slots-title {
    font-size: clamp(11px, 0.9vw + 7px, 13px); font-weight: 700; color: var(--ink-3);
    letter-spacing: 0.4px; text-transform: uppercase; margin-bottom: 2px;
  }
  .st-slot {
    display: flex; align-items: center; gap: 5px;
    padding: 6px 8px; font-size: var(--fs-sm);
    min-height: 36px;
    border: none;
    border-bottom: 1px dashed rgba(0,0,0,0.04);
    background: transparent;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    width: 100%;
    transition: background 0.12s;
  }
  .st-slot:hover { background: rgba(0,0,0,0.03); }
  .st-slot:last-child { border-bottom: none; }
  .st-slot.is-filled:hover { background: rgba(194,130,0,0.06); }
  .st-slot.is-active:hover { background: rgba(230,0,18,0.05); }
  .st-slot-recipe {
    color: var(--ink-3); font-weight: 500;
    /* 긴 레시피명 (예: "르완다 뉸궤 내추럴 라마간 마이크로랏 G1") 대비 — 한 줄 ellipsis 대신
       최대 2줄 표시, 그 이상이면 ellipsis. word-break: keep-all 로 단어 단위 줄바꿈. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.25;
    word-break: keep-all;
    flex: 1; min-width: 0;
  }
  .st-slot.is-filled .st-slot-recipe { color: var(--ink); font-weight: 600; }
  .st-slot.is-active .st-slot-recipe { color: var(--brand); font-weight: 700; }

  /* ── 진짜 반응형 — 작은 화면(<1024)에서 station 카드 컨텐츠 단순화 ──
     1024 베이스라인은 5+1 + 즐겨찾기 5칸 + 매뉴얼 큐 모두 표시.
     좁은 화면에선 ring + recipe 메타만 보이고, 즐겨찾기 슬롯 + 매뉴얼 큐 hide
     (사용자가 어떤 station 이 동작 중인지 모니터링하는 것이 1순위 정보). */
  @media (max-width: 1023px) {
    .st-slots { display: none; }
    .manual-queue { display: none; }
    .st-recipe { display: none; }
    .st-circle { width: 100px; height: 100px; }
  }
  @media (max-width: 767px) {
    .st-info { display: none; }
    .st-circle { width: 80px; height: 80px; }
  }
</style>

<script>
(function() {
  // Spec: designs/02-cinema-gold.html. State labels match the spec exactly.
  // Prefix media paths with BASE_PATH so static export (GitHub Pages) resolves correctly.
  const B = (window.BASE_PATH || '');
  // 회의 피드백 v1.1: 한글 디폴트 / v1.2: i18n 키로 동적 (KO↔EN 토글 가능)
  function L(key) { return (window.IRI18n && window.IRI18n.t) ? window.IRI18n.t(key) : key; }
  function buildStatusMap() {
    return {
      idle:       { label: L('status.idle'),     sub: L('status.sub.idle'),     stage: '직전 추출 완료', active: false, ring: 'idle' },
      extracting: { label: L('status.brewing'),  sub: L('status.sub.brewing'),  stage: '추출 진행',     active: true,  ring: 'brewing' },
      complete:   { label: L('status.complete'), sub: L('status.sub.complete'), stage: '추출 완료',     active: true,  ring: 'done' },
      rinsing:    { label: L('status.rinsing'),  sub: L('status.sub.rinsing'),  stage: '자동 린스',     active: true,  ring: 'rinse' },
      watering:   { label: L('status.watering'), sub: L('status.sub.watering'), stage: '온수 공급',     active: true,  ring: 'water' }
    };
  }
  var STATUS = buildStatusMap();
  // 언어 바뀔 때 STATUS 다시 빌드 + 즉시 갱신
  if (window.IRI18n) {
    window.IRI18n.on(function () { STATUS = buildStatusMap(); update(); });
  }
  function fmt(s) {
    var m = Math.floor(s / 60), sec = s % 60;
    return String(m).padStart(2, '0') + ':' + String(sec).padStart(2, '0');
  }
  let recipesCache = null;
  function loadRecipes() {
    return recipesCache ? Promise.resolve(recipesCache)
      : fetch('/api/recipes').then(r => r.json()).then(r => (recipesCache = r));
  }
  function applyRecipe(card, recipe) {
    if (!recipe) return;
    const nameEl = card.querySelector('.spout-recipe-name');
    if (nameEl) {
      // 원두명 통째로 (최대 2줄 / 60자 CSS line-clamp). 회의: 마지막 글자 작은 글씨 i 처리 불필요
      nameEl.textContent = recipe.name || '';
    }
    // 4 카테고리: 원두명(위) · 원두량 · 비율 · 추출량 (회의 피드백)
    const bean = card.querySelector('.spout-bean');
    const ratio = card.querySelector('.spout-ratio');
    const total = card.querySelector('.spout-total');
    if (bean)  bean.textContent  = (recipe.coffeeWeight || '--') + 'g';
    if (ratio) ratio.textContent = recipe.ratio || '--';
    if (total) total.textContent = (recipe.waterWeight || '--') + 'g';
  }
  // v1.1 S2.1.7: 매뉴얼 큐 렌더링 (mock + localStorage override)
  function applyManualQueue(spouts, recipes) {
    var raw = localStorage.getItem('ir.queueOverride');
    var ov = {};
    try { ov = raw ? JSON.parse(raw) : {}; } catch (e) {}
    spouts.forEach(function (s) {
      var col = document.querySelector('.mq-col[data-spout="' + s.id + '"]');
      if (!col) return;
      // override 가 있으면 그것, 없으면 mock 값
      var queue = ov[s.id] != null ? ov[s.id] : (s.manualQueue || []);
      var cells = col.querySelectorAll('.mq-cell');
      cells.forEach(function (cell, idx) {
        var rid = queue[idx];
        var r = rid != null ? recipes.find(function (x) { return x.id === rid; }) : null;
        var nameEl = cell.querySelector('.mq-cell-recipe');
        cell.classList.remove('is-filled', 'is-head');
        if (r) {
          nameEl.textContent = r.name || ('레시피 ' + r.id);
          nameEl.title = r.name;
          cell.classList.add('is-filled');
          if (idx === 0) cell.classList.add('is-head'); // 큐 헤드 = 다음 추출
        } else {
          nameEl.textContent = '—';
          nameEl.title = '';
        }
      });
    });
  }

  function applyFavoriteSlots(card, spout, recipes, currentRecipeId) {
    const slots = card.querySelectorAll('.st-slot');
    const ids = spout.favoriteRecipeIds || [];
    slots.forEach((slot, idx) => {
      const rid = ids[idx];
      const r = rid != null ? recipes.find(x => x.id === rid) : null;
      const nameEl = slot.querySelector('.st-slot-recipe');
      slot.classList.remove('is-filled', 'is-active');
      if (r) {
        nameEl.textContent = r.name;
        slot.classList.add('is-filled');
        if (r.id === currentRecipeId) slot.classList.add('is-active');
      } else {
        nameEl.textContent = '—';
      }
    });
  }
  function update() {
    Promise.all([fetch('/api/spouts').then(r => r.json()), loadRecipes()])
      .then(([spoutsRaw, recipes]) => {
        // BUG #1 fix: 매뉴얼 레시피 변경은 localStorage override 로 영구화
        // (실 환경에서는 API PUT /api/spouts/:id 가 백엔드에 쓰므로 이 layer 불필요)
        // 5/27: 서빙완료/추출시작 모달도 동일 패턴 — status override 추가 적용
        let spouts = window.IRState ? window.IRState.applySpoutOverrides(spoutsRaw) : spoutsRaw;
        if (window.IRState && window.IRState.applySpoutStatusOverrides) {
          spouts = window.IRState.applySpoutStatusOverrides(spouts);
        }
        spouts.forEach(s => {
          const card = document.querySelector('.spout-card[data-spout="' + s.id + '"]');
          if (!card) return;
          const st = STATUS[s.status] || STATUS.idle;
          if (st.active) card.classList.add('active'); else card.classList.remove('active');
          card.querySelector('.spout-status-text').textContent = st.label;
          const sublabel = card.querySelector('.spout-sublabel');
          if (sublabel) sublabel.textContent = st.sub;
          card.querySelector('.spout-count-val').textContent = s.extractCount.toLocaleString();
          // 실사 비디오 제거됨 (회의 피드백)
          const stage = card.querySelector('.spout-stage');
          if (stage) {
            // 회의 피드백: "현 단계" 정의 불명. 단계명 + (단계 N/M) 형식으로
            const stageNum = (st.active && s.status === 'extracting' && s.stageIdx != null) ? ` · 단계 ${s.stageIdx}/${s.stageTotal || '?'}` : '';
            stage.textContent = st.stage + stageNum;
          }
          const pct = s.progressPct != null ? s.progressPct : 0;
          card.querySelector('.spout-pct-val').textContent = s.status === 'idle' ? '—' : pct;
          const pctU = card.querySelector('.spout-pct-u');
          if (pctU) pctU.style.display = s.status === 'idle' ? 'none' : '';
          const ring = card.querySelector('.spout-ring');
          ring.className = 'spout-ring prog-fill ' + st.ring;
          ring.setAttribute('stroke-dasharray', pct + ' 100');
          card.querySelector('.spout-time-val').textContent = fmt(s.elapsedSec);
          card.querySelector('.spout-total-val').textContent = fmt(s.totalSec);
          const barFill = card.querySelector('.spout-bar-fill');
          barFill.className = 'st-bar-fill spout-bar-fill ' + st.ring;
          barFill.style.width = pct + '%';
          const currentRecipe = recipes.find(r => r.id === s.currentRecipeId);
          applyRecipe(card, currentRecipe);
          applyFavoriteSlots(card, s, recipes, s.currentRecipeId);
        });
        // 매뉴얼 큐 — 카드 forEach 밖에서 한 번에
        applyManualQueue(spouts, recipes);
        spouts.forEach(function (s) {
          // 완료 점멸 등 후속 로직 (원래 forEach 안에 있었음)
          var card = document.querySelector('.spout-card[data-spout="' + s.id + '"]');
          if (!card) return;

          // 완료 점멸 — 회의 피드백: 100% 도달 시 서빙 타이밍 알림
          const wasComplete = card.dataset.lastStatus === 'complete';
          if (s.status === 'complete' && !wasComplete) {
            // 새로 complete 가 됐을 때 점멸 시작
            card.classList.add('is-complete-flash');
            clearTimeout(card._flashTimer);
            card._flashTimer = setTimeout(function () {
              card.classList.remove('is-complete-flash');
            }, 30 * 1000); // 30초간 점멸
          } else if (s.status !== 'complete' && card.classList.contains('is-complete-flash')) {
            card.classList.remove('is-complete-flash');
            clearTimeout(card._flashTimer);
          }
          card.dataset.lastStatus = s.status;
        });
      });
  }
  setInterval(update, 1000);
  update();

  // ─── 클릭 인터랙션 (회의 피드백 v1.2) ────────────────────
  // 1) 추출 중 레시피 영역 클릭 → 매뉴얼 레시피 변경 (confirm 후 적용)
  // 2) 즐겨찾기 슬롯 클릭 → 해당 슬롯 레시피로 즉시 적용 (confirm 후)
  function pickRecipeForSpout(spoutId, presetRid) {
    if (!window.IRRecipePicker) return;
    // 현재 추출구의 현재 레시피명 조회 (confirm 멘트용)
    Promise.all([
      fetch('/api/spouts').then(r => r.json()),
      fetch('/api/recipes').then(r => r.json())
    ]).then(function (rs) {
      var sp = rs[0].find(function (x) { return x.id === spoutId; });
      var allRecipes = rs[1];
      var currentR = sp ? allRecipes.find(function (r) { return r.id === sp.currentRecipeId; }) : null;
      var currentName = currentR ? (currentR.name || ('레시피 ' + currentR.id)) : '없음';

      function applyChange(newRid) {
        var newR = allRecipes.find(function (r) { return r.id === newRid; });
        var newName = newR ? (newR.name || ('레시피 ' + newR.id)) : '레시피';
        // 회의 피드백: 잘못 눌렀을 가능성 → 무조건 confirm
        window.IRModal.confirm({
          title: '레시피 변경',
          body: '추출구 ' + spoutId + '에 ' +
                '<b>' + currentName + '</b> → <b>' + newName + '</b>로 변경합니다.<br>장비에 새 레시피를 적용할까요?',
          ok: '변경',
          onOk: function () {
            // BUG #1 fix: localStorage override 에 저장 → 폴링이 덮어쓰지 못함
            window.IRState.setSpoutOverride(spoutId, newRid);
            window.IRToast?.show('추출구 ' + spoutId + ' → ' + newName + ' 적용 (장비 sync 중)');
            if (sp) sp.currentRecipeId = newRid;
            var card = document.querySelector('.spout-card[data-spout="' + spoutId + '"]');
            if (card) applyRecipe(card, newR);
          }
        });
      }

      if (presetRid != null) {
        // 즐겨찾기 슬롯 클릭 — 이미 같은 레시피면 confirm 생략 (이미 적용 중)
        if (sp && sp.currentRecipeId === presetRid) {
          window.IRToast?.show('이미 적용 중인 레시피입니다.');
          return;
        }
        applyChange(presetRid);
      } else {
        // 추출 중 레시피 박스 클릭 — picker 모달로 전체 레시피 중 선택
        window.IRRecipePicker.open({
          title: '추출구 ' + spoutId + ' — 레시피 선택',
          selectedId: sp ? sp.currentRecipeId : null,
          onPick: function (rid) {
            if (sp && sp.currentRecipeId === rid) return;
            applyChange(rid);
          }
        });
      }
    });
  }

  // 메인 카드 컨테이너에 이벤트 위임 (5 카드 공통)
  document.querySelector('.stations').addEventListener('click', function (ev) {
    var spoutCard = ev.target.closest('.spout-card');
    if (!spoutCard) return;
    var spoutId = parseInt(spoutCard.dataset.spout, 10);

    // 즐겨찾기 슬롯 클릭
    var slot = ev.target.closest('.st-slot');
    if (slot) {
      ev.stopPropagation();
      var slotIdx = parseInt(slot.dataset.slot, 10);
      // 현재 spout 의 favoriteRecipeIds 에서 해당 슬롯의 레시피 id 가져오기
      fetch('/api/spouts').then(r => r.json()).then(function (sps) {
        var sp = sps.find(function (x) { return x.id === spoutId; });
        var rid = sp && sp.favoriteRecipeIds ? sp.favoriteRecipeIds[slotIdx] : null;
        if (rid == null) {
          window.IRToast?.show('비어 있는 슬롯입니다. 즐겨찾기 페이지에서 등록하세요.');
          return;
        }
        pickRecipeForSpout(spoutId, rid);
      });
      return;
    }

    // 추출 중 레시피 박스 클릭
    var recipeBox = ev.target.closest('.spout-recipe-btn');
    if (recipeBox) {
      ev.stopPropagation();
      pickRecipeForSpout(spoutId, null);
      return;
    }

    // 카드 본체 클릭 (슬롯/레시피버튼 아님) — status 따라 모달 분기 (5/27)
    Promise.all([
      fetch('/api/spouts').then(r => r.json()),
      fetch('/api/recipes').then(r => r.json())
    ]).then(function (rs) {
      var rawSp = rs[0].find(function (x) { return x.id === spoutId; });
      if (!rawSp) return;
      // 로컬 override 적용 (display 와 일관)
      var withRecipe = window.IRState ? window.IRState.applySpoutOverrides([rawSp])[0] : rawSp;
      var sp = window.IRState && window.IRState.applySpoutStatusOverrides
        ? window.IRState.applySpoutStatusOverrides([withRecipe])[0]
        : withRecipe;
      var recipe = rs[1].find(function (r) { return r.id === sp.currentRecipeId; });
      var recipeName = recipe ? (recipe.name || ('레시피 ' + recipe.id)) : '레시피 없음';

      if (sp.status === 'complete') {
        // 완료 카드 클릭 → 서빙 완료 확인
        window.IRModal.confirm({
          title: '서빙 완료',
          body: '추출구 ' + spoutId + ' 의 서빙을 완료 처리할까요?<br>완료 후 추출구는 <b>대기</b> 상태로 돌아갑니다.',
          ok: '서빙 완료',
          onOk: function () {
            window.IRState.setSpoutStatus(spoutId, 'idle');
            spoutCard.classList.remove('is-complete-flash');
            clearTimeout(spoutCard._flashTimer);
            window.IRToast && window.IRToast.show('추출구 ' + spoutId + ' 서빙 완료');
            update();
          }
        });
      } else if (sp.status === 'idle') {
        // idle 카드 클릭 → 추출 시작 확인
        if (!recipe) {
          window.IRToast && window.IRToast.show('추출 시작 불가 — 먼저 레시피를 선택하세요.');
          return;
        }
        window.IRModal.confirm({
          title: '추출 시작',
          body: '추출구 ' + spoutId + ' 에서 <b>' + recipeName + '</b><br>(' + (recipe.coffeeWeight || '--') + 'g · ' + (recipe.ratio || '--') + ' · ' + (recipe.waterWeight || '--') + 'g) 로 추출을 시작합니다.',
          ok: '시작',
          onOk: function () {
            window.IRState.setSpoutStatus(spoutId, 'extracting');
            window.IRToast && window.IRToast.show('추출구 ' + spoutId + ' 추출 시작');
            update();
          }
        });
      }
      // brewing/rinsing/watering 중 카드 클릭은 무시 (진행 중 — 별도 액션 없음)
    });
  });

  // ─── v1.1 S2.1.7 매뉴얼 큐 클릭 인터랙션 ───────────────
  // 셀 클릭 → recipe-picker 모달 → 큐에 추가/변경 (mock — localStorage override)
  function setQueueOverride(spoutId, slot, recipeId) {
    var key = 'ir.queueOverride';
    var raw = localStorage.getItem(key);
    var ov = {};
    try { ov = raw ? JSON.parse(raw) : {}; } catch (e) {}
    if (!ov[spoutId]) ov[spoutId] = [];
    if (recipeId == null) ov[spoutId].splice(slot, 1);
    else ov[spoutId][slot] = recipeId;
    localStorage.setItem(key, JSON.stringify(ov));
  }
  document.getElementById('manual-queue').addEventListener('click', function (ev) {
    var clearBtn = ev.target.closest('#mq-clear-all');
    if (clearBtn) {
      window.IRModal.confirm({
        title: '큐 전체 비우기',
        body: '모든 추출구의 매뉴얼 큐를 비웁니다.',
        bodyClass: 'is-error',
        ok: '비우기',
        onOk: function () {
          localStorage.removeItem('ir.queueOverride');
          window.IRToast?.show('매뉴얼 큐 전체 비움');
          // 카드 즉시 갱신 — 다음 폴링까지 빈 큐로 보이게 (mock만)
          document.querySelectorAll('.mq-cell').forEach(function (c) {
            c.classList.remove('is-filled', 'is-head');
            c.querySelector('.mq-cell-recipe').textContent = '—';
          });
        }
      });
      return;
    }
    var cell = ev.target.closest('.mq-cell');
    if (!cell) return;
    var col = cell.closest('.mq-col');
    var spoutId = parseInt(col.dataset.spout, 10);
    var slotIdx = parseInt(cell.dataset.slot, 10);
    if (!window.IRRecipePicker) return;
    window.IRRecipePicker.open({
      title: '추출구 ' + spoutId + ' 큐 ' + (slotIdx + 1) + '번 — 레시피 선택',
      allowClear: true,
      onPick: function (rid) {
        setQueueOverride(spoutId, slotIdx, rid);
        window.IRToast?.show('추출구 ' + spoutId + ' 큐 ' + (slotIdx + 1) + (rid != null ? ' 추가' : ' 비움'));
      }
    });
  });
})();
</script>
