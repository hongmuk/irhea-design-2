<!-- 보안 정보 — 엔지니어 모드 (회의 v1.1: 패스워드 게이트 + 검색 + FATAL 마스킹) -->
<style>
  /* v1.1 S4.4.0 검색 바 */
  .sec-filter {
    display: grid; grid-template-columns: 1.5fr 1fr 1fr 1.2fr auto;
    gap: 8px; margin-bottom: 14px;
    padding: 10px 12px;
    border: 1px solid var(--ir-line);
    background: var(--ir-bg-2);
  }
  .sec-input, .sec-select {
    height: 32px; padding: 0 10px;
    border: 1px solid var(--ir-line);
    background: var(--ir-bg);
    font-size: 12.5px; color: var(--ir-fg);
    font-family: inherit;
  }
  .sec-input:focus, .sec-select:focus { outline: none; border-color: var(--ir-fg); }
  .sec-select:disabled { background: #F3F4F6; color: var(--ir-fg-muted); cursor: not-allowed; }
  .sec-clear {
    height: 32px; padding: 0 14px;
    border: 1px solid var(--ir-line-strong);
    background: var(--ir-bg); color: var(--ir-fg);
    font-size: 11.5px; font-weight: 700;
    cursor: pointer; font-family: inherit;
  }
  .sec-clear:hover { background: #FAFAFA; }
</style>
<div class="ir-shell">
  <div class="ir-content" style="padding:24px 28px 18px;">

    <div style="margin-bottom:14px;display:flex;align-items:baseline;justify-content:space-between;">
      <div>
        <span class="ir-page-sub">🔒 Engineer mode · audit</span>
        <h1 class="ir-page-title" style="font-size:24px;margin:2px 0 0;">보안 <em>정보.</em></h1>
      </div>
      <span style="font-size:11px;color:var(--ir-fg-muted);padding:4px 10px;border:1px solid var(--ir-line);background:var(--ir-bg-2);letter-spacing:0.3px;">로그인 <b style="color:var(--ir-fg);">Admin</b> · <a href="#" id="sec-logout" style="color:var(--ir-orange-deep);text-decoration:none;font-weight:700;">로그아웃</a></span>
    </div>

    <!-- v1.1 S4.4.0: 검색 바 (기간 / 코드 / 소스 / 심각도 / 키워드) — 4분할 전체에 적용 -->
    <div class="sec-filter">
      <input type="text" class="sec-input" id="sec-q" placeholder="🔍  코드 / 메시지 키워드">
      <select class="sec-select" id="sec-period">
        <option value="all">전체 기간</option>
        <option value="7d">최근 7일</option>
        <option value="30d">최근 30일</option>
        <option value="90d">최근 90일</option>
      </select>
      <select class="sec-select" id="sec-source">
        <option value="all">전체 소스</option>
        <option value="Spout1">Spout1</option>
        <option value="Spout2">Spout2</option>
        <option value="Spout3">Spout3</option>
        <option value="Spout4">Spout4</option>
        <option value="Spout5">Spout5</option>
        <option value="Boiler">Boiler</option>
        <option value="MCP">MCP</option>
      </select>
      <select class="sec-select" id="sec-severity">
        <option value="all">전체 심각도</option>
        <option value="FATAL">FATAL (디스트리뷰터 마스킹)</option>
        <option value="ERROR">ERROR</option>
        <option value="WARN">WARN</option>
        <option value="INFO">INFO</option>
      </select>
      <button class="sec-clear" id="sec-clear">초기화</button>
    </div>

    <div class="sec-grid" style="display:grid;grid-template-columns:repeat(2,1fr);grid-template-rows:1fr 1fr;gap:14px;flex:1;">

      <!-- 로그 정보 -->
      <div class="ir-card" style="padding:0;">
        <div class="ir-card-header">로그 정보</div>
        <div style="padding:14px 18px;font-family:var(--ir-font-mono);font-size:11px;line-height:1.55;height:200px;overflow:auto;" id="sec-log"></div>
        <div style="display:flex;justify-content:flex-end;padding:8px 18px 14px;">
          <button class="ir-btn ir-btn-pill" id="sec-log-backup" style="font-size:13px;padding:8px 18px;">로그 백업</button>
        </div>
      </div>

      <!-- 오류 발생 정보 -->
      <div class="ir-card" style="padding:0;">
        <div class="ir-card-header">오류 발생 정보</div>
        <div style="padding:14px 18px;">
          <table class="ir-table" id="sec-err"></table>
        </div>
      </div>

      <!-- 사용 실적 정보 — 초기화 버튼은 HM 전용 (회의 피드백 v1.2: 사용자/총판 절대 못함) -->
      <div class="ir-card" style="padding:0;">
        <div class="ir-card-header">사용 실적 정보 <em style="font-weight:500;font-size: clamp(11.5px, 1vw + 7px, 14px);color:var(--ir-fg-muted);margin-left:6px;">(누적 카운트, 사용자 추출 실적은 /history)</em></div>
        <div style="padding:14px 18px;font-size:13px;line-height:1.65;">
          <div style="margin-bottom:8px;font-weight:700;">1) 펌프 사용량 :</div>
          <div id="sec-pump" style="margin-bottom:14px;color:var(--ir-fg-muted);"></div>
          <div style="margin-bottom:8px;font-weight:700;">2) 솔밸브 동작 :</div>
          <div id="sec-extract" style="color:var(--ir-fg-muted);"></div>
          <div style="display:flex;gap:8px;margin-top:14px;justify-content:flex-end;align-items:center;">
            <span style="flex:1;font-size:11px;color:var(--ir-fg-muted);font-style:italic;">⚠ 누적 카운트 초기화는 제조사(HM) 전용 작업입니다.</span>
            <button class="ir-btn ir-btn-pill" id="sec-reset-one"   style="font-size:12px;padding:8px 16px;opacity:0.45;cursor:not-allowed;" disabled>단일 초기화</button>
            <button class="ir-btn ir-btn-pill" id="sec-reset-all"   style="font-size:12px;padding:8px 16px;opacity:0.45;cursor:not-allowed;" disabled>전체 초기화</button>
          </div>
        </div>
      </div>

      <!-- 오류 상세 — 회의 피드백 v1.2: 오류 발생 시 주변 동작 추출구 함께 표시 -->
      <div class="ir-card" style="padding:0;">
        <div class="ir-card-header">오류 상세 정보</div>
        <div style="padding:14px 18px;font-size:13px;line-height:1.75;" id="sec-detail">
          <div>· 에러 발생 일시: <strong id="ed-date">—</strong></div>
          <div>· 오류코드: <strong id="ed-code">—</strong></div>
          <div>· 발생 소스: <strong id="ed-source">—</strong></div>
          <div>· 상세 메시지: <strong id="ed-message">—</strong></div>
          <div style="margin-top:8px;padding-top:8px;border-top:1px solid var(--ir-line);">
            <div style="font-weight:700;color:var(--ir-fg-muted);font-size:11px;letter-spacing:0.3px;text-transform:uppercase;margin-bottom:4px;">발생 시 주변 추출구 상태</div>
            <div id="ed-surrounding" style="font-size:12px;color:var(--ir-fg-muted);">— 데이터 없음</div>
          </div>
        </div>
      </div>

    </div>

    <div style="display:flex;justify-content:flex-end;padding-top:12px;">
      <a class="ir-btn ir-btn-pill" href="/info">복귀</a>
    </div>
  </div>
</div>

<script>
(function () {
  // ─── 엔지니어 모드 패스워드 게이트 (회의 피드백 v1.2) ──────────
  // sessionStorage['ir-admin-ok'] 체크. 없으면 로그인 모달.
  function requireAdminAuth() {
    if (sessionStorage.getItem('ir-admin-ok') === '1') return Promise.resolve(true);
    return new Promise(function (resolve) {
      var overlay = document.getElementById('ir-modal-overlay');
      var title = document.getElementById('ir-modal-title');
      var body = document.getElementById('ir-modal-body');
      var actions = document.getElementById('ir-modal-actions');
      title.textContent = '🔒 엔지니어 모드 인증';
      body.className = 'ir-modal-body is-info';
      body.innerHTML =
        '<div style="font-size:13px;color:var(--ir-fg-muted);margin-bottom:12px;">보안 정보는 엔지니어 권한이 필요합니다.</div>' +
        '<div style="display:grid;grid-template-columns:auto 1fr;column-gap:14px;row-gap:10px;align-items:center;font-size:14px;font-weight:600;">' +
          '<div>아이디</div><input class="ir-input" id="sec-id" value="Admin" autocomplete="off"/>' +
          '<div>비밀번호</div><input class="ir-input" id="sec-pw" type="password" autocomplete="off" placeholder="********"/>' +
        '</div>';
      actions.innerHTML = '';
      var ok = document.createElement('button');
      ok.className = 'ir-modal-btn is-primary';
      ok.textContent = '인증';
      var cancel = document.createElement('button');
      cancel.className = 'ir-modal-btn';
      cancel.textContent = '취소';

      cancel.onclick = function () {
        overlay.classList.remove('is-open');
        history.back();
      };
      ok.onclick = function () {
        var u = document.getElementById('sec-id').value;
        var p = document.getElementById('sec-pw').value;
        fetch('/api/admin/login', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ username: u, password: p })
        }).then(function (r) {
          if (r.ok) {
            sessionStorage.setItem('ir-admin-ok', '1');
            overlay.classList.remove('is-open');
            resolve(true);
          } else {
            overlay.classList.remove('is-open');
            window.IRModal.open('alert-password-error', function () {
              // 재시도
              requireAdminAuth().then(resolve);
            });
          }
        });
      };
      actions.appendChild(ok);
      actions.appendChild(cancel);
      overlay.classList.add('is-open');
      setTimeout(function () { document.getElementById('sec-pw').focus(); }, 60);
    });
  }

  // 로그아웃 핸들러
  document.getElementById('sec-logout')?.addEventListener('click', function (ev) {
    ev.preventDefault();
    sessionStorage.removeItem('ir-admin-ok');
    window.IRToast?.show('엔지니어 모드 로그아웃');
    setTimeout(function () { location.href = '/info'; }, 400);
  });

  // v1.1 S4.4.0: 권한 체크 (현재 sessionStorage는 admin만 — 디스트리뷰터/개발자는 백엔드 협의 시 분리)
  // 일단 sessionStorage 에 ir-role 이 distributor 인 경우 FATAL 마스킹
  var userRole = sessionStorage.getItem('ir-role') || 'developer'; // 기본은 개발자 (전체 노출)
  var maskFATAL = (userRole === 'distributor');

  // 검색 필터 상태
  var allErrs = [], allLog = [];
  var filter = { q: '', period: 'all', source: 'all', severity: 'all' };

  function filterErrs() {
    return allErrs.filter(function (e) {
      if (maskFATAL && /FATAL/i.test(e.severity || '')) return false;
      if (filter.q && !((e.code + ' ' + (e.message || '')).toLowerCase().indexOf(filter.q.toLowerCase()) >= 0)) return false;
      if (filter.source !== 'all' && e.source !== filter.source) return false;
      if (filter.severity !== 'all' && (e.severity || 'ERROR') !== filter.severity) return false;
      if (filter.period !== 'all') {
        var days = filter.period === '7d' ? 7 : filter.period === '30d' ? 30 : 90;
        var cutoff = Date.now() - days * 86400 * 1000;
        var t = new Date(e.date.replace(/[.]/g, '-')).getTime();
        if (t < cutoff) return false;
      }
      return true;
    });
  }
  function filterLog() {
    if (!filter.q) return allLog;
    var q = filter.q.toLowerCase();
    return allLog.filter(function (l) { return String(l).toLowerCase().indexOf(q) >= 0; });
  }

  function renderLog() {
    document.getElementById('sec-log').innerHTML = filterLog().map(function (l) {
      return '<div>' + l.replace(/</g, '&lt;') + '</div>';
    }).join('') || '<div style="color:var(--ir-fg-muted);font-style:italic;">— 일치하는 로그 없음 —</div>';
  }
  var STATUS_KO = { idle: '대기', extracting: '추출 중', complete: '완료', rinsing: '린스 중', watering: '온수 중', error: '⚠ 오류' };
  function showDetail(e) {
    document.getElementById('ed-date').textContent    = e.date;
    document.getElementById('ed-code').textContent    = e.code;
    document.getElementById('ed-source').textContent  = e.source;
    document.getElementById('ed-message').textContent = e.message;

    var surround = document.getElementById('ed-surrounding');
    if (e.surrounding && e.surrounding.spouts) {
      var rows = e.surrounding.spouts.map(function (sp) {
        var st = STATUS_KO[sp.status] || sp.status;
        var stColor = sp.status === 'error' ? 'color:var(--ir-status-error);font-weight:800;'
                    : sp.status === 'idle' ? 'color:var(--ir-fg-muted);'
                    : 'color:var(--ir-fg);font-weight:600;';
        var recipeStr = sp.recipeId != null ? ' · 레시피 ' + sp.recipeId : '';
        return '<div style="display:flex;justify-content:space-between;padding:2px 0;">' +
                 '<span>추출구 ' + sp.id + recipeStr + '</span>' +
                 '<span style="' + stColor + '">' + st + '</span>' +
               '</div>';
      }).join('');
      var env = '<div style="margin-top:5px;padding-top:5px;border-top:1px dashed var(--ir-line);color:var(--ir-fg-muted);font-size: clamp(11.5px, 1vw + 7px, 14px);">' +
                  '보일러 ' + (e.surrounding.boilerTemp || '?') + '°C · 외기 ' + (e.surrounding.ambientTemp || '?') + '°C' +
                '</div>';
      surround.innerHTML = rows + env;
    } else {
      surround.innerHTML = '<span style="color:var(--ir-fg-muted);">주변 상태 데이터 없음</span>';
    }
  }
  function bindRowClick() {
    var tbl = document.getElementById('sec-err');
    tbl.querySelectorAll('tr[data-i]').forEach(function (tr) {
      tr.addEventListener('click', function () {
        var idx = parseInt(tr.dataset.i, 10);
        showDetail(allErrs[idx]);
      });
    });
  }
  function renderErrs() {
    var errs = filterErrs();
    var tbl = document.getElementById('sec-err');
    tbl.innerHTML = '<thead><tr><th>일시</th><th>오류코드</th></tr></thead><tbody>' +
      (errs.length ? errs.map(function (e) {
        var origIdx = allErrs.indexOf(e);
        var hl = e.highlight ? 'style="color:var(--ir-status-error);font-weight:800;cursor:pointer;" data-i="' + origIdx + '"'
                             : 'style="cursor:pointer;" data-i="' + origIdx + '"';
        return '<tr ' + hl + '><td>' + e.date + '</td><td>' + e.code + '</td></tr>';
      }).join('') : '<tr><td colspan="2" style="text-align:center;color:var(--ir-fg-muted);padding:14px 0;font-style:italic;">— 일치하는 오류 없음 —</td></tr>') +
      '</tbody>';
    bindRowClick();
  }

  // 인증 후 데이터 로드
  requireAdminAuth().then(function () {
    return Promise.all([
      fetch('/api/system-log').then(function (r) { return r.json(); }),
      fetch('/api/error-log').then(function (r) { return r.json(); }),
      fetch('/api/usage-stats').then(function (r) { return r.json(); })
    ]);
  }).then(function (rs) {
    allLog = rs[0] || []; allErrs = rs[1] || []; var us = rs[2] || {};

    // 검색 바 권한 안내
    if (maskFATAL) {
      var sev = document.getElementById('sec-severity');
      sev.disabled = true;
      sev.title = '디스트리뷰터 권한 — FATAL 항목은 마스킹됩니다';
    }
    // 검색 바 입력 바인딩
    document.getElementById('sec-q').addEventListener('input', function (ev) {
      if (ev.isComposing) return;
      filter.q = ev.target.value.trim();
      renderLog(); renderErrs();
    });
    document.getElementById('sec-q').addEventListener('compositionend', function (ev) {
      filter.q = ev.target.value.trim(); renderLog(); renderErrs();
    });
    ['sec-period','sec-source','sec-severity'].forEach(function (id) {
      document.getElementById(id).addEventListener('change', function (ev) {
        filter[id.replace('sec-','')] = ev.target.value;
        renderErrs();
      });
    });
    document.getElementById('sec-clear').addEventListener('click', function () {
      filter = { q:'', period:'all', source:'all', severity:'all' };
      document.getElementById('sec-q').value = '';
      document.getElementById('sec-period').value = 'all';
      document.getElementById('sec-source').value = 'all';
      if (!maskFATAL) document.getElementById('sec-severity').value = 'all';
      renderLog(); renderErrs();
    });

    renderLog();
    renderErrs();
    // 첫 항목 자동 선택 (renderErrs 가 이미 bindRowClick 호출함)
    if (allErrs.length) showDetail(allErrs[0]);

    var pump = us.pumpUsage || {};
    document.getElementById('sec-pump').innerHTML =
      ['1st','2nd','3rd','4th','5th'].map(function (k) {
        return '<span style="margin-right:14px;color:var(--ir-fg);">' + k + ':' +
               '<strong style="color:var(--ir-orange);"> ' + (pump[k] || 0) + '회</strong></span>';
      }).join('');

    var extract = us.extractCount || {};
    document.getElementById('sec-extract').innerHTML =
      ['1st','2nd','3rd','4th','5th'].map(function (k) {
        return '<span style="margin-right:14px;color:var(--ir-fg);">' + k + ':' +
               '<strong style="color:var(--ir-orange);"> ' + (extract[k] || 0) + '회</strong></span>';
      }).join('');
  });

  document.getElementById('sec-log-backup').addEventListener('click', function () {
    window.IRModal.info({ body: '로그 백업 시작' });
  });
  document.getElementById('sec-reset-one').addEventListener('click', function () {
    window.IRModal.confirm({
      title: '추출구 실적 초기화',
      body: '복구불가<br>진행하시겠습니까?',
      bodyClass: 'is-error',
      ok: '초기화',
      onOk: function () { window.IRModal.info({ body: '초기화 완료' }); }
    });
  });
  document.getElementById('sec-reset-all').addEventListener('click', function () {
    window.IRModal.confirm({
      title: '전체 실적 초기화',
      body: '복구불가<br>진행하시겠습니까?',
      bodyClass: 'is-error',
      ok: '전체 초기화',
      onOk: function () { window.IRModal.info({ body: '전체 초기화 완료' }); }
    });
  });
})();
</script>
