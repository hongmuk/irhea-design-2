<!-- 자동 재연결 (S1.1) — designs/02-connect-loading.html 정합. Topbar는 layout.ejs. -->

<div class="connect-shell">

  <div class="kicker">장치 연결</div>
  <div class="title">등록된 머신에 자동 연결 중<em>...</em></div>

  <div class="diagram">
    <div class="node">
      <div class="node-box machine">📡</div>
      <div class="node-lbl">머신 AP</div>
      <div class="node-sub">iRHEA-A3F7B219</div>
    </div>
    <div style="display:flex; flex-direction:column; align-items:center; gap:8px;">
      <span class="wifi-lbl">WIFI</span>
      <div class="waves">
        <span class="wave"></span><span class="wave"></span><span class="wave"></span><span class="wave"></span><span class="wave"></span>
      </div>
    </div>
    <div class="node">
      <div class="node-box">📱</div>
      <div class="node-lbl">태블릿</div>
    </div>
  </div>

  <div class="target">
    <div class="target-info">
      <div class="target-lbl">대상 머신</div>
      <div class="target-name">NT-iRhea 1호기</div>
      <div class="target-meta">SN: R5KrW2600001 · SSID: iRHEA-A3F7B219</div>
    </div>
    <div class="scan-dot">SCAN</div>
  </div>

  <div class="connect-actions">
    <button class="manual" id="conn-manual">수동 모드 (AP 스캔)</button>
    <button class="conn-go" id="conn-go">연결 시작</button>
  </div>

  <div class="footer-line">
    타임아웃까지 <b id="conn-tmo">10초</b>
    <span class="progress"></span>
    <span style="color:var(--ink-3);">머신 전원 / WiFi 신호를 확인하세요</span>
  </div>

  <!-- Dev FAB: toggle mock fail mode -->
  <button class="dev-fab" id="conn-fail-toggle" title="MOCK FAIL 토글">MOCK<br>FAIL</button>

</div>

<style>
  /* connect (S1.1) — designs/02-connect-loading.html 정합 */
  .connect-shell { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 40px 60px; gap: 28px; position: relative; background: var(--bg); }

  .kicker { font-size: 11px; color: var(--brand); font-weight: 700; letter-spacing: 2px; text-transform: uppercase; }
  .title { font-size: 22px; font-weight: 600; color: var(--ink); letter-spacing: -0.5px; text-align: center; }
  .title em { font-style: normal; color: var(--brand); }

  .diagram { display: flex; align-items: center; gap: 38px; padding: 28px 48px; border: 1px dashed var(--hair-2); background: #FCFCFC; }
  .node { display: flex; flex-direction: column; align-items: center; gap: 6px; min-width: 96px; }
  .node-box { width: 64px; height: 80px; border: 1.5px solid var(--ink); display: flex; align-items: center; justify-content: center; font-size: 24px; background: var(--bg); position: relative; }
  .node-box.machine { width: 80px; }
  .node-box.machine::after { content: ''; position: absolute; top: -6px; right: -6px; width: 10px; height: 10px; background: var(--brand); border-radius: 50%; box-shadow: 0 0 8px var(--brand); animation: conn-pulse 1s ease-in-out infinite; }
  .node-lbl { font-size: 10.5px; color: var(--ink-3); font-weight: 600; letter-spacing: 0.4px; text-transform: uppercase; }
  .node-sub { font-size: 10.5px; color: var(--ink); font-weight: 600; font-family: var(--font-mono); letter-spacing: 0.5px; }

  .waves { display: flex; align-items: center; gap: 4px; padding: 0 8px; }
  .wave { width: 4px; height: 4px; background: var(--brand); border-radius: 50%; animation: conn-wave 1.4s ease-in-out infinite; }
  .wave:nth-child(2) { animation-delay: 0.18s; }
  .wave:nth-child(3) { animation-delay: 0.36s; }
  .wave:nth-child(4) { animation-delay: 0.54s; }
  .wave:nth-child(5) { animation-delay: 0.72s; }
  @keyframes conn-wave { 0%,100% { transform: scale(0.6); opacity: 0.25; } 50% { transform: scale(1.3); opacity: 1; } }
  @keyframes conn-pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }
  .wifi-lbl { font-size: 10px; color: var(--ink-3); font-weight: 700; letter-spacing: 1.5px; }

  .target { width: 460px; border: 1px solid var(--hair); padding: 14px 18px; display: flex; align-items: center; gap: 16px; background: var(--bg); }
  .target-info { flex: 1; }
  .target-lbl { font-size: 10px; color: var(--ink-3); font-weight: 600; letter-spacing: 0.5px; text-transform: uppercase; }
  .target-name { font-size: 16px; font-weight: 600; color: var(--ink); letter-spacing: -0.3px; margin-top: 2px; }
  .target-meta { font-size: 10.5px; color: var(--ink-3); font-weight: 500; font-family: var(--font-mono); margin-top: 4px; letter-spacing: 0.3px; }
  .scan-dot { width: 38px; height: 38px; border: 1.5px dashed var(--brand); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 9px; color: var(--brand); font-weight: 700; letter-spacing: 0.5px; animation: conn-rot 2.4s linear infinite; }
  @keyframes conn-rot { from { transform: rotate(0); } to { transform: rotate(360deg); } }

  .connect-actions { display: flex; gap: 10px; }
  .manual { font-size: 12px; padding: 10px 22px; border: 1px dashed var(--hair-2); color: var(--ink-2); font-weight: 600; cursor: pointer; transition: all 0.15s; background: var(--bg); font-family: inherit; }
  .manual:hover { border-color: var(--ink); color: var(--ink); }
  .conn-go { font-size: 13px; padding: 10px 28px; background: var(--brand); color: #fff; border: 1px solid var(--brand); font-weight: 700; cursor: pointer; font-family: inherit; letter-spacing: 0.2px; }
  .conn-go:hover { background: #C8000F; border-color: #C8000F; }
  .conn-go:disabled { opacity: 0.6; cursor: wait; }

  .footer-line { position: absolute; bottom: 18px; left: 0; right: 0; text-align: center; font-size: 11px; color: var(--ink-3); font-weight: 500; }
  .footer-line b { color: var(--brand); font-weight: 700; font-variant-numeric: tabular-nums; }
  .footer-line .progress { display: inline-block; width: 120px; height: 2px; background: var(--hair); margin: 0 12px; position: relative; vertical-align: middle; }
  .footer-line .progress::after { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 100%; background: var(--brand); animation: conn-countdown 10s linear forwards; }
  @keyframes conn-countdown { from { width: 100%; } to { width: 0; } }

  .dev-fab { position: absolute; left: 24px; bottom: 24px; width: 56px; height: 56px; border-radius: 50%; border: 1px solid var(--hair-2); background: var(--bg); color: var(--ink-3); font-size: 10px; font-weight: 700; line-height: 1.1; cursor: pointer; font-family: inherit; }
  .dev-fab:hover { background: #FAFAFA; }
  .dev-fab.is-on { background: var(--brand); border-color: var(--brand); color: #fff; }
</style>

<script>
(function () {
  var failNext = false;
  var tmoEl = document.getElementById('conn-tmo');
  var sec = 10;
  var tick = setInterval(function () {
    sec -= 1;
    if (sec <= 0) { clearInterval(tick); }
    if (tmoEl) tmoEl.textContent = Math.max(0, sec) + '초';
  }, 1000);

  var btn = document.getElementById('conn-go');
  btn.addEventListener('click', function () {
    btn.disabled = true;
    btn.textContent = '연결 중…';
    setTimeout(function () {
      if (failNext) {
        btn.disabled = false; btn.textContent = '재시도';
        window.IRModal?.confirm({
          title: '연결 실패',
          body: '머신과 연결할 수 없습니다.<br>전원과 WiFi 신호를 확인하세요.',
          onOk: function () { btn.click(); }
        });
      } else {
        btn.textContent = '연결됨';
        window.IRToast?.show('머신과 연결되었습니다. 메인 화면으로 이동합니다.');
        setTimeout(function () { window.location.href = '/main'; }, 800);
      }
    }, 1500);
  });

  document.getElementById('conn-manual').addEventListener('click', function () {
    // Per spec: S1.1 → S1.3 AP 스캔 화면.
    window.location.href = '/connect/ap-scan';
  });

  var fail = document.getElementById('conn-fail-toggle');
  fail.addEventListener('click', function () {
    failNext = !failNext;
    fail.classList.toggle('is-on', failNext);
    window.IRToast?.show(failNext ? 'MOCK FAIL 모드 ON' : 'MOCK FAIL 모드 OFF');
  });
})();
</script>
