<!-- 정보 (S8.1) — designs/02-info.html 정합 (v1.1: 4 패널 2×2 + 실적 → S8.3 분리). Topbar는 layout.ejs. -->

<div class="sub-h">
  <div class="sub-h-l">정보<em>장비 · 보일러 · 사용량</em></div>
  <div class="sub-h-r">
    <span>인증 <span class="ok">완료</span></span>
    <span>로그인 <b>Admin</b></span>
    <!-- 시계는 탑바에 상시 노출됨 (회의 §5.3 — 정보 페이지에서 중복 제거) -->
  </div>
</div>

<div class="info-body">

  <!-- Panel 1: 장비 정보 -->
  <div class="panel">
    <div class="panel-h">
      <span class="panel-title"><span class="ico">⚙</span>장비 정보</span>
      <span class="panel-id">8.1.1</span>
    </div>
    <div class="pr"><span class="pr-k">일련 번호</span><span class="pr-v mono" id="info-serial">R5KRW2600001<span class="ro">read-only</span></span></div>
    <div class="pr"><span class="pr-k">모델 번호</span><span class="pr-v" id="info-model">iRHEA-Light-M5</span></div>
    <div class="pr"><span class="pr-k">펌웨어 버전</span><span class="pr-v" id="info-fw">1.0 <em>(2026.03.01)</em></span></div>
    <div class="pr"><span class="pr-k">타임존</span><span class="pr-v">Asia / Seoul <em>(UTC+9)</em></span></div>
    <div class="pr"><span class="pr-k">최초 설치일</span><span class="pr-v" id="info-install">2026.03.17</span></div>
    <div class="panel-foot"><span>관리자 메뉴에서 변경 가능</span><a href="/setup">변경 →</a></div>
  </div>

  <!-- Panel 2: 보일러 정보 — 회의 피드백 v1.3:
       - 워터펌프 사양 / 솔 밸브 종류 제거 (불필요)
       - 온도 최대 제거 (탑바에 상시 노출) -->
  <div class="panel">
    <div class="panel-h">
      <span class="panel-title"><span class="ico">🔥</span>보일러 정보</span>
      <span class="panel-id">8.1.2</span>
    </div>
    <div class="pr"><span class="pr-k">일련 번호</span><span class="pr-v mono" id="info-b-serial">R5KRM2600001<span class="ro">read-only</span></span></div>
    <div class="pr"><span class="pr-k">모델 번호</span><span class="pr-v" id="info-b-model">iRHEA-Light-M5</span></div>
    <div class="pr"><span class="pr-k">펌웨어</span><span class="pr-v" id="info-b-fw">1.0 <em>(2026.03.01)</em></span></div>
    <!-- 명세 v0.9 §4.1: 수량 / 수질 센서 — 보일러 정보에 추가 -->
    <div class="pr"><span class="pr-k">수량 센서</span><span class="pr-v" id="info-b-flow"><b>2,600</b> <em>/ 누적 ml</em></span></div>
    <div class="pr"><span class="pr-k">수질 센서</span><span class="pr-v" id="info-b-quality"><span style="color:#15803D;font-weight:700;">● 정상</span> <em>(제한값 이내)</em></span></div>
    <div class="panel-foot"><span>보일러 온도는 상단 바에서 실시간 확인</span></div>
  </div>

  <!-- 물붓기 범위 Panel 제거 — 회의 피드백 v1.3: 설정 페이지에 있음 (중복) -->

  <!-- Panel 3: 펌프 사용 정보 (장비 정보 — 추출 실적은 /history 로 분리됨) -->
  <div class="panel" style="grid-column: 1 / -1;">
    <div class="panel-h">
      <span class="panel-title"><span class="ico">⚙</span>펌프 / 솔밸브 사용 정보</span>
      <span class="panel-id">8.1.3</span>
    </div>
    <div style="display:grid; grid-template-columns: 1fr 1fr; gap: 8px 18px; font-size: 12px;">
      <div style="font-weight: 600; color: var(--ink-3); font-size: 10.5px; letter-spacing: 0.4px; padding-bottom: 4px; border-bottom: 1px solid var(--hair);">펌프 동작</div>
      <div style="font-weight: 600; color: var(--ink-3); font-size: 10.5px; letter-spacing: 0.4px; padding-bottom: 4px; border-bottom: 1px solid var(--hair);">솔밸브 동작</div>
      <div id="info-pump-usage"></div>
      <div id="info-valve-usage"></div>
    </div>
    <div class="panel-foot">
      <span>추출구별 누적 동작 횟수</span>
      <a href="/history" style="color: var(--brand); font-weight: 600; text-decoration: none;">추출 실적 →</a>
    </div>
  </div>

</div>

<style>
  /* info — designs/02-info.html 정합 */
  .sub-h { height: 48px; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--hair); flex-shrink: 0; background: var(--bg); }
  .sub-h-l { font-size: 15px; font-weight: 700; color: var(--ink); letter-spacing: -0.2px; }
  .sub-h-l em { font-style: normal; color: var(--ink-3); font-weight: 500; margin-left: 8px; font-size: 12px; }
  .sub-h-r { display: inline-flex; gap: 16px; align-items: center; font-size: 12px; color: var(--ink-3); }
  .sub-h-r b { color: var(--ink-2); font-weight: 700; }
  .sub-h-r .ok { color: var(--brand); font-weight: 700; }

  /* 패널 4개 → 3개로 축소 (회의 v1.3): 장비 정보 / 보일러 정보 / 펌프·솔밸브 사용 (전폭) */
  .info-body { flex: 1; padding: 18px 24px; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: auto 1fr; gap: 14px; min-height: 0; }
  .panel { border: 1px solid var(--hair); padding: 14px 16px; display: flex; flex-direction: column; gap: 8px; min-height: 0; position: relative; background: var(--bg); }

  .panel-h { display: flex; align-items: baseline; justify-content: space-between; padding-bottom: 8px; border-bottom: 1px solid var(--hair); margin: 0; }
  .panel-title { font-size: 13px; font-weight: 700; color: var(--ink); letter-spacing: -0.2px; }
  .panel-title .ico { margin-right: 6px; font-weight: 400; }
  .panel-id { font-size: 10px; color: var(--ink-3); font-weight: 500; letter-spacing: 0.4px; font-variant-numeric: tabular-nums; }

  /* 위계: 라벨(회색 11.5) / 값(검정 13) */
  .pr { display: grid; grid-template-columns: 130px 1fr; gap: 12px; align-items: baseline; padding: 6px 0; border-top: 1px solid var(--hair); font-size: 13px; }
  .pr:first-of-type { border-top: none; padding-top: 2px; }
  .pr-k { color: var(--ink-3); font-weight: 500; letter-spacing: -0.1px; }
  .pr-v { color: var(--ink); font-weight: 600; font-variant-numeric: tabular-nums; letter-spacing: -0.2px; }
  .pr-v.mono { font-family: var(--font-mono); font-size: 12px; }
  .pr-v em { color: var(--ink-3); font-weight: 500; font-style: normal; margin-left: 6px; }
  .pr-v .ro { font-size: 9px; color: var(--ink-3); border: 1px solid var(--hair-2); padding: 1px 4px; margin-left: 6px; font-weight: 600; letter-spacing: 0.3px; }

  .panel-foot { margin-top: auto; padding-top: 8px; border-top: 1px solid var(--hair); font-size: 10px; color: var(--ink-3); display: flex; align-items: center; justify-content: space-between; }
  .panel-foot a { color: var(--brand); font-weight: 600; text-decoration: none; }

  /* metric card (warn-colored) */
  .panel.metric { padding: 0; background: linear-gradient(180deg, #FFFAF2 0%, var(--bg) 60%); border-color: #C28200; }
  .metric-h { padding: 12px 16px; border-bottom: 1px solid var(--hair); display: flex; align-items: baseline; justify-content: space-between; }
  .metric-h .panel-title { color: #C28200; }
  .metric-grid { padding: 14px 16px 8px; display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; }
  .metric-cell { display: flex; flex-direction: column; gap: 4px; padding: 6px 0; }
  .metric-cell + .metric-cell { border-left: 1px solid var(--hair); padding-left: 12px; }
  .metric-num { font-size: 28px; font-weight: 600; color: var(--ink); letter-spacing: -1.5px; line-height: 1; font-variant-numeric: tabular-nums; }
  .metric-num.brand { color: var(--brand); }
  .metric-lbl { font-size: 11px; color: var(--ink-3); font-weight: 500; letter-spacing: -0.1px; }
  .metric-foot { padding: 8px 16px 12px; display: flex; align-items: center; justify-content: space-between; border-top: 1px solid var(--hair); }
  .metric-foot .timestamp { font-size: 10.5px; color: var(--ink-3); font-weight: 500; }
  .btn-detail { font-size: 12px; padding: 6px 14px; border: 1px solid var(--ink); color: var(--ink); font-weight: 600; cursor: pointer; transition: all 0.15s; text-decoration: none; }
  .btn-detail:hover { background: var(--ink); color: #fff; }

  .rt { width: 100%; font-size: 12px; font-variant-numeric: tabular-nums; }
  .rt th { text-align: left; padding: 5px 0; font-size: 10px; color: var(--ink-3); font-weight: 600; letter-spacing: 0.4px; text-transform: uppercase; border-bottom: 1px solid var(--hair); }
  .rt td { padding: 5px 0; font-weight: 500; color: var(--ink); border-bottom: 1px solid var(--hair); }
  .rt td:last-child { text-align: right; font-weight: 600; }
  .rt tr:last-child td { border-bottom: none; }
</style>

<script>
(function () {
  fetch('/api/system-config').then(r => r.json()).then(function (sc) {
    if (sc.serialNumber) document.getElementById('info-serial').innerHTML =
      sc.serialNumber + '<span class="ro">read-only</span>';
    if (sc.modelName || sc.modelNumber) document.getElementById('info-model').textContent = sc.modelName || sc.modelNumber;
    if (sc.firmwareVersion && sc.firmwareDate) document.getElementById('info-fw').innerHTML =
      sc.firmwareVersion + ' <em>(' + sc.firmwareDate + ')</em>';
    if (sc.installedAt) document.getElementById('info-install').textContent = sc.installedAt;
  });
  fetch('/api/boiler-info').then(r => r.json()).then(function (b) {
    if (b.serialNumber) document.getElementById('info-b-serial').innerHTML = b.serialNumber + '<span class="ro">read-only</span>';
    if (b.modelNumber) document.getElementById('info-b-model').textContent = b.modelNumber;
    if (b.firmwareVersion && b.firmwareDate) document.getElementById('info-b-fw').innerHTML =
      b.firmwareVersion + ' <em>(' + b.firmwareDate + ')</em>';
    // 회의 v1.3: waterPump / valve / tempMax 표시 제거 (불필요 / 탑바)
  });
  // 펌프 / 솔밸브 사용량 — usage-stats 에서
  fetch('/api/usage-stats').then(r => r.json()).then(function (us) {
    var labels = ['1번', '2번', '3번', '4번', '5번'];
    var keys = ['1st', '2nd', '3rd', '4th', '5th'];
    var pump = us.pumpUsage || {};
    var ext = us.extractCount || {};
    document.getElementById('info-pump-usage').innerHTML = keys.map(function (k, i) {
      return '<div style="display:flex;justify-content:space-between;padding:3px 0;">' +
        '<span style="color:var(--ink-3);">' + labels[i] + '</span>' +
        '<span style="font-weight:600;font-variant-numeric:tabular-nums;">' + (pump[k] || 0).toLocaleString() + ' 회</span>' +
      '</div>';
    }).join('');
    document.getElementById('info-valve-usage').innerHTML = keys.map(function (k, i) {
      return '<div style="display:flex;justify-content:space-between;padding:3px 0;">' +
        '<span style="color:var(--ink-3);">' + labels[i] + '</span>' +
        '<span style="font-weight:600;font-variant-numeric:tabular-nums;">' + (ext[k] || 0).toLocaleString() + ' 회</span>' +
      '</div>';
    }).join('');
  });
})();
</script>
