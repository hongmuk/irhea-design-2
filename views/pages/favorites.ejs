<!-- 즐겨찾기 (S7.1) — designs/02-favorites.html 정합. Topbar는 layout.ejs. -->

<!-- 즐겨찾기 — 회의 피드백 v1.2:
     • 추출구당 2 슬롯 → 5 슬롯
     • A/B 라벨 + 좌우 스왑 제거 (추출구별 고정 매핑)
     • 별표 아이콘 제거 (슬롯/카운트 모두 텍스트로만 표현)
     • 슬롯에 원두 무게·비율·추출량 정보 표시
     • "PORT-01" 라벨 제거 -->
<div class="sub-h">
  <div class="sub-h-l">
    <div class="sub-h-title">즐겨찾기 편집<em>추출구당 최대 5 슬롯</em></div>
  </div>
  <div class="sub-h-r">
    <button class="sh-btn ghost" id="fav-cancel" type="button">취소</button>
    <button class="sh-btn primary" id="fav-save">저장</button>
  </div>
</div>

<div class="fav-body">
  <!-- Left: 레시피 풀 + 등록 현황 -->
  <aside class="fav-col fav-left">
    <div class="col-h">
      <span>레시피 <b id="fav-total">--</b></span>
      <span>등록 <b id="fav-reg">--</b> · 미등록 <b id="fav-unreg">--</b></span>
    </div>
    <div id="fav-rail" class="fav-rail"></div>
  </aside>

  <!-- Right: 5 추출구 × 5 슬롯 -->
  <section class="fav-col">
    <div class="ports">
      <% for (let i = 1; i <= 5; i++) { %>
      <div class="port" data-spout="<%= i %>">
        <div class="port-h">추출구 <%= i %></div>
        <div class="port-body">
          <% for (let s = 0; s < 5; s++) { %>
          <div class="slot empty" data-slot="<%= s %>">
            <div class="slot-content">
              <div class="slot-recipe">비어 있음</div>
              <div class="slot-meta">탭하여 레시피 선택</div>
            </div>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>
  </section>
</div>

<!-- Info bar — 회의 피드백 따라 단순화 -->
<div class="fav-info-bar">
  <span>각 슬롯을 탭하면 레시피 선택 모달이 뜹니다. 비우려면 모달에서 [비우기] 선택.</span>
  <button class="fav-reset" id="fav-reset-all">↺ 전체 해제</button>
</div>

<style>
  /* favorites — designs/02-favorites.html 정합 */
  /* 10인치 — 터치 영역(min-h 36) 유지, 폰트는 합리적 */
  .sub-h { height: 48px; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--hair); flex-shrink: 0; gap: 16px; background: var(--bg); }
  .sub-h-l { display: inline-flex; align-items: baseline; gap: 14px; }
  .sub-h-title { font-size: 15px; font-weight: 700; color: var(--ink); letter-spacing: -0.2px; }
  .sub-h-title em { font-style: normal; color: var(--ink-3); font-weight: 500; margin-left: 8px; font-size: 12px; }
  .sub-h-pill { font-size: clamp(11.5px, 1vw + 7px, 14px); padding: 3px 9px; border: 1px solid var(--brand); color: var(--brand); font-weight: 700; letter-spacing: 0.3px; background: var(--brand-dim); }
  .sub-h-r { display: inline-flex; gap: 8px; }
  .sh-btn { font-size: 12.5px; padding: 8px 18px; font-weight: 700; cursor: pointer; line-height: 1; transition: all 0.15s; font-family: inherit; border: none; min-height: 36px; }
  .sh-btn.ghost { background: transparent; color: var(--ink-2); border: 1px solid var(--hair-2); }
  .sh-btn.ghost:hover { border-color: var(--ink); color: var(--ink); }
  .sh-btn.primary { background: var(--brand); color: #FFF; border: 1px solid var(--brand); }
  .sh-btn.primary:hover { background: #C8000F; border-color: #C8000F; }

  .fav-body { flex: 1; display: grid; grid-template-columns: 260px 1fr; min-height: 0; }
  @media (max-width: 900px) { .fav-body { grid-template-columns: 200px 1fr; } }
  .fav-col { display: flex; flex-direction: column; min-height: 0; }
  .fav-left { border-right: 1px solid var(--hair); }
  .col-h { padding: 10px 16px; font-size: 11px; color: var(--ink-3); font-weight: 700; letter-spacing: 0.6px; text-transform: uppercase; border-bottom: 1px solid var(--hair); display: flex; align-items: center; justify-content: space-between; }
  .col-h b { color: var(--ink); font-weight: 700; }
  .fav-rail { flex: 1; overflow-y: auto; }
  /* 빈 상태 */
  .rl-empty {
    display: flex; flex-direction: column; align-items: center; justify-content: center;
    padding: 36px 16px; gap: 6px; color: var(--ink-3);
    text-align: center;
  }
  .rl-empty-ico { font-size: 30px; opacity: 0.4; margin-bottom: 4px; }
  .rl-empty-msg { font-size: 13px; font-weight: 700; color: var(--ink-2); }
  .rl-empty-sub { font-size: 11.5px; color: var(--ink-3); }

  /* 리스트 행 — min-height 40 (터치), 폰트는 12.5 */
  .rl-i { display: flex; align-items: center; gap: 8px; padding: 10px 16px; border-bottom: 1px solid var(--hair); font-size: 12.5px; position: relative; cursor: pointer; min-height: 40px; }
  .rl-i:hover { background: #FAFAFA; }
  .rl-i.unset { color: var(--ink-3); }
  .rl-i.highlight { background: var(--brand-dim); }
  .rl-i.highlight::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--brand); }
  .rl-name { flex: 1; font-weight: 600; letter-spacing: -0.1px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
  .rl-i.highlight .rl-name { font-weight: 700; color: var(--ink); }
  .rl-count { font-size: 11px; font-weight: 700; color: var(--ink-3); font-variant-numeric: tabular-nums; letter-spacing: 0.2px; }
  .rl-count.is-registered { color: var(--brand); }

  .ports { padding: 16px 16px 12px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; flex: 1; min-height: 0; }
  @media (max-width: 1100px) { .ports { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 700px)  { .ports { grid-template-columns: repeat(2, 1fr); } }
  .port { display: flex; flex-direction: column; border: 1px solid var(--hair); background: var(--bg); overflow: hidden; min-height: 0; }
  /* 추출구 헤더 — inverted block 대신 카드 시스템과 통일: 화이트 + ink + 좌측 골드 hairline */
  .port-h { padding: 10px 12px 10px 16px; background: var(--bg); color: var(--ink); font-size: 12.5px; font-weight: 700; letter-spacing: -0.1px; text-align: left; border-bottom: 1px solid var(--hair); border-left: 4px solid var(--gold); }
  .port-body { flex: 1; padding: 6px; display: flex; flex-direction: column; gap: 4px; min-height: 0; overflow-y: auto; }

  /* 5 슬롯 컴팩트 (회의 피드백 v1.2: abc 라벨 제거, 별표 통일) */
  .slot {
    display: flex; align-items: center; gap: 7px;
    padding: 7px 8px;
    border: 1px solid var(--hair);
    background: var(--bg);
    cursor: pointer; transition: all 0.15s;
    min-height: 50px;
  }
  .slot:hover { border-color: var(--ink-2); background: #FAFAFA; }
  .slot.is-filled { border-color: var(--hair-2); background: #FFFDF7; }
  .slot.is-filled:hover { border-color: var(--brand); }
  .slot.empty {
    border-style: dashed;
    background: transparent;
    color: var(--ink-3);
  }
  .slot-content { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 1px; }
  /* 위계: 레시피명(검정 굵게) + 메타(회색 작게) */
  .slot-recipe {
    font-size: 12.5px; font-weight: 700; color: var(--ink); letter-spacing: -0.2px;
    line-height: 1.2;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .slot.empty .slot-recipe { color: var(--ink-3); font-weight: 500; font-style: italic; }
  .slot-meta {
    font-size: clamp(11.5px, 1vw + 7px, 14px); color: var(--ink-3); font-weight: 500; letter-spacing: -0.1px;
    font-variant-numeric: tabular-nums;
  }
  .slot.is-filled .slot-meta b { color: var(--ink); font-weight: 700; }

  .fav-info-bar { padding: 10px 24px; border-top: 1px solid var(--hair); background: #FCFCFC; display: flex; align-items: center; justify-content: space-between; font-size: 11.5px; color: var(--ink-3); flex-shrink: 0; gap: 16px; }
  .fav-info-bar b { color: var(--ink-2); font-weight: 600; }
  .fav-reset { color: var(--ink-2); border: 1px dashed var(--hair-2); padding: 5px 10px; font-size: 11px; cursor: pointer; font-weight: 500; background: transparent; font-family: inherit; }
  .fav-reset:hover { color: var(--brand); border-color: var(--brand); }
</style>

<script>
(function () {
  var recipes = [];
  var spouts = [];
  var FAV_SLOTS = 5;

  function render() {
    var fav = window.IRState.getFavorites(spouts);

    // Build mapping: recipeId -> 등록 카운트 (어느 슬롯이든 합산)
    var map = {};
    recipes.forEach(function (r) { map[r.id] = 0; });
    Object.keys(fav).forEach(function (sid) {
      var ids = fav[sid] || [];
      ids.forEach(function (rid) {
        if (rid != null && map[rid] != null) map[rid] += 1;
      });
    });

    // Left rail
    var rail = document.getElementById('fav-rail');
    var reg = 0, unreg = 0;
    var html;
    if (recipes.length === 0) {
      html = '<div class="rl-empty"><span class="rl-empty-ico">☕</span>' +
             '<span class="rl-empty-msg">레시피가 없습니다</span>' +
             '<span class="rl-empty-sub">먼저 <a href="/recipes" style="color:var(--brand);text-decoration:underline;">레시피</a>를 추가하세요</span></div>';
    } else {
      html = recipes.map(function (r) {
        var count = map[r.id] || 0;
        var registered = count > 0;
        if (registered) reg += 1; else unreg += 1;
        var countHtml = registered ? '×' + count : '미등록';
        var cls = 'rl-i' + (registered ? '' : ' unset');
        var countCls = 'rl-count' + (registered ? ' is-registered' : '');
        var displayName = r.name || ('레시피 ' + r.id);
        return '<div class="' + cls + '" data-rid="' + r.id + '" title="' + displayName.replace(/"/g, '&quot;') + '">' +
               '<span class="rl-name">' + displayName + '</span>' +
               '<span class="' + countCls + '">' + countHtml + '</span></div>';
      }).join('');
    }
    rail.innerHTML = html;
    document.getElementById('fav-total').textContent = recipes.length;
    document.getElementById('fav-reg').textContent = reg;
    document.getElementById('fav-unreg').textContent = unreg;

    // Slots — 추출구당 5개
    spouts.forEach(function (s) {
      var port = document.querySelector('.port[data-spout="' + s.id + '"]');
      if (!port) return;
      var ids = fav[s.id] || [];
      var slots = port.querySelectorAll('.slot');
      for (var idx = 0; idx < FAV_SLOTS; idx++) {
        var slot = slots[idx];
        if (!slot) continue;
        var rid = ids[idx];
        var r = rid != null ? recipes.find(function (x) { return x.id === rid; }) : null;
        var recipeEl = slot.querySelector('.slot-recipe');
        var metaEl = slot.querySelector('.slot-meta');
        slot.classList.remove('empty', 'is-filled');
        if (r) {
          slot.classList.add('is-filled');
          recipeEl.textContent = r.name || ('레시피 ' + r.id);
          // 회의 피드백: 원두 무게 · 비율 · 추출 전체 무게
          metaEl.innerHTML =
            '<b>' + (r.coffeeWeight || '--') + 'g</b> · ' +
            '<b>' + (r.ratio || '--') + '</b> · ' +
            '<b>' + (r.waterWeight || '--') + 'g</b>';
        } else {
          slot.classList.add('empty');
          recipeEl.textContent = '비어 있음';
          metaEl.textContent = '탭하여 레시피 선택';
        }
      }
    });
  }

  function bindSlotClicks() {
    document.querySelectorAll('.slot').forEach(function (sl) {
      sl.addEventListener('click', function () {
        var port = sl.closest('.port');
        var spoutId = parseInt(port.dataset.spout, 10);
        var slotIdx = parseInt(sl.dataset.slot, 10);
        var slotLabel = String(slotIdx + 1);
        var fav = window.IRState.getFavorites(spouts);
        var currentId = (fav[spoutId] || [])[slotIdx];
        window.IRRecipePicker.open({
          title: '추출구 ' + spoutId + ' · 슬롯 ' + slotLabel + ' 레시피 선택',
          selectedId: currentId,
          allowClear: true,
          onPick: function (rid) {
            window.IRState.setFavorite(spoutId, slotIdx, rid);
            window.IRToast?.show('추출구 ' + spoutId + ' · 슬롯 ' + slotLabel + (rid != null ? ' = 레시피 ' + rid : ' 비움'));
            render();
          }
        });
      });
    });
  }

  // bindSwaps 제거 — 회의 피드백 v1.2: A↔B 스왑 개념 폐기 (추출구별 고정 매핑)

  // 회의 피드백 v1.2: 변경 사항 있을 때 무조건 confirm
  var initialSnapshot = null;
  function snapshot() {
    return JSON.stringify(window.IRState.getFavorites(spouts));
  }
  function isDirty() {
    return initialSnapshot && snapshot() !== initialSnapshot;
  }

  Promise.all([
    fetch('/api/spouts').then(r => r.json()),
    fetch('/api/recipes').then(r => r.json())
  ]).then(function ([sp, rcps]) {
    spouts = sp;
    recipes = window.IRState.applyOverlay(rcps);
    render();
    bindSlotClicks();
    initialSnapshot = snapshot();
  });

  document.getElementById('fav-save').onclick = function () {
    if (!isDirty()) {
      window.IRToast?.show('변경 사항이 없습니다.');
      return;
    }
    // 회의 피드백: 저장 시 무조건 confirm
    window.IRModal.confirm({
      title: '즐겨찾기 저장',
      body: '변경된 즐겨찾기 매핑을 저장합니다.<br>장비에도 적용됩니다.',
      ok: '저장',
      onOk: function () {
        initialSnapshot = snapshot();
        window.IRToast?.show('즐겨찾기 매핑이 저장되었습니다.');
      }
    });
  };

  // 회의 피드백: 취소(이전) 시 변경 있으면 confirm
  document.getElementById('fav-cancel').addEventListener('click', function () {
    if (isDirty()) {
      window.IRModal.confirm({
        title: '저장하지 않은 변경 사항',
        body: '저장하지 않은 변경 사항이 있습니다.<br>이전 화면으로 돌아가시겠습니까?',
        bodyClass: 'is-error',
        ok: '돌아가기',
        cancel: '계속 편집',
        onOk: function () { history.back(); }
      });
    } else {
      history.back();
    }
  });
  document.getElementById('fav-reset-all').onclick = function () {
    window.IRModal?.confirm({
      title: '전체 해제',
      bodyClass: 'is-error',
      body: '모든 추출구의 즐겨찾기를 해제하시겠습니까?',
      ok: '해제',
      onOk: function () {
        window.IRState.clearAllFavorites();
        // Re-seed empty mapping so render() shows all slots empty
        spouts.forEach(function (s) { window.IRState.setFavorite(s.id, 0, null); window.IRState.setFavorite(s.id, 1, null); });
        render();
        window.IRToast?.show('전체 즐겨찾기 해제');
      }
    });
  };
})();
</script>
