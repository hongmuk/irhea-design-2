<!-- 즐겨찾기 (S7.1) — designs/02-favorites.html 정합. Topbar는 layout.ejs. -->

<div class="sub-h">
  <div class="sub-h-l">
    <div class="sub-h-title">즐겨찾기 편집<em>S7.1 · 5 추출구 × 2 슬롯 = 10 슬롯</em></div>
    <span class="sub-h-pill">v1.1 — 추출구당 2 슬롯</span>
  </div>
  <div class="sub-h-r">
    <button class="sh-btn ghost" onclick="history.back()">취소</button>
    <button class="sh-btn primary" id="fav-save">저장</button>
  </div>
</div>

<div class="fav-body">
  <!-- Left: 12 recipes with registration count -->
  <aside class="fav-col fav-left">
    <div class="col-h">
      <span>레시피 <b id="fav-total">--</b></span>
      <span>등록 <b id="fav-reg">--</b> · 미등록 <b id="fav-unreg">--</b></span>
    </div>
    <div id="fav-rail" class="fav-rail"></div>
  </aside>

  <!-- Right: 5 ports × 2 slots -->
  <section class="fav-col">
    <div class="ports">
      <% for (let i = 1; i <= 5; i++) { %>
      <div class="port" data-spout="<%= i %>">
        <div class="port-h">추출구 <%= i %> <span class="port-id">PORT-0<%= i %></span></div>
        <div class="port-body">
          <div class="slot a" data-slot="A">
            <div class="slot-h"><span>★ 슬롯 A</span><span class="slot-action">1초 = 추출</span></div>
            <div class="slot-recipe">—</div>
            <div class="slot-meta">—</div>
          </div>
          <div class="slot-swap" title="A ↔ B 스왑">↑↓ A ↔ B</div>
          <div class="slot b" data-slot="B">
            <div class="slot-h"><span>☆ 슬롯 B</span><span class="slot-action">탭 전환</span></div>
            <div class="slot-recipe">—</div>
            <div class="slot-meta">—</div>
          </div>
        </div>
      </div>
      <% } %>
    </div>
  </section>
</div>

<!-- Info bar -->
<div class="fav-info-bar">
  <span><span class="star">★</span> = <b>1초 클릭 추출</b> · ☆ = <b>탭 전환</b> · 빈 슬롯 = 탭 → 12 레시피 모달 · 매뉴얼 큐와 별개</span>
  <button class="fav-reset" id="fav-reset-all">↺ 전체 해제</button>
</div>

<style>
  /* favorites — designs/02-favorites.html 정합 */
  .sub-h { height: 52px; padding: 0 24px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--hair); flex-shrink: 0; gap: 16px; background: var(--bg); }
  .sub-h-l { display: inline-flex; align-items: baseline; gap: 14px; }
  .sub-h-title { font-size: 14px; font-weight: 600; color: var(--ink); letter-spacing: -0.2px; }
  .sub-h-title em { font-style: normal; color: var(--ink-3); font-weight: 500; margin-left: 8px; font-size: 12px; }
  .sub-h-pill { font-size: 10.5px; padding: 3px 9px; border: 1px solid var(--brand); color: var(--brand); font-weight: 600; letter-spacing: 0.3px; background: var(--brand-dim); }
  .sub-h-r { display: inline-flex; gap: 8px; }
  .sh-btn { font-size: 12px; padding: 8px 16px; font-weight: 600; cursor: pointer; line-height: 1; transition: all 0.15s; font-family: inherit; border: none; }
  .sh-btn.ghost { background: transparent; color: var(--ink-2); border: 1px solid var(--hair-2); }
  .sh-btn.ghost:hover { border-color: var(--ink); color: var(--ink); }
  .sh-btn.primary { background: var(--brand); color: #FFF; border: 1px solid var(--brand); }
  .sh-btn.primary:hover { background: #C8000F; border-color: #C8000F; }

  .fav-body { flex: 1; display: grid; grid-template-columns: 260px 1fr; min-height: 0; }
  .fav-col { display: flex; flex-direction: column; min-height: 0; }
  .fav-left { border-right: 1px solid var(--hair); }
  .col-h { padding: 10px 16px; font-size: 11px; color: var(--ink-3); font-weight: 600; letter-spacing: 0.6px; text-transform: uppercase; border-bottom: 1px solid var(--hair); display: flex; align-items: center; justify-content: space-between; }
  .col-h b { color: var(--ink); font-weight: 600; }
  .fav-rail { flex: 1; overflow-y: auto; }
  .rl-i { display: flex; align-items: center; gap: 8px; padding: 10px 16px; border-bottom: 1px solid var(--hair); font-size: 12.5px; position: relative; cursor: pointer; }
  .rl-i:hover { background: #FAFAFA; }
  .rl-i.unset { color: var(--ink-3); }
  .rl-i.highlight { background: var(--brand-dim); }
  .rl-i.highlight::before { content: ''; position: absolute; left: 0; top: 0; bottom: 0; width: 2px; background: var(--brand); }
  .rl-name { flex: 1; font-weight: 500; letter-spacing: -0.1px; }
  .rl-i.highlight .rl-name { font-weight: 600; color: var(--ink); }
  .rl-count { font-size: 11px; font-weight: 600; color: var(--ink-3); font-variant-numeric: tabular-nums; letter-spacing: 0.2px; }
  .rl-count .star { color: var(--brand); }
  .rl-count .moon { color: var(--ink-2); }

  .ports { padding: 18px 18px 14px; display: grid; grid-template-columns: repeat(5, 1fr); gap: 12px; flex: 1; min-height: 0; }
  .port { display: flex; flex-direction: column; border: 1px solid var(--hair); background: var(--bg); overflow: hidden; min-height: 0; }
  .port-h { padding: 8px 12px; background: var(--ink); color: #FFF; font-size: 12px; font-weight: 600; letter-spacing: -0.1px; display: flex; align-items: center; justify-content: space-between; }
  .port-h .port-id { font-size: 10px; opacity: 0.5; font-weight: 500; letter-spacing: 0.5px; }
  .port-body { flex: 1; padding: 10px; display: flex; flex-direction: column; gap: 8px; }

  .slot { padding: 10px 11px; border: 1px solid var(--hair); display: flex; flex-direction: column; gap: 4px; cursor: pointer; transition: all 0.15s; }
  .slot:hover { border-color: var(--ink-3); }
  .slot.a { border: 2px solid var(--brand); background: linear-gradient(180deg, #FFFAFA 0%, var(--bg) 100%); }
  .slot.b { border: 1px solid var(--hair-2); background: #FAFAFA; }
  .slot.empty { border-style: dashed; background: transparent; color: var(--ink-3); align-items: center; justify-content: center; min-height: 60px; }
  .slot-h { display: flex; align-items: baseline; justify-content: space-between; font-size: 10.5px; letter-spacing: 0.4px; font-weight: 600; }
  .slot.a .slot-h { color: var(--brand); }
  .slot.b .slot-h { color: var(--ink-3); }
  .slot-action { font-size: 8.5px; opacity: 0.7; }
  .slot-recipe { font-size: 13px; font-weight: 600; color: var(--ink); letter-spacing: -0.2px; line-height: 1.2; }
  .slot.b .slot-recipe { font-weight: 600; color: var(--ink-2); }
  .slot-meta { font-size: 10px; color: var(--ink-3); font-weight: 500; letter-spacing: -0.1px; }
  .slot-swap { display: flex; align-items: center; justify-content: center; font-size: 10px; color: var(--ink-3); padding: 1px 0; cursor: pointer; letter-spacing: 0.5px; }
  .slot-swap:hover { color: var(--brand); }

  .fav-info-bar { padding: 10px 24px; border-top: 1px solid var(--hair); background: #FCFCFC; display: flex; align-items: center; justify-content: space-between; font-size: 11.5px; color: var(--ink-3); flex-shrink: 0; gap: 16px; }
  .fav-info-bar b { color: var(--ink-2); font-weight: 600; }
  .fav-info-bar .star { color: var(--brand); font-weight: 700; }
  .fav-reset { color: var(--ink-2); border: 1px dashed var(--hair-2); padding: 5px 10px; font-size: 11px; cursor: pointer; font-weight: 500; background: transparent; font-family: inherit; }
  .fav-reset:hover { color: var(--brand); border-color: var(--brand); }
</style>

<script>
(function () {
  var recipes = [];
  var spouts = [];

  function render() {
    var fav = window.IRState.getFavorites(spouts);

    // Build mapping: recipeId -> { a, b }
    var map = {};
    recipes.forEach(function (r) { map[r.id] = { a: 0, b: 0 }; });
    Object.keys(fav).forEach(function (sid) {
      var ids = fav[sid] || [];
      if (ids[0] != null && map[ids[0]]) map[ids[0]].a += 1;
      if (ids[1] != null && map[ids[1]]) map[ids[1]].b += 1;
    });

    // Left rail
    var rail = document.getElementById('fav-rail');
    var reg = 0, unreg = 0;
    var html = recipes.map(function (r) {
      var m = map[r.id] || { a: 0, b: 0 };
      var registered = (m.a + m.b) > 0;
      if (registered) reg += 1; else unreg += 1;
      var countParts = [];
      if (m.a) countParts.push('<span class="star">★</span> ×' + m.a);
      if (m.b) countParts.push('<span class="moon">☆</span> ×' + m.b);
      var countHtml = registered ? countParts.join(' ') : '미등록';
      var cls = 'rl-i' + (registered ? '' : ' unset');
      return '<div class="' + cls + '" data-rid="' + r.id + '">' +
             '<span class="rl-name">레시피 ' + r.id + '</span>' +
             '<span class="rl-count">' + countHtml + '</span></div>';
    }).join('');
    rail.innerHTML = html;
    document.getElementById('fav-total').textContent = recipes.length;
    document.getElementById('fav-reg').textContent = reg;
    document.getElementById('fav-unreg').textContent = unreg;

    // Slots
    spouts.forEach(function (s) {
      var port = document.querySelector('.port[data-spout="' + s.id + '"]');
      if (!port) return;
      var ids = fav[s.id] || [];
      var slots = port.querySelectorAll('.slot');
      [0, 1].forEach(function (idx) {
        var slot = slots[idx];
        var rid = ids[idx];
        var r = rid != null ? recipes.find(x => x.id === rid) : null;
        if (!slot) return;
        slot.classList.remove('empty');
        if (r) {
          slot.querySelector('.slot-recipe').textContent = '레시피 ' + r.id;
          slot.querySelector('.slot-meta').textContent =
            '원두 ' + r.id + ' · ' + (r.ratio || '--');
        } else {
          slot.classList.add('empty');
          slot.querySelector('.slot-recipe').textContent = '비어 있음';
          slot.querySelector('.slot-meta').textContent = '탭하여 레시피 선택';
        }
      });
    });
  }

  function bindSlotClicks() {
    document.querySelectorAll('.slot').forEach(function (sl) {
      sl.addEventListener('click', function () {
        var port = sl.closest('.port');
        var spoutId = parseInt(port.dataset.spout, 10);
        var slotLabel = sl.dataset.slot;
        var slotIdx = slotLabel === 'A' ? 0 : 1;
        var fav = window.IRState.getFavorites(spouts);
        var currentId = (fav[spoutId] || [])[slotIdx];
        window.IRRecipePicker.open({
          title: '추출구 ' + spoutId + ' · 슬롯 ' + slotLabel + ' 레시피 선택',
          selectedId: currentId,
          allowClear: true,
          onPick: function (rid) {
            window.IRState.setFavorite(spoutId, slotIdx, rid);
            window.IRToast?.show('추출구 ' + spoutId + ' · 슬롯 ' + slotLabel + (rid != null ? ' = 레시피 ' + rid : ' 비움'));
            render();
          }
        });
      });
    });
  }

  function bindSwaps() {
    document.querySelectorAll('.slot-swap').forEach(function (sw) {
      sw.addEventListener('click', function () {
        var port = sw.closest('.port');
        var spoutId = parseInt(port.dataset.spout, 10);
        window.IRState.swapFavorites(spoutId);
        window.IRToast?.show('추출구 ' + spoutId + ' · A ↔ B 스왑');
        render();
      });
    });
  }

  Promise.all([
    fetch('/api/spouts').then(r => r.json()),
    fetch('/api/recipes').then(r => r.json())
  ]).then(function ([sp, rcps]) {
    spouts = sp;
    recipes = window.IRState.applyOverlay(rcps);
    render();
    bindSlotClicks();
    bindSwaps();
  });

  document.getElementById('fav-save').onclick = function () {
    window.IRToast?.show('즐겨찾기 매핑이 저장되었습니다.');
  };
  document.getElementById('fav-reset-all').onclick = function () {
    window.IRModal?.confirm({
      title: '전체 해제',
      bodyClass: 'is-error',
      body: '모든 추출구의 즐겨찾기를 해제하시겠습니까?',
      onOk: function () {
        window.IRState.clearAllFavorites();
        // Re-seed empty mapping so render() shows all slots empty
        spouts.forEach(function (s) { window.IRState.setFavorite(s.id, 0, null); window.IRState.setFavorite(s.id, 1, null); });
        render();
        window.IRToast?.show('전체 즐겨찾기 해제');
      }
    });
  };
})();
</script>
