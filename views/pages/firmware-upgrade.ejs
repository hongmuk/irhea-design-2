<%- include('../partials/settings-shell', { activeTab: 'firmware' }) %>

  <!-- 회의 피드백 v1.2:
       • 설치 방식 (자동/수동)을 먼저 → 자동일 때만 정책 노출
       • 보드별 진행 표시 (WHP, MCP, 백 프론트, …) — 설치 프로그램 스타일
       • 업그레이드 소스 (USB / AWS) 명시
  -->
  <section class="ir-grow ir-center" style="min-height:420px;">
    <div class="ir-card" style="max-width:620px;width:100%;padding:24px 28px;">

      <div style="text-align:center;font-size:18px;font-weight:800;margin-bottom:18px;">펌웨어 업그레이드</div>

      <!-- 버전 -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:18px;font-size:14px;text-align:center;margin-bottom:18px;">
        <div>
          <div style="color:var(--ir-fg-muted);font-size:12px;letter-spacing:0.05em;">현재 버전</div>
          <div id="fw-current" style="font-size:22px;font-weight:800;font-family:var(--ir-font-mono);">v1.0</div>
        </div>
        <div>
          <div style="color:var(--ir-fg-muted);font-size:12px;letter-spacing:0.05em;">최신 버전</div>
          <div id="fw-latest" style="font-size:22px;font-weight:800;font-family:var(--ir-font-mono);">—</div>
        </div>
      </div>

      <!-- 모듈 선택 (v1.1 S5.1.4 — "전체 또는 선택") + 보드별 진행 -->
      <div class="fw-module-select">
        <div style="font-size:13px;font-weight:700;color:var(--ir-fg-muted);margin-bottom:8px;">업그레이드 대상 (다중 선택)</div>
        <div class="fw-modules">
          <label class="fw-mod"><input type="checkbox" data-mod="WHP" checked><span class="fw-mod-mk">✓</span><span>WHP <em>(워터 히터 펌프)</em></span></label>
          <label class="fw-mod"><input type="checkbox" data-mod="MCP" checked><span class="fw-mod-mk">✓</span><span>MCP <em>(메인 컴 · 클라우드)</em></span></label>
          <label class="fw-mod"><input type="checkbox" data-mod="5000" checked><span class="fw-mod-mk">✓</span><span>5천원 <em>(서브 보드)</em></span></label>
          <label class="fw-mod"><input type="checkbox" data-mod="FRONT" checked><span class="fw-mod-mk">✓</span><span>백 프론트 <em>(LED + 버튼)</em></span></label>
        </div>
      </div>

      <!-- 보드별 진행 — 회의 v1.3: WHP / MCP / 5천원 / 백 프론트 (4종) -->
      <div class="fw-boards" id="fw-boards" style="display:none;">
        <div class="fw-board" data-board="WHP">
          <span class="fw-board-name">WHP <em>(워터 히터 펌프)</em></span>
          <span class="fw-board-bar"><span class="fw-board-fill"></span></span>
          <span class="fw-board-status">대기</span>
        </div>
        <div class="fw-board" data-board="MCP">
          <span class="fw-board-name">MCP <em>(메인 컴 · 클라우드)</em></span>
          <span class="fw-board-bar"><span class="fw-board-fill"></span></span>
          <span class="fw-board-status">대기</span>
        </div>
        <div class="fw-board" data-board="5000">
          <span class="fw-board-name">5천원 <em>(서브 보드)</em></span>
          <span class="fw-board-bar"><span class="fw-board-fill"></span></span>
          <span class="fw-board-status">대기</span>
        </div>
        <div class="fw-board" data-board="FRONT">
          <span class="fw-board-name">백 프론트 <em>(LED + 버튼 보드)</em></span>
          <span class="fw-board-bar"><span class="fw-board-fill"></span></span>
          <span class="fw-board-status">대기</span>
        </div>
      </div>

      <!-- Actions -->
      <div style="display:flex;justify-content:center;gap:14px;margin:18px 0 24px;">
        <button class="ir-btn" id="fw-check">버전 체크</button>
        <button class="ir-btn ir-btn-primary" id="fw-upgrade" disabled style="opacity:0.55;">업그레이드</button>
      </div>

      <hr style="border:none;border-top:1px solid var(--ir-line-soft);margin:18px 0;"/>

      <!-- 설치 방식 먼저 (자동/수동) -->
      <div style="font-size:13px;font-weight:700;color:var(--ir-fg-muted);margin-bottom:8px;">설치 방식</div>
      <div style="display:flex;gap:8px;margin-bottom:14px;">
        <span class="ir-toggle-opt is-active" data-mode="manual" style="border:1.5px solid var(--ir-line-strong);">수동</span>
        <span class="ir-toggle-opt" data-mode="auto" style="border:1.5px solid var(--ir-line-strong);">자동</span>
      </div>

      <!-- 업그레이드 소스 -->
      <div style="font-size:13px;font-weight:700;color:var(--ir-fg-muted);margin-bottom:8px;">업그레이드 소스</div>
      <div style="display:flex;gap:8px;margin-bottom:14px;">
        <span class="ir-toggle-opt is-active" data-src="usb" style="border:1.5px solid var(--ir-line-strong);">USB</span>
        <span class="ir-toggle-opt" data-src="aws" style="border:1.5px solid var(--ir-line-strong);">AWS (클라우드)</span>
      </div>

      <!-- 정책 — 자동일 때만 표시. 회의 §12.3 / 명세 v0.9: "항상 체크 / 한번만 / 절대 안함" -->
      <div id="fw-policy-wrap" style="display:none;">
        <div style="font-size:13px;font-weight:700;color:var(--ir-fg-muted);margin-bottom:8px;">자동 체크 정책</div>
        <div style="display:flex;gap:8px;">
          <span class="ir-toggle-opt is-active" data-policy="always" style="border:1.5px solid var(--ir-line-strong);">항상 체크</span>
          <span class="ir-toggle-opt"            data-policy="once"   style="border:1.5px solid var(--ir-line-strong);">한번만</span>
          <span class="ir-toggle-opt"            data-policy="never"  style="border:1.5px solid var(--ir-line-strong);">절대 안함</span>
        </div>
      </div>

    </div>
  </section>

  <style>
    /* 보드별 진행 표시 (설치 프로그램 스타일) */
    .fw-boards { display: flex; flex-direction: column; gap: 8px; padding: 14px; border: 1px solid var(--ir-line); background: var(--ir-bg-2); margin-bottom: 6px; }
    .fw-board { display: grid; grid-template-columns: 160px 1fr 70px; align-items: center; gap: 12px; font-size: 12px; }
    .fw-board-name { font-weight: 700; color: var(--ir-fg); }
    .fw-board-name em { color: var(--ir-fg-muted); font-weight: 500; font-style: normal; font-size: 10px; margin-left: 4px; }
    .fw-board-bar { height: 10px; background: var(--ir-bg-3); border: 1px solid var(--ir-line); position: relative; overflow: hidden; }
    .fw-board-fill { position: absolute; left: 0; top: 0; bottom: 0; background: var(--ir-orange); width: 0%; transition: width 0.2s; }
    .fw-board[data-state="done"] .fw-board-fill { background: var(--ir-status-ok, #15803D); }
    .fw-board-status { font-size: 11px; font-weight: 700; color: var(--ir-fg-muted); text-align: right; font-variant-numeric: tabular-nums; }
    .fw-board[data-state="active"] .fw-board-status { color: var(--ir-orange-deep); }
    .fw-board[data-state="done"] .fw-board-status { color: var(--ir-status-ok, #15803D); }
    .fw-board.is-skipped { opacity: 0.4; }
    .fw-board.is-skipped .fw-board-status { color: var(--ir-fg-muted); }

    /* 모듈 선택 (v1.1 S5.1.4) */
    .fw-module-select { padding: 14px 16px 12px; border: 1px solid var(--ir-line); background: var(--ir-bg-2); margin-bottom: 12px; }
    .fw-modules { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    .fw-mod { display: flex; align-items: center; gap: 8px; padding: 8px 12px; border: 1px solid var(--ir-line); cursor: pointer; font-size: 12.5px; }
    .fw-mod:has(input:checked) { border-color: var(--ir-orange); background: rgba(197,160,89,0.04); }
    .fw-mod input { display: none; }
    .fw-mod-mk { width: 16px; height: 16px; border: 2px solid var(--ir-line-strong); display: inline-flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 800; color: #fff; flex-shrink: 0; }
    .fw-mod:has(input:checked) .fw-mod-mk { background: var(--ir-orange); border-color: var(--ir-orange); }
    .fw-mod:not(:has(input:checked)) .fw-mod-mk { color: transparent; }
    .fw-mod em { color: var(--ir-fg-muted); font-style: normal; font-weight: 400; margin-left: 4px; font-size: 10.5px; }
  </style>

<%- include('../partials/settings-shell-close') %>

<script>
(function () {
  var policy = 'always';
  var mode = 'manual';
  var src = 'usb';

  // 회의 피드백: 설치 방식 = 자동일 때만 정책 노출
  function updatePolicyVisibility() {
    document.getElementById('fw-policy-wrap').style.display = mode === 'auto' ? 'block' : 'none';
  }
  document.querySelectorAll('[data-policy]').forEach(function (el) {
    el.addEventListener('click', function () {
      document.querySelectorAll('[data-policy]').forEach(function (x) { x.classList.remove('is-active'); });
      el.classList.add('is-active');
      policy = el.dataset.policy;
    });
  });
  document.querySelectorAll('[data-mode]').forEach(function (el) {
    el.addEventListener('click', function () {
      document.querySelectorAll('[data-mode]').forEach(function (x) { x.classList.remove('is-active'); });
      el.classList.add('is-active');
      mode = el.dataset.mode;
      updatePolicyVisibility();
    });
  });
  document.querySelectorAll('[data-src]').forEach(function (el) {
    el.addEventListener('click', function () {
      document.querySelectorAll('[data-src]').forEach(function (x) { x.classList.remove('is-active'); });
      el.classList.add('is-active');
      src = el.dataset.src;
    });
  });

  document.getElementById('fw-check').addEventListener('click', function () {
    // 회의 피드백: USB 모드면 USB 확인 / AWS 모드면 AWS 확인
    if (src === 'usb') {
      // mock: assume USB present
    }
    var btn = document.getElementById('fw-upgrade');
    btn.disabled = true;
    btn.style.opacity = '0.55';
    fetch('/api/firmware/check', { method: 'POST' })
      .then(function (r) { return r.json(); })
      .then(function (j) {
        document.getElementById('fw-current').textContent = 'v' + j.current;
        document.getElementById('fw-latest').textContent  = 'v' + j.latest;
        if (j.updateAvailable) {
          btn.disabled = false;
          btn.style.opacity = '1';
        }
      });
  });

  // 보드별 진행 시뮬레이션 (회의 피드백: 단순 % 대신 각 보드 따로)
  function runBoardUpgrade(boardEl, durationMs) {
    return new Promise(function (resolve) {
      boardEl.dataset.state = 'active';
      var fill = boardEl.querySelector('.fw-board-fill');
      var status = boardEl.querySelector('.fw-board-status');
      var start = Date.now();
      var iv = setInterval(function () {
        var p = Math.min(100, (Date.now() - start) / durationMs * 100);
        fill.style.width = p.toFixed(0) + '%';
        status.textContent = p.toFixed(0) + '%';
        if (p >= 100) {
          clearInterval(iv);
          boardEl.dataset.state = 'done';
          status.textContent = '✓ 완료';
          resolve();
        }
      }, 60);
    });
  }

  document.getElementById('fw-upgrade').addEventListener('click', function () {
    // v1.1 S5.1.4: 선택된 모듈만 업그레이드
    var selected = Array.from(document.querySelectorAll('.fw-mod input:checked')).map(function (i) { return i.dataset.mod; });
    if (selected.length === 0) {
      window.IRModal.info({ body: '업그레이드할 모듈을 1개 이상 선택해 주세요.', bodyClass: 'is-error' });
      return;
    }
    window.IRModal.confirm({
      title: '펌웨어 업그레이드',
      body: '선택한 ' + selected.length + '개 모듈을 업그레이드 합니다.<br>업그레이드 중 전원을 끄지 마세요.',
      ok: '진행',
      onOk: function () {
        var boardsWrap = document.getElementById('fw-boards');
        boardsWrap.style.display = 'flex';
        var boards = Array.from(boardsWrap.querySelectorAll('.fw-board'));
        // 선택 안 된 보드는 skipped 표시
        boards.forEach(function (b) {
          if (selected.indexOf(b.dataset.board) < 0) {
            b.classList.add('is-skipped');
            b.querySelector('.fw-board-status').textContent = '건너뜀';
          }
        });
        var targets = boards.filter(function (b) { return selected.indexOf(b.dataset.board) >= 0; });
        var durations = [1800, 1400, 1100, 900];
        // 순차 업그레이드
        var p = Promise.resolve();
        targets.forEach(function (b, i) {
          p = p.then(function () { return runBoardUpgrade(b, durations[i] || 1000); });
        });
        p
          // 회의 피드백 v1.2: 통신 실패 시 IRError 자동
          .then(function () { return (window.IRFetch || fetch)('/api/firmware/upgrade', { method: 'POST' }); })
          .then(function () {
            window.IRModal.info({ body: '펌웨어 업그레이드 완료' });
          }).catch(function () {});
      }
    });
  });
})();
</script>
