<%- include('../partials/settings-shell', { activeTab: 'engineering' }) %>

  <div class="ir-row" style="gap:24px;flex:1;align-items:flex-start;">

    <aside class="ir-side-menu">
      <a class="ir-tab is-active" href="/settings/engineering/factory-reset">공장초기화</a>
      <a class="ir-tab" href="/settings/engineering/connection">장비 연결 설정</a>
    </aside>

    <section class="ir-grow ir-center" style="min-height:420px;">
      <div class="ir-card" style="max-width:520px;width:100%;padding:28px 32px;">
        <div style="text-align:center;font-family:var(--ir-font-display);font-style:italic;font-size:22px;margin-bottom:24px;color:var(--ir-fg);">공장 <em style="color:var(--ir-orange-deep);">초기화.</em></div>

        <div id="fr-list" style="display:flex;flex-direction:column;gap:14px;font-size:16px;font-weight:600;">
          <% var __cats = [
            { id: 'log',     label: '1. 로그 & 오류 데이터', sel: true },
            { id: 'recipe',  label: '2. 레시피 데이터',     sel: false },
            { id: 'user',    label: '3. 사용자 데이터',     sel: true },
            { id: 'device',  label: '4. 장비 설정 데이터',  sel: false },
            { id: 'security',label: '5. 보안 데이터',       sel: true }
          ]; %>
          <% __cats.forEach(function (c) { %>
            <label class="fr-row" data-cat="<%= c.id %>" style="display:flex;align-items:center;gap:18px;cursor:pointer;">
              <span style="flex:1;"><%= c.label %></span>
              <span class="fr-dot" data-on="<%= c.sel %>" style="width:18px;height:18px;border-radius:50%;border:1.5px solid var(--ir-line-strong);background:<%= c.sel ? 'var(--ir-status-ok)' : 'transparent' %>;"></span>
            </label>
          <% }) %>
        </div>

        <div style="display:flex;align-items:center;justify-content:space-between;margin-top:24px;gap:12px;">
          <button class="ir-btn ir-btn-primary" id="fr-run">실행</button>
          <div class="ir-progress-ring" id="fr-progress" style="display:none;">20%</div>
          <button class="ir-btn" id="fr-cancel">취소</button>
        </div>
      </div>
    </section>

  </div>

<%- include('../partials/settings-shell-close') %>

<script>
(function () {
  if (location.search.indexOf('dev=1') >= 0) sessionStorage.setItem('ir-admin-ok', '1');
  if (sessionStorage.getItem('ir-admin-ok') !== '1') {
    window.location.href = '/settings/engineering';
    return;
  }

  // Toggle dot rows
  document.querySelectorAll('.fr-row').forEach(function (row) {
    row.addEventListener('click', function () {
      var dot = row.querySelector('.fr-dot');
      var on = dot.dataset.on === 'true';
      dot.dataset.on = (!on).toString();
      dot.style.background = !on ? 'var(--ir-status-ok)' : 'transparent';
    });
  });

  document.getElementById('fr-cancel').addEventListener('click', function () {
    window.location.href = '/settings/engineering';
  });

  document.getElementById('fr-run').addEventListener('click', function () {
    var cats = [];
    document.querySelectorAll('.fr-row').forEach(function (row) {
      if (row.querySelector('.fr-dot').dataset.on === 'true') cats.push(row.dataset.cat);
    });
    if (cats.length === 0) {
      window.IRModal.info({ body: '항목을 선택하세요', bodyClass: 'is-error' });
      return;
    }
    window.IRModal.confirm({
      body: '복구불가<br>진행하시겠습니까?',
      bodyClass: 'is-error',
      onOk: function () {
        var ring = document.getElementById('fr-progress');
        ring.style.display = 'inline-flex';
        ring.textContent = '0%';
        var p = 0;
        var iv = setInterval(function () {
          p += 8;
          ring.textContent = Math.min(p, 100) + '%';
          if (p >= 100) {
            clearInterval(iv);
            fetch('/api/factory-reset', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ categories: cats })
            }).then(function () {
              window.IRModal.info({ body: '초기화 완료' });
              ring.style.display = 'none';
            });
          }
        }, 120);
      }
    });
  });
})();
</script>
