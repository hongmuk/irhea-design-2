<div class="ir-toast-container" id="ir-toast-container"></div>

<style>
  .ir-toast-container {
    position: fixed;
    left: 50%;
    bottom: 96px;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
    pointer-events: none;
    z-index: 1100;
  }
  .ir-toast {
    pointer-events: auto;
    background: var(--ink, #111);
    color: #fff;
    font-size: 13px;
    font-weight: 600;
    padding: 12px 18px;
    border-radius: 4px;
    box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 160ms, transform 160ms;
    max-width: 480px;
    letter-spacing: 0.01em;
  }
  .ir-toast.is-show { opacity: 1; transform: translateY(0); }
  .ir-toast.is-warn { background: var(--gold, #C5A059); color: #fff; }
  .ir-toast.is-error { background: var(--brand, #E60012); color: #fff; }
</style>

<script>
(function () {
  function show(msg, opts) {
    opts = opts || {};
    var container = document.getElementById('ir-toast-container');
    if (!container) return;
    var t = document.createElement('div');
    t.className = 'ir-toast' + (opts.type ? ' is-' + opts.type : '');
    t.textContent = msg;
    container.appendChild(t);
    requestAnimationFrame(function () { t.classList.add('is-show'); });
    setTimeout(function () {
      t.classList.remove('is-show');
      setTimeout(function () { t.remove(); }, 220);
    }, opts.duration || 2200);
  }
  window.IRToast = { show: show };
})();
</script>
