<%# Settings shell — 4 top tabs + orange divider + 저장/복귀 row.
   Usage: include this partial then content then settings-shell-close.
   Active tab keys: 'general' | 'backup' | 'engineering' | 'firmware' %>
<% var __activeTab = (typeof activeTab !== 'undefined') ? activeTab : 'general'; %>
<% var __showSave  = (typeof showSave  !== 'undefined') ? showSave  : false; %>
<% var __backHref  = (typeof backHref  !== 'undefined') ? backHref  : '/main'; %>

<div class="ir-shell">
  <!-- 회의 v1.1: 탭 순서 — 사용자용 먼저, 관리자 메뉴는 맨 뒤
       (일반 / 백업 / 펌웨어 → 🔒 관리자 메뉴) — v1.1 용어 통일 -->

  <div class="ir-tabs">
    <a class="ir-tab <%= __activeTab === 'general' ? 'is-active' : '' %>"     href="/settings/general"     data-i18n="tab.general">장비 설정</a>
    <a class="ir-tab <%= __activeTab === 'backup' ? 'is-active' : '' %>"      href="/settings/backup"      data-i18n="tab.backup">백업 / 복구</a>
    <a class="ir-tab <%= __activeTab === 'firmware' ? 'is-active' : '' %>"    href="/settings/firmware"    data-i18n="tab.firmware">펌웨어 업그레이드</a>
    <a class="ir-tab is-admin <%= __activeTab === 'engineering' ? 'is-active' : '' %>" href="/settings/engineering" data-i18n="tab.engineering">🔒 관리자 메뉴</a>

    <div style="flex:1;"></div>

    <div class="ir-action-row" style="align-self:flex-start;margin-top:0;">
      <% if (__showSave) { %>
        <button class="ir-btn" data-ir-save>저장</button>
      <% } %>
      <a class="ir-btn" href="<%= __backHref %>">복귀</a>
    </div>
  </div>

  <div class="ir-divider"></div>

  <div class="ir-content" style="padding-top:0;">
