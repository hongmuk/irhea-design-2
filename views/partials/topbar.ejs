<div class="topbar">
  <div class="brand">
    <img class="brand-logo" src="/img/irhea-logo.png" alt="iRhea" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
    <span class="logo-fallback" style="display:none; font-family:var(--font-display); font-weight:700; font-size:22px; color:var(--gold);">iRHEA</span>
    <span class="brand-divider"></span>
    <span class="brand-sub"><b>M5 PRO</b> · 1호기</span>
  </div>
  <div class="topbar-right">
    <!-- 홈 아이콘은 사이드바로 이관 (회의 피드백: 다른 메뉴는 다 사이드바인데 홈만 위에 있으면 위화감) -->

    <!-- 언어 토글 — 회의 피드백 v1.2: 실제 작동하도록 (i18n.js 연동) -->
    <button class="tb-lang-wrap" id="tb-lang-btn" type="button" style="display:flex; align-items:center; gap:4px; border:1px solid var(--hair-2); padding:8px 12px; min-height:var(--tap-min); border-radius:var(--radius-sm); cursor:pointer; background:transparent; font-family:inherit;">
      <span id="tb-lang-label" style="font-weight:700; font-size:12px; color:var(--ink);">KO</span>
      <span style="font-size:10px; opacity:0.5;">▼</span>
    </button>

    <span class="tb-sep"></span>
    <!-- v1.1 S2.1.2 — 메인 헤더 보강: 클라우드 접속 / 총 추출 / 타임존 -->
    <span class="tb-stat" id="top-cloud" title="AWS 클라우드 접속 상태"><span class="tb-cloud-ico">📡</span><span class="tb-val">클라우드</span></span>
    <span class="tb-sep"></span>
    <span class="tb-stat" id="top-totalbrew" title="설치 후 누적 추출"><span class="tb-lbl">총 추출</span><span class="tb-val" id="top-totalbrew-val">—</span><span class="tb-tz" style="font-size:10px; margin-left:2px; opacity:0.6;">회</span></span>
    <span class="tb-sep"></span>
    <span class="tb-stat"><span class="tb-lbl">Boiler</span><span class="tb-val">95.0°</span></span>
    <span class="tb-sep"></span>
    <span class="tb-stat"><span class="tb-val" id="top-clock">--:--</span><span class="tb-tz" style="font-size:10px; margin-left:3px; opacity:0.6;" id="top-tz">KST · UTC+9</span></span>
    <span class="tb-sep"></span>
    <!-- 5/13 §1: 연결 정상 = 초록, 오류 = 빨강 -->
    <span class="tb-live tb-live-ok" id="top-live"><span class="tb-live-dot"></span>연결됨</span>
    <button class="btn-shutdown" id="btn-shutdown-top" aria-label="종료" title="종료">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18.36 6.64a9 9 0 11-12.73 0"/>
        <line x1="12" y1="2" x2="12" y2="12"/>
      </svg>
    </button>
  </div>
</div>

<script>
  (function() {
    function updateClock() {
      const now = new Date();
      const h = String(now.getHours()).padStart(2, '0');
      const m = String(now.getMinutes()).padStart(2, '0');
      const el = document.getElementById('top-clock');
      if (el) el.textContent = h + ':' + m;
    }
    setInterval(updateClock, 1000);
    updateClock();

    // v1.1 S2.1.2 — 총 추출 합 (spouts.extractCount 누적)
    function updateTotalBrew() {
      fetch('/api/spouts').then(function (r) { return r.json(); }).then(function (sps) {
        var total = (sps || []).reduce(function (s, sp) { return s + (sp.extractCount || 0); }, 0);
        var el = document.getElementById('top-totalbrew-val');
        if (el) el.textContent = total.toLocaleString();
      }).catch(function () {});
    }
    setInterval(updateTotalBrew, 5000);
    updateTotalBrew();

    document.getElementById('btn-shutdown-top')?.addEventListener('click', function() {
      // Shutdown flow per designs/02-shutdown-progress.html → 02-shutdown-complete.html.
      // STEP1: progress modal (blocking, no buttons) → STEP2: complete modal.
      if (!window.IRModal) return;
      window.IRModal.confirm({
        title: '장비 종료',
        body: '장비를 종료하시겠습니까?',
        ok: '종료',
        onOk: function () {
          // STEP1: 종료 진행 (블로킹 2.5s)
          window.IRModal.info({
            title: '장비 종료 진행 중',
            body: '<span class="ir-modal-ico">⏳</span>장비를 종료합니다.<br>기다려 주세요',
            buttons: []
          });
          setTimeout(function () {
            // STEP2: 완료 (버튼 없음 — 물리 스위치 OFF 대기)
            window.IRModal.info({
              title: '종료 완료',
              body: '장비 종료 완료<br>전원 스위치를 꺼<br>주세요.',
              buttons: []
            });
          }, 2500);
        }
      });
    });

    // 언어 토글 — i18n.js 와 연동 (회의 피드백 v1.2)
    function syncLangLabel() {
      var label = document.getElementById('tb-lang-label');
      if (label && window.IRI18n) label.textContent = window.IRI18n.lang.toUpperCase();
    }
    syncLangLabel();
    document.getElementById('tb-lang-btn')?.addEventListener('click', function () {
      if (!window.IRI18n) return;
      var next = window.IRI18n.lang === 'ko' ? 'en' : 'ko';
      window.IRI18n.set(next);
      syncLangLabel();
      window.IRToast?.show(next === 'ko' ? '한국어로 변경되었습니다.' : 'Changed to English.');
    });
  })();
</script>
