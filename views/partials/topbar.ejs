<div class="topbar">
  <div class="brand">
    <img class="brand-logo" src="/img/irhea-logo.png" alt="iRhea" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';">
    <span class="logo-fallback" style="display:none; font-family:var(--font-display); font-weight:700; font-size:22px; color:var(--gold);">iRHEA</span>
    <span class="brand-divider"></span>
    <span class="brand-sub"><b>M5 PRO</b> · 1호기</span>
  </div>
  <div class="topbar-right">
    <a href="/main" class="tb-home" style="text-decoration:none; color:inherit; font-size:18px;" title="홈 (메인)">⌂</a>
    
    <!-- Demo-style Language Switcher -->
    <div class="tb-lang-wrap" style="display:flex; align-items:center; gap:4px; border:1px solid var(--hair-2); padding:2px 6px; border-radius:var(--radius-sm); cursor:pointer;">
      <span style="font-weight:700; font-size:12px; color:var(--ink);">KO</span>
      <span style="font-size:10px; opacity:0.5;">▼</span>
    </div>

    <span class="tb-sep"></span>
    <span class="tb-stat"><span class="tb-lbl">Boiler</span><span class="tb-val">95.0°</span></span>
    <span class="tb-sep"></span>
    <span class="tb-stat"><span class="tb-val" id="top-clock">--:--</span><span class="tb-tz" style="font-size:10px; margin-left:3px; opacity:0.6;">KST</span></span>
    <span class="tb-sep"></span>
    <span class="tb-live">연결됨</span>
    <button class="btn-shutdown" id="btn-shutdown-top" aria-label="종료" title="종료">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M18.36 6.64a9 9 0 11-12.73 0"/>
        <line x1="12" y1="2" x2="12" y2="12"/>
      </svg>
    </button>
  </div>
</div>

<script>
  (function() {
    function updateClock() {
      const now = new Date();
      const h = String(now.getHours()).padStart(2, '0');
      const m = String(now.getMinutes()).padStart(2, '0');
      const el = document.getElementById('top-clock');
      if (el) el.textContent = h + ':' + m;
    }
    setInterval(updateClock, 1000);
    updateClock();

    document.getElementById('btn-shutdown-top')?.addEventListener('click', function() {
      // Shutdown flow per designs/02-shutdown-progress.html → 02-shutdown-complete.html.
      // STEP1: progress modal (blocking, no buttons) → STEP2: complete modal.
      if (!window.IRModal) return;
      window.IRModal.confirm({
        title: '알림',
        body: '장비를 종료하시겠습니까?',
        onOk: function () {
          // STEP1: progress (blocking 2.5s)
          window.IRModal.info({
            body: '⏳<br>장비를 종료합니다.<br>기다려 주세요',
            buttons: []
          });
          setTimeout(function () {
            // STEP2: complete (no buttons, waiting for physical power off)
            window.IRModal.info({
              body: '장비 종료 완료<br>전원 스위치를 꺼<br>주세요.',
              buttons: []
            });
          }, 2500);
        }
      });
    });

    // Simple language toggle simulation
    document.querySelector('.tb-lang-wrap')?.addEventListener('click', function() {
       const lang = this.querySelector('span').textContent;
       this.querySelector('span').textContent = (lang === 'KO' ? 'EN' : 'KO');
       window.IRToast?.show((lang === 'KO' ? 'English' : '한국어') + '로 변경되었습니다.');
    });
  })();
</script>
