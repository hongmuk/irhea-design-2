<meta charset="UTF-8">
<!-- viewport-fit=cover: 노치/안전영역까지 화면 활용 (풀스크린 PWA 모드 대비) -->
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>iRHEA-Light | <%= title %></title>

<!-- ── PWA / 풀스크린 kiosk 메타 ─────────────────────────────────────────
     태블릿 홈 화면에 추가하면 manifest 의 display: fullscreen 으로 실행.
     iOS Safari (PWA standalone) + Android Chrome (fullscreen) 모두 커버. -->
<link rel="manifest" href="/manifest.json">
<meta name="theme-color" content="#C5A059">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="iRHEA">
<link rel="apple-touch-icon" href="/img/app-icon.svg">
<link rel="icon" type="image/svg+xml" href="/img/app-icon.svg">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,400;0,500;1,400;1,500&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css">
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="/css/app.css">
<link rel="stylesheet" href="/css/theme-irhea.css">
<script src="/js/state.js"></script>
<script src="/js/recipe-picker.js"></script>
<script src="/js/i18n.js"></script>
<script src="/js/error-handler.js"></script>
<script src="/js/fullscreen.js" defer></script>
