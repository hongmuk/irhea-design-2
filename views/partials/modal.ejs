<!--
  iRHEA-Light — 표준 알림 모달 컨테이너 + 8 사전정의 알림.
  공통 트리거: window.IRModal.open(id) / window.IRModal.confirm({...})
  표준 ID:
    alert-password-error
    alert-extract-press
    alert-shutdown
    alert-shutdown-done
    confirm-firmware
    confirm-connection-change
    confirm-connection-fail
    confirm-irreversible
  ad-hoc 모달은 confirm({title, body, ok, cancel, onOk, onCancel}) 사용.
-->

<div class="ir-modal-overlay" id="ir-modal-overlay" data-modal-root>
  <div class="ir-modal" id="ir-modal" role="dialog" aria-modal="true" aria-labelledby="ir-modal-title">
    <div class="ir-modal-header" id="ir-modal-title">알림</div>
    <div class="ir-modal-body" id="ir-modal-body">메시지</div>
    <div class="ir-modal-actions" id="ir-modal-actions"></div>
  </div>
</div>

<script>
(function () {
  // Standard preset alerts — wireframe v6.0 9.2 + FLOW.3 팝업 12종(4종 신규) 매핑
  // 회의 §14: O/X → 직관 텍스트. v1.1 신규는 P-RECIPE-*, P-WIFI-*, P-SERIAL-*.
  var PRESETS = {
    // ─ v0.9 명세 원본 (image2/5/7/9/11/23/24/26/27) ─
    'alert-password-error':     { title: '암호 오류',           body: '암호 오류<br><span style="font-size:11px;color:#666;">5회 실패 시 10분 잠금</span>', bodyClass: 'is-error', buttons: [{ label: '닫기' }] },
    'alert-extract-press':      { title: '추출 진행',           body: '추출 진행<br>추출구의 버튼을 눌러주세요', buttons: [{ label: '닫기' }] },
    'alert-shutdown':           { title: '알림',                body: '장비를 종료합니다.<br>기다려 주세요', buttons: [] },
    'alert-shutdown-done':      { title: '알림',                body: '장비 종료 완료<br>전원 스위치를 꺼주세요.', buttons: [{ label: '확인', primary: true }] },
    'confirm-firmware':         { title: '펌웨어 업그레이드',    body: '펌웨어를 업그레이드 합니다.<br>업그레이드 중 전원을 끄지 마세요.', buttons: [{ label: '진행', primary: true, value: 'ok' }, { label: '취소', value: 'cancel' }] },
    'confirm-connection-change':{ title: '장치 연결 변경',       body: '장치 연결 설정을 변경 합니다.', buttons: [{ label: '변경', primary: true, value: 'ok' }, { label: '취소', value: 'cancel' }] },
    'confirm-connection-fail':  { title: '연결 실패',            body: '연결 실패<br>재시도하시겠습니까?', bodyClass: 'is-error', buttons: [{ label: '재시도', primary: true, value: 'ok' }, { label: '재검색', value: 'cancel' }] },
    'confirm-irreversible':     { title: '복구불가',             body: '복구불가<br>진행하시겠습니까?', bodyClass: 'is-error', buttons: [{ label: '진행', primary: true, value: 'ok' }, { label: '취소', value: 'cancel' }] },

    // ─ v1.1 신규 (FLOW.3 12종 중 4종) ─
    'alert-wifi-fail':          { title: 'WiFi 인증 실패',       body: '잘못된 비밀번호입니다.<br>PW를 다시 입력해 주세요.', bodyClass: 'is-error', buttons: [{ label: '닫기' }] },
    'alert-serial-mismatch':    { title: '시리얼 불일치',         body: '시리얼 매칭 실패.<br>장비 시리얼 번호를 다시 확인해 주세요.', bodyClass: 'is-error', buttons: [{ label: '닫기' }] },
    'confirm-recipe-validate-1':{ title: 'Stage 합계 불일치',     body: '스테이지 합계가 100%가 아닙니다.<br>자동 보정하시겠습니까?', buttons: [{ label: '자동 보정', primary: true, value: 'ok' }, { label: '직접 수정', value: 'cancel' }] },
    'alert-recipe-validate-2':  { title: '유속 한계 초과',        body: '유속이 펌프 한계를 초과합니다.<br>최대값으로 조정 후 저장합니다.', bodyClass: 'is-error', buttons: [{ label: '최대값 적용', primary: true, value: 'ok' }, { label: '직접 수정', value: 'cancel' }] },
    'confirm-recipe-conflict':  { title: '즐겨찾기 매핑 충돌',    body: '이미 즐겨찾기에 등록된 추출구가 있습니다.<br>어떻게 할까요?', buttons: [{ label: '덮어쓰기', primary: true, value: 'overwrite' }, { label: '기존 해제', value: 'release' }, { label: '취소', value: 'cancel' }] },
    'confirm-recipe-runtime':   { title: '추출 결과 ±20% 초과',  body: '첫 추출 결과가 목표값 대비 ±20%를 벗어납니다.<br>레시피 보정을 권장합니다.', buttons: [{ label: '보정 (편집)', primary: true, value: 'edit' }, { label: '기록만', value: 'log' }, { label: '무시', value: 'cancel' }] },

    // ─ 에러 다양화 (§14 통신끊김/응답없음/장비저장실패) ─
    'alert-comms-lost':         { title: '통신 끊김',             body: '장비와의 통신이 끊겼습니다.<br>케이블·전원·WiFi를 확인해 주세요.', bodyClass: 'is-error', buttons: [{ label: '재시도', primary: true, value: 'ok' }, { label: '닫기', value: 'cancel' }] },
    'alert-device-timeout':     { title: '응답 없음',             body: '장비가 응답하지 않습니다.<br>잠시 후 다시 시도해 주세요.', bodyClass: 'is-error', buttons: [{ label: '재시도', primary: true, value: 'ok' }, { label: '닫기', value: 'cancel' }] },
    'alert-save-failed':        { title: '장비 저장 실패',         body: '설정 저장에 실패했습니다.<br>잠시 후 다시 시도해 주세요.', bodyClass: 'is-error', buttons: [{ label: '재시도', primary: true, value: 'ok' }, { label: '닫기', value: 'cancel' }] },
    'alert-usb-missing':        { title: 'USB 미인식',            body: 'USB가 연결되지 않았습니다.<br>USB를 꽂은 후 다시 시도해 주세요.', bodyClass: 'is-error', buttons: [{ label: '닫기' }] },
    'alert-usb-no-space':       { title: 'USB 용량 부족',         body: 'USB 저장 공간이 부족합니다.<br>다른 USB를 사용해 주세요.', bodyClass: 'is-error', buttons: [{ label: '닫기' }] }
  };

  function el(id) { return document.getElementById(id); }

  function renderActions(buttons, onClick) {
    var actions = el('ir-modal-actions');
    actions.innerHTML = '';
    buttons.forEach(function (b) {
      var btn = document.createElement('button');
      btn.className = 'ir-modal-btn' + (b.primary ? ' is-primary' : '');
      btn.textContent = b.label;
      btn.dataset.value = b.value || b.label;
      btn.addEventListener('click', function () { onClick(b.value || b.label); });
      actions.appendChild(btn);
    });
  }

  function openWith(opts) {
    var overlay = el('ir-modal-overlay');
    el('ir-modal-title').textContent = opts.title || '알림';
    var body = el('ir-modal-body');
    body.innerHTML = opts.body || '';
    body.className = 'ir-modal-body' + (opts.bodyClass ? ' ' + opts.bodyClass : '');
    renderActions(opts.buttons || [{ label: '확인', primary: true }], function (val) {
      overlay.classList.remove('is-open');
      if (typeof opts.onClose === 'function') opts.onClose(val);
    });
    overlay.classList.add('is-open');
  }

  window.IRModal = {
    open: function (id, onClose) {
      var p = PRESETS[id];
      if (!p) {
        console.warn('IRModal: unknown preset', id);
        return;
      }
      openWith({
        title: p.title || '알림',
        body: p.body,
        bodyClass: p.bodyClass,
        buttons: p.buttons,
        onClose: onClose
      });
    },
    confirm: function (opts) {
      // opts: { title, body, bodyClass, ok = '확인', cancel = '취소', onOk, onCancel }
      var buttons = [
        { label: opts.ok || '확인', primary: true, value: 'ok' },
        { label: opts.cancel || '취소', value: 'cancel' }
      ];
      openWith({
        title: opts.title || '알림',
        body: opts.body || '',
        bodyClass: opts.bodyClass,
        buttons: buttons,
        onClose: function (v) {
          if (v === 'ok' && typeof opts.onOk === 'function') opts.onOk();
          if (v === 'cancel' && typeof opts.onCancel === 'function') opts.onCancel();
        }
      });
    },
    info: function (opts) {
      openWith({
        title: opts.title || '알림',
        body: opts.body || '',
        bodyClass: opts.bodyClass,
        buttons: opts.buttons || [{ label: '확인', primary: true }],
        onClose: opts.onClose
      });
    },
    close: function () {
      var overlay = el('ir-modal-overlay');
      if (overlay) overlay.classList.remove('is-open');
    }
  };

  // Close on overlay click (only when click target is overlay itself)
  document.addEventListener('click', function (ev) {
    var overlay = el('ir-modal-overlay');
    if (!overlay || !overlay.classList.contains('is-open')) return;
    if (ev.target === overlay) {
      // Don't auto-close if there are no buttons (forced wait modal)
      var hasButtons = el('ir-modal-actions').children.length > 0;
      if (hasButtons) overlay.classList.remove('is-open');
    }
  });
})();
</script>
